--- release.yml ---
name: Release

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:
    inputs:
      tag:
        description: 'Release tag to build and publish, for example v0.2.0'
        required: true
        type: string
      release_notes:
        description: 'Release notes body. Leave empty to use a default message.'
        required: false
        type: string
        default: ''

permissions:
  contents: write

concurrency:
  group: release-${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
  cancel-in-progress: false

jobs:
  build:
    name: Build ${{ matrix.platform }}
    runs-on: ${{ matrix.runner }}
    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: windows
            runner: windows-latest
            package_script: package:win
          - platform: macos
            runner: macos-latest
            package_script: package:mac
          - platform: linux
            runner: ubuntu-24.04
            package_script: package:linux

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Install Linux packaging dependencies
        if: matrix.platform == 'linux'
        run: |
          sudo apt-get update
          sudo apt-get install --no-install-recommends -y build-essential libfuse2 ruby ruby-dev
          sudo gem install --no-document fpm

      - name: Package ${{ matrix.platform }}
        run: npm run ${{ matrix.package_script }} -- --publish never
        env:
          CSC_IDENTITY_AUTO_DISCOVERY: false

      - name: Upload ${{ matrix.platform }} artifacts
        uses: actions/upload-artifact@v4
        with:
          name: autoplan-${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}-${{ matrix.platform }}
          path: |
            release/*.exe
            release/*.blockmap
            release/*.dmg
            release/*.zip
            release/*.AppImage
            release/*.deb
            release/latest*.yml
          if-no-files-found: error
          retention-days: 14

  release:
    name: Publish GitHub Release
    runs-on: ubuntu-latest
    needs: build
    env:
      GH_TOKEN: ${{ github.token }}
      RELEASE_TAG: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}

    steps:
      - name: Checkout tag metadata
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
          fetch-depth: 0

      - name: Download packaged artifacts
        uses: actions/download-artifact@v4
        with:
          path: dist-artifacts

      - name: Resolve release notes
        shell: bash
        env:
          DISPATCH_NOTES: ${{ github.event_name == 'workflow_dispatch' && inputs.release_notes || '' }}
        run: |
          set -euo pipefail

          if [[ -n "${DISPATCH_NOTES}" ]]; then
            printf '%s\n' "${DISPATCH_NOTES}" > release-notes.md
          elif git cat-file -e "refs/tags/${RELEASE_TAG}^{tag}" 2>/dev/null; then
            git tag -l "${RELEASE_TAG}" --format='%(contents)' > release-notes.md
          else
            git log -1 --pretty='format:- %s (%h)%n' > release-notes.md
          fi

          if [[ ! -s release-notes.md ]]; then
            printf 'Automated release for %s.\n' "${RELEASE_TAG}" > release-notes.md
          fi

      - name: Create or update release
        shell: bash
        run: |
          set -euo pipefail

          mapfile -d '' files < <(
            find dist-artifacts -type f \( \
              -name '*.exe' -o \
              -name '*.blockmap' -o \
              -name '*.dmg' -o \
              -name '*.zip' -o \
              -name '*.AppImage' -o \
              -name '*.deb' -o \
              -name 'latest*.yml' \
            \) -print0
          )
          if [[ ${#files[@]} -eq 0 ]]; then
            echo "No release artifacts found." >&2
            exit 1
          fi

          if gh release view "${RELEASE_TAG}" >/dev/null 2>&1; then
            gh release edit "${RELEASE_TAG}" --title "${RELEASE_TAG}" --notes-file release-notes.md
            gh release upload "${RELEASE_TAG}" "${files[@]}" --clobber
          else
            gh release create "${RELEASE_TAG}" "${files[@]}" --title "${RELEASE_TAG}" --notes-file release-notes.md
          fi
--- package.json ---
{
  "name": "autoplan",
  "version": "0.2.0",
  "description": "Electron app for issue-driven autonomous planning and development loops.",
  "author": "lyming99 <lyming99@users.noreply.github.com>",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev": "node scripts/dev.js",
    "build": "tsc --noEmit && vite build",
    "package:win": "npm run build && electron-builder --win nsis --x64",
    "package:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64",
    "package:linux": "npm run build && electron-builder --linux AppImage deb --x64",
    "package:all": "npm run build && electron-builder --win nsis --mac dmg zip --linux AppImage deb --x64",
    "check": "tsc --noEmit && node --check src/main.js && node --check src/agentCli.js && node --check src/attachments.js && node --check src/database.js && node --check src/loopService.js && node --check src/preload.js && node --check scripts/dev.js && node --check scripts/smoke-test.js",
    "smoke": "node scripts/smoke-test.js"
  },
  "build": {
    "appId": "com.autoplan.desktop",
    "productName": "AutoPlan",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "toolsets": {
      "appimage": "1.0.3"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^33.3.2",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
