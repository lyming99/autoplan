--- release line numbers ---
   1: name: Release
   2: 
   3: on:
   4:   push:
   5:     tags:
   6:       - 'v*'
   7:   workflow_dispatch:
   8:     inputs:
   9:       tag:
  10:         description: 'Release tag to build and publish, for example v0.2.0'
  11:         required: true
  12:         type: string
  13:       release_notes:
  14:         description: 'Release notes body. Leave empty to use a default message.'
  15:         required: false
  16:         type: string
  17:         default: ''
  18: 
  19: permissions:
  20:   contents: write
  21: 
  22: concurrency:
  23:   group: release-${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
  24:   cancel-in-progress: false
  25: 
  26: jobs:
  27:   build:
  28:     name: Build ${{ matrix.platform }}
  29:     runs-on: ${{ matrix.runner }}
  30:     strategy:
  31:       fail-fast: false
  32:       matrix:
  33:         include:
  34:           - platform: windows
  35:             runner: windows-latest
  36:             package_script: package:win
  37:           - platform: macos
  38:             runner: macos-latest
  39:             package_script: package:mac
  40:           - platform: linux
  41:             runner: ubuntu-24.04
  42:             package_script: package:linux
  43: 
  44:     steps:
  45:       - name: Checkout
  46:         uses: actions/checkout@v4
  47:         with:
  48:           ref: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
  49: 
  50:       - name: Setup Node.js
  51:         uses: actions/setup-node@v4
  52:         with:
  53:           node-version: 22
  54:           cache: npm
  55: 
  56:       - name: Install dependencies
  57:         run: npm ci
  58: 
  59:       - name: Install Linux packaging dependencies
  60:         if: matrix.platform == 'linux'
  61:         run: |
  62:           sudo apt-get update
  63:           sudo apt-get install --no-install-recommends -y build-essential libfuse2 ruby ruby-dev
  64:           sudo gem install --no-document fpm
  65: 
  66:       - name: Package ${{ matrix.platform }}
  67:         run: npm run ${{ matrix.package_script }} -- --publish never
  68:         env:
  69:           CSC_IDENTITY_AUTO_DISCOVERY: false
  70: 
  71:       - name: Upload ${{ matrix.platform }} artifacts
  72:         uses: actions/upload-artifact@v4
  73:         with:
  74:           name: autoplan-${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}-${{ matrix.platform }}
  75:           path: |
  76:             release/*.exe
  77:             release/*.blockmap
  78:             release/*.dmg
  79:             release/*.zip
  80:             release/*.AppImage
  81:             release/*.deb
  82:             release/latest*.yml
  83:           if-no-files-found: error
  84:           retention-days: 14
  85: 
  86:   release:
  87:     name: Publish GitHub Release
  88:     runs-on: ubuntu-latest
  89:     needs: build
  90:     env:
  91:       GH_TOKEN: ${{ github.token }}
  92:       RELEASE_TAG: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
  93: 
  94:     steps:
  95:       - name: Checkout tag metadata
  96:         uses: actions/checkout@v4
  97:         with:
  98:           ref: ${{ github.event_name == 'workflow_dispatch' && inputs.tag || github.ref_name }}
  99:           fetch-depth: 0
 100: 
 101:       - name: Download packaged artifacts
 102:         uses: actions/download-artifact@v4
 103:         with:
 104:           path: dist-artifacts
 105: 
 106:       - name: Resolve release notes
 107:         shell: bash
 108:         env:
 109:           DISPATCH_NOTES: ${{ github.event_name == 'workflow_dispatch' && inputs.release_notes || '' }}
 110:         run: |
 111:           set -euo pipefail
 112: 
 113:           if [[ -n "${DISPATCH_NOTES}" ]]; then
 114:             printf '%s\n' "${DISPATCH_NOTES}" > release-notes.md
 115:           elif git cat-file -e "refs/tags/${RELEASE_TAG}^{tag}" 2>/dev/null; then
 116:             git tag -l "${RELEASE_TAG}" --format='%(contents)' > release-notes.md
 117:           else
 118:             git log -1 --pretty='format:- %s (%h)%n' > release-notes.md
 119:           fi
 120: 
 121:           if [[ ! -s release-notes.md ]]; then
 122:             printf 'Automated release for %s.\n' "${RELEASE_TAG}" > release-notes.md
 123:           fi
 124: 
 125:       - name: Create or update release
 126:         shell: bash
 127:         run: |
 128:           set -euo pipefail
 129: 
 130:           mapfile -d '' files < <(
 131:             find dist-artifacts -type f \( \
 132:               -name '*.exe' -o \
 133:               -name '*.blockmap' -o \
 134:               -name '*.dmg' -o \
 135:               -name '*.zip' -o \
 136:               -name '*.AppImage' -o \
 137:               -name '*.deb' -o \
 138:               -name 'latest*.yml' \
 139:             \) -print0
 140:           )
 141:           if [[ ${#files[@]} -eq 0 ]]; then
 142:             echo "No release artifacts found." >&2
 143:             exit 1
 144:           fi
 145: 
 146:           if gh release view "${RELEASE_TAG}" >/dev/null 2>&1; then
 147:             gh release edit "${RELEASE_TAG}" --title "${RELEASE_TAG}" --notes-file release-notes.md
 148:             gh release upload "${RELEASE_TAG}" "${files[@]}" --clobber
 149:           else
 150:             gh release create "${RELEASE_TAG}" "${files[@]}" --title "${RELEASE_TAG}" --notes-file release-notes.md
 151:           fi

