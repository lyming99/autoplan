+  return new Set(defaultGroups.map((group) => group.key));
+}
+
+function formatTaskPlanGroupCounts(group: TaskPlanGroup) {
+  return `${group.stats.total} 个任务 · 进行中 ${group.stats.running} · 已完成 ${group.stats.completed}`;
