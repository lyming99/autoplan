--- styles.css ---
@import './renderer/styles/layout.css';

@import './renderer/styles/components.css';

@import './renderer/styles/workspace.css';

.task-plan-group-toggle {
  width: 100%;
  border: 0;
  border-radius: var(--r-md);
  background: transparent;
  color: inherit;
  cursor: pointer;
  text-align: left;
}

.task-plan-group-toggle:hover {
  background: var(--bg-hover);
}

.task-plan-group-toggle:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px var(--brand-50);
}

.task-plan-group-title-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1 1 auto;
}

.task-plan-group-chevron {
  display: inline-grid;
  place-items: center;
  width: 18px;
  height: 18px;
  flex: 0 0 auto;
  border-radius: 999px;
  background: var(--bg-soft);
  color: var(--text-3);
  font-size: 11px;
  transition: transform 0.14s ease, background 0.14s ease, color 0.14s ease;
}

.task-plan-group.is-collapsed .task-plan-group-chevron {
  transform: rotate(-90deg);
}

.task-plan-group-meta {
  display: inline-flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-items: center;
  gap: 6px;
  max-width: 56%;
  min-width: 0;
}

.task-plan-group-counts {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 2px 8px;
  border: 1px solid var(--line-soft);
  border-radius: 999px;
  background: var(--bg-soft);
  color: var(--text-2);
  font-size: 11px;
  font-weight: 700;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-plan-group-items {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.task-plan-group.is-collapsed {
  gap: 0;
}

.task-plan-group.is-collapsed .task-plan-group-toggle {
  padding-bottom: 2px;
}

@media (max-width: 760px) {
  .task-plan-group-meta {
    width: 100%;
    max-width: 100%;
    justify-content: flex-start;
  }

  .task-plan-group-toggle {
    align-items: flex-start;
  }
}
