  92:   const time = Date.parse(String(value || ''));
  93:   return Number.isFinite(time) ? time : null;
  94: }
  95: 
  96: function taskSortTime(task: TimedPlanTask) {
  97:   return readTaskTime(task.finished_at) ?? readTaskTime(task.started_at) ?? readTaskTime(task.updated_at);
  98: }
  99: 
 100: function latestTaskTime(tasks: TimedPlanTask[]) {
 101:   const fieldGroups: Array<Array<keyof TimedPlanTask>> = [['finished_at'], ['started_at'], ['updated_at']];
 102:   for (const fields of fieldGroups) {
 103:     const times = tasks.flatMap((task) => fields.map((field) => readTaskTime(task[field] as string | null | undefined)));
 104:     const validTimes = times.filter((time): time is number => time !== null);
 105:     if (validTimes.length) return Math.max(...validTimes);
 106:   }
 107:   return null;
 108: }
 109: 
 110: function latestTaskTimestamp(tasks: TimedPlanTask[], field: 'finished_at' | 'updated_at') {
 111:   let latestValue = '';
 112:   let latestTime: number | null = null;
 113:   tasks.forEach((task) => {
 114:     const value = task[field];
 115:     const time = readTaskTime(value);
 116:     if (time === null) return;
 117:     if (latestTime === null || time > latestTime) {
 118:       latestTime = time;
 119:       latestValue = value || '';
 120:     }
 121:   });
 122:   return latestValue;
 123: }
 124: 
 125: export function formatTaskPlanGroupSummary(group: TaskPlanGroup) {
 126:   const timedTasks = group.tasks as TimedPlanTask[];
 127:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
 128:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
 129:   const timeSummary = latestFinishedAt
 130:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
 131:     : latestUpdatedAt
 132:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
 133:       : '暂无时间记录';
 134:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
 135: }
 136: 
 137: function taskPlanGroupTitle(task: PlanTask) {
 138:   return String(task.plan_title || readPlanTaskAssociationFilePath(task) || '未命名计划').trim() || '未命名计划';
 139: }
 140: 
 141: function taskPlanGroupIdentity(task: TimedPlanTask): TaskPlanGroupIdentity {
 142:   const planId = readPlanId(task);
 143:   if (planId !== null) return { key: `plan:${planId}`, source: 'plan', sourceId: String(planId) };
 144:   const filePath = readPlanTaskAssociationFilePath(task);
 145:   if (filePath) return { key: `file:${filePath}`, source: 'file', sourceId: filePath };
 146:   const title = taskPlanGroupTitle(task);
 147:   if (title !== '未命名计划') return { key: `title:${title}`, source: 'title', sourceId: title };
 148:   return { key: 'unknown-plan', source: 'unknown', sourceId: null };
 149: }
 150: 
 151: function getTaskPlanGroupStats(tasks: PlanTask[]): TaskPlanGroupStats {
 152:   return tasks.reduce<TaskPlanGroupStats>(
 153:     (stats, task) => ({
 154:       total: stats.total + 1,
 155:       running: stats.running + (matchesTaskStatusFilter(task, 'running') ? 1 : 0),
 156:       completed: stats.completed + (matchesTaskStatusFilter(task, 'completed') ? 1 : 0),
 157:     }),
 158:     { total: 0, running: 0, completed: 0 },
 159:   );
 160: }
 161: 
 162: export function groupTasksByPlan(tasks: PlanTask[]) {
 163:   const groups = new Map<string, TaskPlanGroup>();
 164:   tasks.forEach((task, index) => {
 165:     const timedTask = task as TimedPlanTask;
 166:     const identity = taskPlanGroupIdentity(timedTask);
 167:     const key = identity.key;
 168:     const existingGroup = groups.get(key);
 169:     if (existingGroup) {
 170:       existingGroup.tasks.push(task);
 171:       if (existingGroup.title === '未命名计划') existingGroup.title = taskPlanGroupTitle(task);
 172:       return;
 173:     }
 174: 
 175:     groups.set(key, {
 176:       key,
 177:       source: identity.source,
 178:       sourceId: identity.sourceId,
 179:       title: taskPlanGroupTitle(task),
 180:       tasks: [task],
 181:       firstIndex: index,
 182:       sortTime: null,
 183:       stats: { total: 0, running: 0, completed: 0 },
 184:       hasRunningTask: false,
 185:     });
 186:   });
 187: 
 188:   return Array.from(groups.values())
 189:     .map((group) => {
 190:       const indexedTasks = group.tasks.map((task, index) => ({ task, index }));
 191:       const sortedTasks = indexedTasks
 192:         .sort((left, right) => {
 193:           const leftTime = taskSortTime(left.task as TimedPlanTask);
 194:           const rightTime = taskSortTime(right.task as TimedPlanTask);
 195:           if (leftTime !== null && rightTime !== null && leftTime !== rightTime) return rightTime - leftTime;
 196:           if (leftTime !== null && rightTime === null) return -1;
 197:           if (leftTime === null && rightTime !== null) return 1;
 198:           return left.index - right.index;
 199:         })
 200:         .map(({ task }) => task);
 201:       return {
 202:         ...group,
 203:         tasks: sortedTasks,
 204:         sortTime: latestTaskTime(group.tasks as TimedPlanTask[]),
 205:         stats: getTaskPlanGroupStats(sortedTasks),
 206:         hasRunningTask: sortedTasks.some((task) => matchesTaskStatusFilter(task, 'running')),
 207:       };
 208:     })
 209:     .sort((left, right) => {
 210:       if (left.sortTime !== null && right.sortTime !== null && left.sortTime !== right.sortTime) {
 211:         return right.sortTime - left.sortTime;
 212:       }
 213:       if (left.sortTime !== null && right.sortTime === null) return -1;
 214:       if (left.sortTime === null && right.sortTime !== null) return 1;
 215:       return left.firstIndex - right.firstIndex;
 216:     });
 217: }
 218: 
 219: export function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
 220:   const timedTasks = tasks as TimedPlanTask[];
 221:   const linkedTasks = timedTasks.filter((task) => isTaskAssociatedWithPlan(task, plan));
 222:   const hasTaskAssociations = timedTasks.some(
 223:     (task) => readPlanId(task) !== null || Boolean(readPlanTaskAssociationFilePath(task)),
 224:   );
 225:   if (!linkedTasks.length && !hasTaskAssociations && planCount === 1) return timedTasks;
 226:   return linkedTasks;
 227: }
 228: 
 229: export function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
 230:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
 231:   const completedMs = tasks.reduce(
 232:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
 233:     0,
 234:   );
 235: 
 236:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
 237: }
 238: 
 239: export function planTitle(plan: Plan) {
 240:   return String((plan as Plan & { title?: string | null }).title || '').trim();
 241: }
 242: 
 243: export function scopeFileLabel(file: PlanTask['scope_files'][number]) {
 244:   if (file.isUnknown) return 'unknown';
 245:   if (file.isValidation) return 'validation';
 246:   return file.path;
 247: }
 248: 
 249: export function scopeFileStatus(file: PlanTask['scope_files'][number]) {
 250:   if (file.isUnknown) return '无法判断影响范围';
 251:   if (file.isValidation) return '完整验收任务';
 252:   if (file.canOpen) return '可打开';
 253:   return file.reason || (file.exists ? '不可打开' : '文件不存在');
 254: }
