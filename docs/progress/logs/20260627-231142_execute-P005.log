1205: /** 直接写一个 plan markdown 文件并入库同步任务，替代旧的 planDraft 接受流程。 */
1206: function writeSmokePlan(db, loop, workspace, projectId) {
1207:   const planDir = path.join(workspace, 'docs', 'plan');
1208:   fs.mkdirSync(planDir, { recursive: true });
1209:   const planRel = path.join('docs', 'plan', 'smoke-plan.md');
1210:   const planFile = path.join(workspace, planRel);
1211:   fs.writeFileSync(
1212:     planFile,
1213:     [
1214:       '# Smoke 开发计划',
1215:       '',
1216:       '## 任务计划',
1217:       '- [ ] P001: 明确范围与影响面 <!-- scope: unknown -->',
1218:       '- [ ] P002: 完成核心实现 <!-- scope: unknown -->',
1219:       '- [ ] P003: 完成交互与异常状态 <!-- scope: unknown -->',
1220:       '- [ ] P004: 补充验证 <!-- scope: unknown -->',
1221:       '- [ ] P005: 更新文档或进度记录 <!-- scope: unknown -->',
1222:       '- [ ] P006: 完整验收 <!-- scope: validation -->',
1223:       '',
1224:     ].join('\n'),
1225:     'utf8',
1226:   );
1227:   const now = nowIso();
1228:   const planId = db.insert(
1229:     `INSERT INTO plans (project_id, issue_hash, file_path, hash, status, total_tasks, completed_tasks, validation_passed, created_at, updated_at)
1230:      VALUES (?, ?, ?, ?, ?, 0, 0, 0, ?, ?)`,
1231:     [projectId, 'smoke-plan', planRel, '', 'pending', now, now],
1232:   );
1233:   loop.syncPlanTasks(planId, planFile);
1234:   return planId;
1235: }
