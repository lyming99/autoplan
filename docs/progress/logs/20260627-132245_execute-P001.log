  206:   const body = input.body ?? current.body ?? '';
  207:   const agentCliConfig = nextIntakeAgentCliConfig(current, input);
  208:   db.run(
  209:     `UPDATE feedback
  210:      SET requirement_id = ?, title = ?, body = ?, status = ?, agent_cli_provider = ?, agent_cli_command = ?, codex_reasoning_effort = ?, updated_at = ?
  211:      WHERE id = ? AND project_id = ?`,
  212:     [
  213:       input.requirementId === undefined ? current.requirement_id || null : input.requirementId || null,
  214:       input.title ?? titleFromBody(body, '未命名反馈'),
  215:       body,
  216:       input.status ?? current.status ?? 'open',
  217:       agentCliConfig.provider,
  218:       agentCliConfig.command,
  219:       agentCliConfig.codexReasoningEffort,
  220:       nowIso(),
  221:       id,
  222:       projectId,
  223:     ],
  224:   );
  225:   saveAttachments(db, attachmentsRoot(), 'feedback', id, input.attachments, projectId);
  226:   return loop.snapshot(projectId);
  227: });
  228: 
  229: ipcMain.handle('feedback:delete', (_event, input = {}) => {
  230:   const projectId = requiredProjectId(input);
  231:   const id = requiredRecordId(input);
  232:   const rec = db.get('SELECT linked_plan_id FROM feedback WHERE id = ? AND project_id = ?', [id, projectId]);
  233:   if (rec?.linked_plan_id) loop.interruptPlan(projectId, rec.linked_plan_id);
  234:   deleteIntakeRecord('feedback', 'feedback', projectId, id);
  235:   return loop.snapshot(projectId);
  236: });
  237: 
  238: // 中断需求/反馈关联的计划任务
  239: ipcMain.handle('intake:interrupt', (_event, input = {}) => {
  240:   const projectId = requiredProjectId(input);
  241:   const table = input.type === 'feedback' ? 'feedback' : 'requirements';
  242:   const rec = db.get(`SELECT linked_plan_id FROM ${table} WHERE id = ? AND project_id = ?`, [
  243:     requiredRecordId(input),
  244:     projectId,
  245:   ]);
  246:   if (rec?.linked_plan_id) loop.interruptPlan(projectId, rec.linked_plan_id);
  247:   return loop.snapshot(projectId);
  248: });
  249: 
  250: // 恢复被中断的计划
  251: ipcMain.handle('intake:resume', (_event, input = {}) => {
  252:   const projectId = requiredProjectId(input);
  253:   const table = input.type === 'feedback' ? 'feedback' : 'requirements';
  254:   const rec = db.get(`SELECT linked_plan_id FROM ${table} WHERE id = ? AND project_id = ?`, [
  255:     requiredRecordId(input),
  256:     projectId,
  257:   ]);
  258:   if (rec?.linked_plan_id) loop.resumePlan(projectId, rec.linked_plan_id);
  259:   return loop.snapshot(projectId);
  260: });
