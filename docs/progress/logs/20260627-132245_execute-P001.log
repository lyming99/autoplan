 2415: function normalizeTaskScope(value, options = {}) {
 2416:   const scope = String(value || '')
 2417:     .trim()
 2418:     .replace(/^["'`[{(]+|["'`\]})]+$/g, '')
 2419:     .replace(/\s*--$/, '')
 2420:     .replaceAll('\\', '/')
 2421:     .toLowerCase();
 2422:   if (!scope || scope === '-') return '';
 2423:   if (scope === 'unknown') return options.keepUnknown ? 'unknown' : '';
 2424:   return scope;
 2425: }
