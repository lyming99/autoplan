  402: async function openResolvedFilePath(filePath, mode, command) {
  403:   if (mode === 'folder') {
  404:     shell.showItemInFolder(filePath);
  405:     return;
  406:   }
  407:   if (mode === 'vscode') {
  408:     await runOpenCommand(command || 'code', [filePath]);
  409:     return;
  410:   }
  411:   if (mode === 'command') {
  412:     if (!command) throw planReadError('OPEN_COMMAND_MISSING', '第三方编辑器命令未配置');
  413:     await runOpenCommand(command, [filePath], { template: command.includes('{file}') });
  414:     return;
  415:   }
  416:   const error = await shell.openPath(filePath);
  417:   if (error) throw planReadError('OPEN_FILE_FAILED', error);
  418: }
  419: 
  420: function runOpenCommand(command, args, options = {}) {
  421:   return new Promise((resolve, reject) => {
  422:     const spawnCommand = options.template ? command.replaceAll('{file}', shellQuote(args[0])) : command;
  423:     const spawnArgs = options.template ? [] : args;
  424:     const child = spawn(spawnCommand, spawnArgs, { detached: true, stdio: 'ignore', shell: process.platform === 'win32' || options.template });
  425:     child.once('error', (error) => reject(planReadError('OPEN_COMMAND_FAILED', error?.message || '编辑器命令启动失败')));
  426:     child.once('spawn', () => {
  427:       child.unref();
  428:       resolve();
  429:     });
  430:   });
  431: }
