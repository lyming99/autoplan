 1869: function taskSnapshotRow(workspace, task, operationContext = null) {
 1870:   if (!task) return task;
 1871:   const startedAt = normalizeOptionalString(task.started_at) || null;
 1872:   const finishedAt = normalizeOptionalString(task.finished_at) || null;
 1873:   const isRunning = task.status === TASK_EVENT_STATUS.RUNNING;
 1874:   const runDurationMs = isRunning ? taskRunDurationMs(startedAt, nowIso()) : undefined;
 1875:   const agentContext = agentCliContextFields(operationContext || {}, { defaultProvider: false });
 1876:   const providerForSession = agentContext.agentCliProvider || (task.codex_session_id ? DEFAULT_AGENT_CLI_PROVIDER : undefined);
 1877:   const sessionContext = providerForSession !== DEFAULT_AGENT_CLI_PROVIDER
 1878:     ? {}
 1879:     : codexSessionContextFields({
 1880:         codexSessionId: operationContext?.codexSessionId ?? task.codex_session_id,
 1881:         codexSessionRequestedId: operationContext?.codexSessionRequestedId,
 1882:         codexSessionMode: operationContext?.codexSessionMode,
 1883:         codexSessionState: operationContext?.codexSessionState,
 1884:         codexSessionFallback: operationContext?.codexSessionFallback,
 1885:       });
 1886:   return {
 1887:     ...task,
 1888:     scope_files: taskScopeFileInfos(workspace, task),
 1889:     started_at: startedAt,
 1890:     finished_at: finishedAt,
 1891:     duration_ms: normalizeDurationMs(task.duration_ms),
 1892:     ...(runDurationMs !== undefined ? { run_duration_ms: normalizeDurationMs(runDurationMs) } : {}),
 1893:     ...agentContext,
 1894:     ...sessionContext,
 1895:   };
 1896: }
