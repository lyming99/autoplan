   59: function readDurationMs(task: TimedPlanTask) {
   60:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
   61:   const duration = Number(task.duration_ms);
   62:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
   63: }
   64: 
   65: function getTaskDurationMs(task: TimedPlanTask) {
   66:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
   67:   return readDurationMs(task);
   68: }
   69: 
   70: function readPlanId(task: TimedPlanTask) {
   71:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
   72:   const planId = Number(task.plan_id);
   73:   return Number.isFinite(planId) ? planId : null;
   74: }
   75: 
   76: function formatTaskDuration(task: TimedPlanTask) {
   77:   const duration = getTaskDurationMs(task);
   78:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
   79:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
   80:   return `耗时 ${formatDuration(duration, '0秒')}`;
   81: }
   82: 
   83: function normalizeTaskStatus(status: string | null | undefined) {
   84:   return String(status || '').trim().toLowerCase();
   85: }
   86: 
   87: function matchesTaskStatusFilter(task: PlanTask, filter: TaskStatusFilter) {
   88:   const status = normalizeTaskStatus(task.status);
   89:   if (filter === 'all') return true;
   90:   if (filter === 'running') return ['running', 'processing', 'stopping'].includes(status);
   91:   if (filter === 'queued') return ['pending', 'queued', 'waiting'].includes(status);
   92:   if (filter === 'completed') return ['completed', 'done', 'passed', 'accepted'].includes(status);
   93:   return true;
   94: }
   95: 
   96: function readTaskTime(value: string | null | undefined) {
   97:   const time = Date.parse(String(value || ''));
   98:   return Number.isFinite(time) ? time : null;
   99: }
  100: 
  101: function taskSortTime(task: TimedPlanTask) {
  102:   return readTaskTime(task.finished_at) ?? readTaskTime(task.started_at) ?? readTaskTime(task.updated_at);
  103: }
  104: 
  105: function latestTaskTime(tasks: TimedPlanTask[]) {
  106:   const fieldGroups: Array<Array<keyof TimedPlanTask>> = [['finished_at'], ['started_at'], ['updated_at']];
  107:   for (const fields of fieldGroups) {
  108:     const times = tasks.flatMap((task) => fields.map((field) => readTaskTime(task[field] as string | null | undefined)));
  109:     const validTimes = times.filter((time): time is number => time !== null);
  110:     if (validTimes.length) return Math.max(...validTimes);
  111:   }
  112:   return null;
  113: }
  114: 
  115: function latestTaskTimestamp(tasks: TimedPlanTask[], field: 'finished_at' | 'updated_at') {
  116:   let latestValue = '';
  117:   let latestTime: number | null = null;
  118:   tasks.forEach((task) => {
  119:     const value = task[field];
  120:     const time = readTaskTime(value);
  121:     if (time === null) return;
  122:     if (latestTime === null || time > latestTime) {
  123:       latestTime = time;
  124:       latestValue = value || '';
  125:     }
  126:   });
  127:   return latestValue;
  128: }
  129: 
  130: function formatTaskPlanGroupSummary(group: TaskPlanGroup) {
  131:   const timedTasks = group.tasks as TimedPlanTask[];
  132:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
  133:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
  134:   const timeSummary = latestFinishedAt
  135:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
  136:     : latestUpdatedAt
  137:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
  138:       : '暂无时间记录';
  139:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
  140: }
