 2383: function taskDeclaredScopes(task, options = {}) {
 2384:   const { keepUnknown = false, includePathFallback = true } = options;
 2385:   const raw = `${task.task_key || ''} ${task.title || ''} ${task.raw_line || ''}`;
 2386:   const scopes = new Set();
 2387: 
 2388:   addScopeParts(scopes, String(task.scope || '').split(TASK_SCOPE_SPLIT_RE), { keepUnknown });
 2389:   addScopeParts(scopes, explicitTaskScopeParts(raw), { keepUnknown });
 2390: 
 2391:   if (includePathFallback) {
 2392:     for (const match of raw.matchAll(TASK_PATH_RE)) {
 2393:       const scope = normalizeTaskScope(match[0], { keepUnknown });
 2394:       if (scope && !scope.startsWith('docs/plan/') && !scope.startsWith('docs/progress/')) {
 2395:         scopes.add(scope);
 2396:       }
 2397:     }
 2398:   }
 2399: 
 2400:   return Array.from(scopes);
 2401: }
