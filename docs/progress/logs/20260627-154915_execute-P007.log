 413: .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 20px; margin-bottom: 24px; }
 414: .stat { position: relative; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
 415: .stat::after { content: ""; position: absolute; right: -18px; top: -18px; width: 84px; height: 84px; border-radius: 50%; opacity: 0.5; }
 416: .stat-brand::after { background: var(--brand-50); }
 417: .stat-info::after { background: var(--info-bg); }
 418: .stat-success::after { background: var(--success-bg); }
 419: .stat-warning::after { background: var(--warning-bg); }
 420: .stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; line-height: 0; }
--- 420-560 ---
 420: .stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; line-height: 0; }
 421: .stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }
 422: .stat-info .stat-ico { background: var(--info-bg); color: var(--info); }
 423: .stat-success .stat-ico { background: var(--success-bg); color: var(--success); }
 424: .stat-warning .stat-ico { background: var(--warning-bg); color: var(--warning); }
 425: .stat .stat-value { font-size: 26px; font-weight: 800; line-height: 1; position: relative; z-index: 1; }
 426: .stat .stat-label { font-size: 12px; color: var(--text-3); margin-top: 6px; position: relative; z-index: 1; }
 427: .stat .stat-delta { font-size: 11px; margin-top: 8px; color: var(--success); font-weight: 600; position: relative; z-index: 1; }
 428: .overview-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(380px,1fr); align-items: stretch; gap: 24px; }
 429: .overview-main-column, .overview-side-column { display: flex; flex-direction: column; gap: 20px; min-width: 0; }
 430: .overview-side-column .card-head h2 { white-space: nowrap; }
 431: .loop-card { background: var(--brand-grad); color: #fff; border-radius: var(--r-lg); padding: 22px 24px; position: relative; overflow: hidden; box-shadow: 0 18px 40px rgba(77,110,255,0.28); }
 432: .loop-card .lc-top { display: flex; align-items: center; gap: 12px; }
 433: .loop-card .lc-status { font-size: 13px; opacity: 0.9; }
 434: .loop-card .lc-phase { font-size: 22px; font-weight: 800; margin-top: 4px; }
 435: .loop-card .lc-meta { display: flex; gap: 22px; margin-top: 16px; font-size: 12px; opacity: 0.92; }
 436: .loop-card .lc-meta b { display: block; font-size: 15px; font-weight: 700; margin-top: 2px; }
 437: .loop-card .lc-led { width: 12px; height: 12px; border-radius: 50%; background: #b6f5cf; box-shadow: 0 0 0 4px rgba(182,245,207,0.25); }
 438: .loop-card .lc-led.running { animation: led-pulse 1.6s ease-in-out infinite; }
 439: .loop-card .lc-led.stopped { background: #cfd6e6; box-shadow: 0 0 0 4px rgba(207,214,230,0.25); }
