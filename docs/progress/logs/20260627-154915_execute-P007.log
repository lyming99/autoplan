 441: .pipeline { display: flex; align-items: flex-start; gap: 0; overflow-x: auto; }
 442: .pipe-step { flex: 1 1 0; min-width: 0; text-align: center; position: relative; }
 443: .pipe-node { width: 40px; height: 40px; margin: 0 auto; border-radius: 50%; display: grid; place-items: center; background: var(--bg-elevated); border: 2px solid var(--line); color: var(--text-3); font-weight: 700; font-size: 14px; position: relative; z-index: 1; }
 444: .pipe-step.done .pipe-node { background: var(--success); border-color: var(--success); color: #fff; }
 445: .pipe-step.active .pipe-node { background: var(--brand-600); border-color: var(--brand-600); color: #fff; box-shadow: 0 0 0 5px var(--brand-50); }
 446: .pipe-status-icon { --icon-size: 18px; }
 447: .pipe-step::before { content: ""; position: absolute; top: 20px; left: -50%; right: 50%; height: 2px; background: var(--line); z-index: 0; }
 448: .pipe-step:first-child::before { display: none; }
 449: .pipe-step.done::before, .pipe-step.active::before { background: var(--success); }
 450: .pipe-label { font-size: 12px; font-weight: 600; margin-top: 10px; color: var(--text-2); }
 451: .pipe-step.active .pipe-label { color: var(--brand-600); }
