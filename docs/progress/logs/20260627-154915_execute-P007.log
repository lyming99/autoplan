 296: .project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
 297: .project-card-top { display: flex; align-items: flex-start; gap: 12px; }
 298: .project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
 299: .project-info { min-width: 0; flex: 1 1 auto; }
 300: .project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 301: .project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 302: .project-card-menu { flex: 0 0 auto; }
 303: .ctx-details { position: relative; }
 304: .ctx-details > summary { list-style: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; color: var(--text-3); line-height: 1; cursor: pointer; }
 305: .ctx-details > summary::-webkit-details-marker { display: none; }
 306: .ctx-details > summary:hover { background: var(--bg-hover); color: var(--text-1); }
 307: .ctx-more-icon { --icon-size: 18px; }
 308: .ctx-menu { position: absolute; right: 0; top: calc(100% + 4px); z-index: 60; min-width: 150px; padding: 5px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-md); box-shadow: var(--shadow-lg); display: flex; flex-direction: column; gap: 2px; }
 309: .ctx-menu button { display: flex; align-items: center; gap: 9px; width: 100%; padding: 8px 10px; border: 0; border-radius: var(--r-sm); background: transparent; color: var(--text-2); text-align: left; font-size: 12.5px; white-space: nowrap; }
 310: .ctx-menu button span { min-width: 0; }
 311: .ctx-menu button:hover { background: var(--bg-hover); color: var(--text-1); }
 312: .ctx-menu .ctx-danger { color: var(--danger); }
 313: .ctx-menu .ctx-danger:hover { background: var(--danger-bg); }
 314: .project-desc { font-size: 12.5px; color: var(--text-2); line-height: 1.55; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
 315: .project-loop-status { display: flex; align-items: center; gap: 8px; margin-top: 12px; color: var(--text-2); font-size: 12px; font-weight: 600; }
 316: .project-loop-status .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
 317: .project-loop-status .led.stopped { box-shadow: 0 0 0 3px var(--line); }
 318: .project-loop-interval { margin-left: auto; color: var(--text-3); font-family: var(--font-mono); font-weight: 500; }
 319: .project-cli-badge { padding: 1px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 600; }
 320: .field-hint { color: var(--text-3); font-size: 11px; font-weight: 500; }
 321: .project-meta { font-size: 11px; color: var(--text-4); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line-soft); }
