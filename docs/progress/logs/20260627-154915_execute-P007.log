    "mcp:http": "node src/mcpServer.js --http",
    "mcp:stdio": "node src/mcpServer.js --stdio",
    "smoke": "node scripts/smoke-test.js"
  },
  "build": {
    "appId": "com.autoplan.desktop",
    "productName": "AutoPlan",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "toolsets": {
      "appimage": "1.0.3"
    },
