 494: 
 495: .act-codex .act-tag { background: rgba(109,93,252,0.3); color: #c4b8ff; }
 496: .act-codex .act-text { color: #e0e6ff; }
 497: .act-exec .act-tag { background: rgba(24,169,87,0.3); color: #7fe0a8; }
 498: .act-exec .act-text { color: #9fd8b8; }
