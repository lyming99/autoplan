 346: .topbar { display: flex; align-items: center; gap: 16px; padding: 14px 24px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); flex: 0 0 auto; }
 347: .topbar-title { min-width: 0; }
 348: .topbar-title h1 { font-size: 18px; font-weight: 700; }
 349: .topbar-title p { font-size: 12px; color: var(--text-3); margin-top: 2px; }
 350: .topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }
 351: .workspace-search { display: flex; align-items: center; gap: 10px; flex: 1 1 420px; max-width: 580px; min-width: 280px; margin-left: auto; }
 352: .workspace-search + .topbar-actions { margin-left: 0; }
 353: .workspace-search-field { position: relative; flex: 1 1 auto; min-width: 0; }
 354: .workspace-search-input.search-input { max-width: none; padding: 9px 38px 9px 36px; color: var(--text-1); transition: background 0.14s, border-color 0.14s, box-shadow 0.14s; }
 355: .workspace-search-input.search-input:hover:not(:disabled) { background: var(--bg-soft); border-color: #cdd8ea; }
 356: .workspace-search-input.search-input:disabled { background: var(--bg-soft); color: var(--text-4); cursor: not-allowed; }
 357: .workspace-search-icon { position: absolute; left: 13px; top: 50%; z-index: 1; color: var(--text-3); transform: translateY(-50%); pointer-events: none; }
 358: .workspace-search-clear { position: absolute; right: 6px; top: 50%; display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 8px; background: transparent; color: var(--text-3); transform: translateY(-50%); transition: background 0.14s, color 0.14s; }
 359: .workspace-search-clear:hover { background: var(--bg-hover); color: var(--text-1); }
 360: .workspace-search-clear:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--brand-50); color: var(--brand-600); }
 361: .workspace-search-clear:disabled { color: var(--text-4); cursor: not-allowed; }
 362: .workspace-search-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 600; white-space: nowrap; }
 363: .workspace-search-count.is-empty { color: var(--warning); }
 364: .search-results { flex: 0 0 auto; margin: 14px 24px 0; overflow: hidden; }
 365: .search-results-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 14px 16px; border-bottom: 1px solid var(--line-soft); }
 366: .search-results-head h2 { font-size: 14.5px; font-weight: 750; }
 367: .search-results-head p { margin-top: 3px; color: var(--text-3); font-size: 12px; }
 368: .search-results-head b { color: var(--text-1); }
 369: .search-results-clear { flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--brand-600); font-size: 12px; font-weight: 700; }
 370: .search-results-clear:hover { background: var(--brand-50); border-color: #cdd8ea; }
 371: .search-source-strip { display: flex; gap: 8px; padding: 12px 16px; border-bottom: 1px solid var(--line-soft); overflow-x: auto; }
 372: .search-source-chip { display: inline-flex; align-items: center; gap: 7px; flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: 999px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; transition: background 0.14s, border-color 0.14s, color 0.14s; }
 373: .search-source-chip b { min-width: 20px; padding: 1px 6px; border-radius: 999px; background: var(--bg-elevated); color: var(--brand-600); text-align: center; }
 374: .search-source-chip:hover:not(:disabled) { background: var(--brand-50); border-color: #cdd8ea; color: var(--brand-700); }
 375: .search-source-chip:disabled { cursor: default; color: var(--text-4); }
 376: .search-source-chip:disabled b { color: var(--text-4); }
 377: .search-results-body { max-height: min(420px, 42vh); overflow: auto; padding: 14px 16px 16px; }
 378: .search-result-groups { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
 379: .search-result-group { min-width: 0; display: flex; flex-direction: column; gap: 10px; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
 380: .search-result-group.is-empty { color: var(--text-4); }
 381: .search-result-group-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
 382: .search-result-group-title { display: inline-flex; align-items: center; gap: 8px; min-width: 0; color: var(--text-1); font-size: 13px; font-weight: 750; }
 383: .search-result-group-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 384: .search-result-group-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 700; }
 385: .search-result-items { display: grid; gap: 8px; }
 386: .search-result-item { width: 100%; min-width: 0; display: grid; gap: 7px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); text-align: left; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
 387: .search-result-item:hover { background: #fff; border-color: #cdd8ea; }
 388: .search-result-item:active { transform: translateY(1px); }
 389: .search-result-item:focus-visible { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
 390: .search-result-item-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
 391: .search-result-title { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; font-weight: 700; }
 392: .search-result-status { flex: 0 0 auto; max-width: 42%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 2px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-700); font-size: 11px; font-weight: 750; }
 393: .search-result-snippet { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-2); font-size: 12.5px; line-height: 1.5; overflow-wrap: anywhere; }
 394: .search-result-meta { display: flex; justify-content: space-between; gap: 10px; color: var(--text-4); font-size: 11px; }
 395: .search-result-meta span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 396: .search-result-more { width: 100%; padding: 7px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); background: transparent; color: var(--brand-600); font-size: 12px; font-weight: 700; }
 397: .search-result-more:hover { background: var(--brand-50); }
 398: .search-result-group-empty { padding: 18px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); color: var(--text-4); text-align: center; font-size: 12px; }
 399: .search-results-empty { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 16px; color: var(--text-3); font-size: 13px; }
 400: .pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; background: var(--bg-soft); border: 1px solid var(--line); color: var(--text-2); }
 401: .led { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 4px var(--success-bg); }
 402: .pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
 403: .led.running { animation: led-pulse 1.6s ease-in-out infinite; }
 404: .led.stopped { background: var(--text-4); box-shadow: 0 0 0 4px var(--line); }
 405: @keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,0.15); } }
 406: .view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 20px 24px; display: none; }
 407: .view.active { display: flex; flex-direction: column; }
 408: /* 概览等纯流式内容视图：恢复 block，内部自己滚动 */
 409: .view.active:has(.overview-grid),
 410: .view.active:has(.stat-grid),
 411: .view.active > section.card:only-child { display: block; }
