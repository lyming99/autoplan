199: .markdown-reader h2 { margin: 24px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--line-soft); font-size: 18px; line-height: 1.35; font-weight: 750; }
200: .markdown-reader h3 { margin: 20px 0 8px; font-size: 15.5px; line-height: 1.4; font-weight: 700; }
201: .markdown-reader h4, .markdown-reader h5, .markdown-reader h6 { margin: 16px 0 8px; font-size: 14px; line-height: 1.4; font-weight: 700; }
202: .markdown-reader p { margin: 0 0 12px; color: var(--text-2); }
203: .markdown-reader a { color: var(--brand-600); overflow-wrap: anywhere; word-break: break-word; }
204: .markdown-reader a:hover { text-decoration: underline; }
205: .markdown-scope-files { display: inline-flex; flex-wrap: wrap; align-items: center; gap: 5px; vertical-align: baseline; }
206: .markdown-scope-label { padding: 2px 6px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 800; }
207: .markdown-scope-link {
211: .markdown-scope-link:hover:not(:disabled) { border-color: var(--brand-500); background: var(--brand-50); text-decoration: none; }
212: .markdown-scope-link.special, .markdown-scope-link:disabled { color: var(--text-4); cursor: not-allowed; }
213: .markdown-reader ul, .markdown-reader ol { margin: 0 0 14px; padding-left: 1.45em; color: var(--text-2); }
214: .markdown-reader li { margin: 4px 0; }
215: .markdown-reader li > p { margin: 6px 0; }
216: .markdown-reader .contains-task-list { list-style: none; padding-left: 1.2em; }
217: .markdown-reader .task-list-item { margin-left: -1.2em; }
218: .markdown-reader input[type="checkbox"] { width: auto; margin: 0 7px 0 0; accent-color: var(--brand-600); vertical-align: -2px; }
219: .markdown-reader .task-list-item > input[type="checkbox"] { margin-top: 0.42em; }
220: .markdown-reader blockquote { margin: 14px 0; padding: 10px 14px; border-left: 3px solid var(--brand-500); border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--brand-50); color: var(--text-2); }
221: .markdown-reader blockquote p { color: inherit; }
222: .markdown-reader code { padding: 2px 5px; border: 1px solid var(--line-soft); border-radius: var(--r-sm); background: var(--bg-soft); color: var(--text-1); font-family: var(--font-mono); font-size: 0.92em; word-break: break-word; }
223: .markdown-reader pre { max-width: 100%; margin: 14px 0; padding: 12px 14px; overflow: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,0.65); }
224: .markdown-reader pre code { display: block; padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text-1); white-space: pre; word-break: normal; overflow-wrap: normal; }
225: .markdown-reader pre:focus-visible, .markdown-reader-table:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
226: .markdown-reader-table { max-width: 100%; margin: 14px 0; overflow-x: auto; border: 1px solid var(--line); border-radius: var(--r-md); }
227: .markdown-reader-table table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 13px; }
228: .markdown-reader th, .markdown-reader td { padding: 8px 10px; border: 1px solid var(--line); text-align: left; vertical-align: top; }
229: .markdown-reader th { background: var(--bg-soft); color: var(--text-1); font-weight: 700; }
230: .markdown-reader tr:nth-child(even) td { background: rgba(248,250,253,0.65); }
231: .markdown-reader hr { margin: 20px 0; border: 0; border-top: 1px solid var(--line); }
232: .markdown-reader img { max-width: 100%; height: auto; border-radius: var(--r-md); box-shadow: var(--shadow-sm); }
234: .event-list { min-width: 0; }
235: .event-item { display: grid; gap: 8px; border-left: 3px solid transparent; }
236: .event-title { align-items: flex-start; }
237: .event-title > span:first-child { white-space: normal; overflow: visible; text-overflow: clip; overflow-wrap: anywhere; line-height: 1.45; }
238: .event-badge { flex: 0 0 auto; display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; white-space: nowrap; }
239: .event-badge-start, .event-badge-updated { color: var(--info); background: var(--info-bg); }
240: .event-badge-success { color: var(--success); background: var(--success-bg); }
241: .event-badge-failed { color: var(--danger); background: var(--danger-bg); }
242: .event-badge-stopped, .event-badge-stopping { color: var(--warning); background: var(--warning-bg); }
243: .event-item-start { border-left-color: var(--info); }
244: .event-item-success { border-left-color: var(--success); }
245: .event-item-failed { border-left-color: var(--danger); }
246: .event-item-stopped, .event-item-stopping { border-left-color: var(--warning); }
247: .event-item-updated { border-left-color: var(--info); }
248: .event-item .item-body, .event-meta { margin-top: 0; }
251: /* 需求/反馈卡片：进度 + 操作脚 + 追加任务 */
252: .intake-progress { margin-top: 12px; }
253: .intake-item .item-foot {
257: .intake-item .item-foot .meta { margin-top: 0; margin-left: auto; }
258: .intake-item .item-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
259: .intake-item .danger-link { color: var(--danger); }
260: .intake-item .danger-link:hover { text-decoration: underline; }
283: .projects-main { height: calc(100vh - 77px); overflow: auto; padding: 28px 32px 48px; }
284: .projects-hero { display: flex; align-items: flex-end; gap: 20px; flex-wrap: wrap; margin-bottom: 22px; }
285: .projects-hero h2 { font-size: 24px; font-weight: 800; }
286: .projects-hero p { font-size: 13px; color: var(--text-3); margin-top: 6px; }
291: .projects-toolbar { margin-bottom: 20px; }
292: .search-input { width: 100%; max-width: 400px; padding: 10px 14px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); font: inherit; font-size: 13px; }
293: .search-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
294: .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
295: .project-card { position: relative; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
296: .project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
297: .project-card-top { display: flex; align-items: flex-start; gap: 12px; }
298: .project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
299: .project-info { min-width: 0; flex: 1 1 auto; }
300: .project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
301: .project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
302: .project-card-menu { flex: 0 0 auto; }
314: .project-desc { font-size: 12.5px; color: var(--text-2); line-height: 1.55; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
315: .project-loop-status { display: flex; align-items: center; gap: 8px; margin-top: 12px; color: var(--text-2); font-size: 12px; font-weight: 600; }
316: .project-loop-status .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
317: .project-loop-status .led.stopped { box-shadow: 0 0 0 3px var(--line); }
318: .project-loop-interval { margin-left: auto; color: var(--text-3); font-family: var(--font-mono); font-weight: 500; }
319: .project-cli-badge { padding: 1px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 600; }
320: .field-hint { color: var(--text-3); font-size: 11px; font-weight: 500; }
321: .project-meta { font-size: 11px; color: var(--text-4); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line-soft); }
323: .workspace-shell { display: grid; grid-template-columns: 248px 1fr; height: 100vh; }
324: .workspace-main { display: flex; flex-direction: column; min-width: 0; height: 100vh; overflow: hidden; }
325: .sidebar { display: flex; flex-direction: column; gap: 6px; padding: 22px 14px 18px; background: var(--bg-elevated); border-right: 1px solid var(--line); height: 100vh; overflow-y: auto; }
326: .sidebar .brand { display: flex; align-items: center; gap: 12px; padding: 4px 10px 18px; }
327: .sidebar .brand-name { font-size: 17px; font-weight: 700; }
328: .sidebar .brand-sub { font-size: 11px; color: var(--text-3); margin-top: 2px; }
331: .project-switcher { margin: 0 4px 10px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); }
332: .project-label { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; color: var(--text-4); margin-bottom: 8px; }
333: .project-select { width: 100%; padding: 8px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); font: inherit; font-size: 13px; font-weight: 600; color: var(--text-1); }
334: .project-switcher .project-path { margin-top: 8px; font-size: 11px; }
341: .sidebar-footer { margin-top: auto; padding: 12px; border-radius: var(--r-md); background: var(--bg-soft); border: 1px solid var(--line-soft); }
342: .loop-mini { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text-2); }
343: .loop-mini b { color: var(--text-1); }
344: .loop-config { font-size: 11px; color: var(--text-3); margin-top: 6px; }
346: .topbar { display: flex; align-items: center; gap: 16px; padding: 14px 24px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); flex: 0 0 auto; }
347: .topbar-title { min-width: 0; }
348: .topbar-title h1 { font-size: 18px; font-weight: 700; }
349: .topbar-title p { font-size: 12px; color: var(--text-3); margin-top: 2px; }
350: .topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }
351: .workspace-search { display: flex; align-items: center; gap: 10px; flex: 1 1 420px; max-width: 580px; min-width: 280px; margin-left: auto; }
352: .workspace-search + .topbar-actions { margin-left: 0; }
353: .workspace-search-field { position: relative; flex: 1 1 auto; min-width: 0; }
354: .workspace-search-input.search-input { max-width: none; padding: 9px 38px 9px 36px; color: var(--text-1); transition: background 0.14s, border-color 0.14s, box-shadow 0.14s; }
355: .workspace-search-input.search-input:hover:not(:disabled) { background: var(--bg-soft); border-color: #cdd8ea; }
356: .workspace-search-input.search-input:disabled { background: var(--bg-soft); color: var(--text-4); cursor: not-allowed; }
357: .workspace-search-icon { position: absolute; left: 13px; top: 50%; z-index: 1; color: var(--text-3); transform: translateY(-50%); pointer-events: none; }
358: .workspace-search-clear { position: absolute; right: 6px; top: 50%; display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 8px; background: transparent; color: var(--text-3); transform: translateY(-50%); transition: background 0.14s, color 0.14s; }
359: .workspace-search-clear:hover { background: var(--bg-hover); color: var(--text-1); }
360: .workspace-search-clear:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--brand-50); color: var(--brand-600); }
361: .workspace-search-clear:disabled { color: var(--text-4); cursor: not-allowed; }
362: .workspace-search-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 600; white-space: nowrap; }
363: .workspace-search-count.is-empty { color: var(--warning); }
364: .search-results { flex: 0 0 auto; margin: 14px 24px 0; overflow: hidden; }
365: .search-results-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 14px 16px; border-bottom: 1px solid var(--line-soft); }
366: .search-results-head h2 { font-size: 14.5px; font-weight: 750; }
367: .search-results-head p { margin-top: 3px; color: var(--text-3); font-size: 12px; }
368: .search-results-head b { color: var(--text-1); }
369: .search-results-clear { flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--brand-600); font-size: 12px; font-weight: 700; }
370: .search-results-clear:hover { background: var(--brand-50); border-color: #cdd8ea; }
371: .search-source-strip { display: flex; gap: 8px; padding: 12px 16px; border-bottom: 1px solid var(--line-soft); overflow-x: auto; }
372: .search-source-chip { display: inline-flex; align-items: center; gap: 7px; flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: 999px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; transition: background 0.14s, border-color 0.14s, color 0.14s; }
373: .search-source-chip b { min-width: 20px; padding: 1px 6px; border-radius: 999px; background: var(--bg-elevated); color: var(--brand-600); text-align: center; }
374: .search-source-chip:hover:not(:disabled) { background: var(--brand-50); border-color: #cdd8ea; color: var(--brand-700); }
375: .search-source-chip:disabled { cursor: default; color: var(--text-4); }
376: .search-source-chip:disabled b { color: var(--text-4); }
377: .search-results-body { max-height: min(420px, 42vh); overflow: auto; padding: 14px 16px 16px; }
378: .search-result-groups { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
379: .search-result-group { min-width: 0; display: flex; flex-direction: column; gap: 10px; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
380: .search-result-group.is-empty { color: var(--text-4); }
381: .search-result-group-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
382: .search-result-group-title { display: inline-flex; align-items: center; gap: 8px; min-width: 0; color: var(--text-1); font-size: 13px; font-weight: 750; }
383: .search-result-group-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
384: .search-result-group-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 700; }
385: .search-result-items { display: grid; gap: 8px; }
386: .search-result-item { width: 100%; min-width: 0; display: grid; gap: 7px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); text-align: left; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
387: .search-result-item:hover { background: #fff; border-color: #cdd8ea; }
388: .search-result-item:active { transform: translateY(1px); }
389: .search-result-item:focus-visible { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
390: .search-result-item-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
391: .search-result-title { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; font-weight: 700; }
392: .search-result-status { flex: 0 0 auto; max-width: 42%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 2px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-700); font-size: 11px; font-weight: 750; }
393: .search-result-snippet { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-2); font-size: 12.5px; line-height: 1.5; overflow-wrap: anywhere; }
394: .search-result-meta { display: flex; justify-content: space-between; gap: 10px; color: var(--text-4); font-size: 11px; }
395: .search-result-meta span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
396: .search-result-more { width: 100%; padding: 7px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); background: transparent; color: var(--brand-600); font-size: 12px; font-weight: 700; }
397: .search-result-more:hover { background: var(--brand-50); }
398: .search-result-group-empty { padding: 18px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); color: var(--text-4); text-align: center; font-size: 12px; }
399: .search-results-empty { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 16px; color: var(--text-3); font-size: 13px; }
406: .view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 20px 24px; display: none; }
407: .view.active { display: flex; flex-direction: column; }
408: /* 概览等纯流式内容视图：恢复 block，内部自己滚动 */
409: .view.active:has(.overview-grid),
410: .view.active:has(.stat-grid),
411: .view.active > section.card:only-child { display: block; }
413: .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 20px; margin-bottom: 24px; }
414: .stat { position: relative; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
415: .stat::after { content: ""; position: absolute; right: -18px; top: -18px; width: 84px; height: 84px; border-radius: 50%; opacity: 0.5; }
416: .stat-brand::after { background: var(--brand-50); }
417: .stat-info::after { background: var(--info-bg); }
418: .stat-success::after { background: var(--success-bg); }
419: .stat-warning::after { background: var(--warning-bg); }
420: .stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; line-height: 0; }
421: .stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }
422: .stat-info .stat-ico { background: var(--info-bg); color: var(--info); }
423: .stat-success .stat-ico { background: var(--success-bg); color: var(--success); }
424: .stat-warning .stat-ico { background: var(--warning-bg); color: var(--warning); }
425: .stat .stat-value { font-size: 26px; font-weight: 800; line-height: 1; position: relative; z-index: 1; }
426: .stat .stat-label { font-size: 12px; color: var(--text-3); margin-top: 6px; position: relative; z-index: 1; }
427: .stat .stat-delta { font-size: 11px; margin-top: 8px; color: var(--success); font-weight: 600; position: relative; z-index: 1; }
428: .overview-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(380px,1fr); align-items: stretch; gap: 24px; }
429: .overview-main-column, .overview-side-column { display: flex; flex-direction: column; gap: 20px; min-width: 0; }
430: .overview-side-column .card-head h2 { white-space: nowrap; }
431: .loop-card { background: var(--brand-grad); color: #fff; border-radius: var(--r-lg); padding: 22px 24px; position: relative; overflow: hidden; box-shadow: 0 18px 40px rgba(77,110,255,0.28); }
432: .loop-card .lc-top { display: flex; align-items: center; gap: 12px; }
433: .loop-card .lc-status { font-size: 13px; opacity: 0.9; }
434: .loop-card .lc-phase { font-size: 22px; font-weight: 800; margin-top: 4px; }
435: .loop-card .lc-meta { display: flex; gap: 22px; margin-top: 16px; font-size: 12px; opacity: 0.92; }
436: .loop-card .lc-meta b { display: block; font-size: 15px; font-weight: 700; margin-top: 2px; }
437: .loop-card .lc-led { width: 12px; height: 12px; border-radius: 50%; background: #b6f5cf; box-shadow: 0 0 0 4px rgba(182,245,207,0.25); }
438: .loop-card .lc-led.running { animation: led-pulse 1.6s ease-in-out infinite; }
439: .loop-card .lc-led.stopped { background: #cfd6e6; box-shadow: 0 0 0 4px rgba(207,214,230,0.25); }
441: .pipeline { display: flex; align-items: flex-start; gap: 0; overflow-x: auto; }
453: /* 实时执行日志（对话格式） */
456: .overview-main-column > .live-log-card { height: 440px; }
457: .overview-main-column > .live-log-card .codex-log { flex: 1 1 auto; min-height: 0; max-height: none; }
458: .log-card-head { align-items: stretch; flex-direction: column; gap: 8px; padding: 12px 18px; }
459: .log-title-line { display: flex; align-items: center; gap: 12px; min-width: 0; }
460: .log-title-line h2 { flex: 0 0 auto; }
461: .log-title-line .hint { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
462: .log-phase-chip { flex: 0 0 auto; border: 1px solid var(--line); border-radius: 999px; padding: 4px 9px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; white-space: nowrap; }
463: .log-phase-chip.running { color: var(--success); background: var(--success-bg); border-color: transparent; }
464: .log-summary { display: flex; align-items: center; gap: 18px; color: var(--text-3); font-size: 12px; }
465: .log-summary b { color: var(--text-1); margin-left: 4px; }
481: /* 活动时间线行 */
510: .intake-layout { display: grid; grid-template-rows: minmax(0,1fr) auto; gap: 14px; flex: 1 1 0; min-height: 0; max-width: 880px; margin: 0 auto; width: 100%; }
511: .intake-layout > .composer { margin-bottom: 0; }
512: .intake-stream { display: grid; grid-template-rows: auto minmax(0,1fr); min-height: 0; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--bg-elevated); padding: 16px; }
