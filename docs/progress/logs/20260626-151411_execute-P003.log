 362:     event.type,
 363:     event.message,
 364:     display.title,
 365:     display.body,
 366:     display.badge,
 367:     display.meta,
 368:     toSearchText(meta),
 369:     toSearchText(event),
 370:   ]
 371:     .filter(Boolean)
 372:     .join(' ');
 373: }
