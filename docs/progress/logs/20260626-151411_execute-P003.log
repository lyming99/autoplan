 287: function formatTaskEvent(event: AppEvent, meta: EventMetaRecord): TaskEventDisplay | null {
 288:   const taskKey = readMetaText(meta, ['taskKey', 'task_key']);
 289:   const taskId = readMetaText(meta, ['taskId', 'task_id']);
 290:   const taskTitle = readMetaText(meta, ['taskTitle', 'task_title', 'title']) || '未命名任务';
 291:   const hasTaskIdentity = Boolean(taskKey || taskId || readMetaText(meta, ['taskTitle', 'task_title', 'title']));
 292:   if (!hasTaskIdentity) return null;
 293: 
 294:   const tone = classifyTaskEvent(event, meta);
 295:   const presentation = TASK_EVENT_PRESENTATION[tone];
 296:   const taskLabel = taskKey ? `${taskKey} 任务` : taskId ? `任务 #${taskId}` : '任务';
 297:   const separator = taskLabel === '任务' ? '' : ' ';
 298:   const title = `${presentation.action}${separator}${taskLabel}：${taskTitle}`;
 299:   const originalMessage = event.message?.trim() || '';
 300:   const planId = readMetaText(meta, ['planId', 'plan_id']);
 301:   const status = readMetaText(meta, ['status', 'taskStatus', 'task_status']);
 302:   const agentCliProvider = readMetaText(meta, ['agentCliProvider', 'agent_cli_provider']);
 303:   const codexReasoningEffort = readMetaText(meta, [
 304:     'codexReasoningEffort',
 305:     'codex_reasoning_effort',
 306:     'codexThinkingDepth',
 307:     'codex_thinking_depth',
 308:     'reasoningEffort',
 309:     'reasoning_effort',
 310:     'thinkingDepth',
 311:     'thinking_depth',
 312:   ]);
 313:   const durationMs = readMetaNumber(meta, ['durationMs', 'duration_ms']);
 314:   const metaParts = [
 315:     formatChinaDateTime(event.created_at),
 316:     planId ? `Plan #${planId}` : '',
 317:     agentCliProvider ? agentCliProviderLabel(agentCliProvider) : '',
 318:     agentCliProvider !== 'claude' && codexReasoningEffort ? `思考深度 ${codexReasoningEffortLabel(codexReasoningEffort)}` : '',
 319:     status ? `状态 ${status}` : '',
 320:     durationMs !== null ? `耗时 ${formatDuration(durationMs, '0秒')}` : '',
 321:   ].filter(Boolean);
 322: 
 323:   return {
 324:     title,
 325:     body: originalMessage && !sameEventText(originalMessage, title) ? originalMessage : '',
 326:     meta: metaParts.join(' · '),
 327:     badge: presentation.badge,
 328:     tone,
 329:   };
 330: }
 331: 
 332: function formatEvent(event: AppEvent): TaskEventDisplay {
 333:   const meta = readEventMeta(event);
 334:   const taskDisplay = meta && (isTaskEventType(event.type) || readMetaText(meta, ['taskKey', 'task_key', 'taskId', 'task_id']))
 335:     ? formatTaskEvent(event, meta)
 336:     : null;
 337:   if (taskDisplay) return taskDisplay;
 338: 
 339:   return {
 340:     title: event.type || '事件',
 341:     body: event.message || '',
 342:     meta: formatChinaDateTime(event.created_at),
 343:   };
 344: }
