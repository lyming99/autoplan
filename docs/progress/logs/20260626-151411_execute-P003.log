  59: function readDurationMs(task: TimedPlanTask) {
  60:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
  61:   const duration = Number(task.duration_ms);
  62:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
  63: }
  64: 
  65: function getTaskDurationMs(task: TimedPlanTask) {
  66:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
  67:   return readDurationMs(task);
  68: }
  69: 
  70: function readPlanId(task: TimedPlanTask) {
  71:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
  72:   const planId = Number(task.plan_id);
  73:   return Number.isFinite(planId) ? planId : null;
  74: }
  75: 
  76: function formatTaskDuration(task: TimedPlanTask) {
  77:   const duration = getTaskDurationMs(task);
  78:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
  79:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
  80:   return `耗时 ${formatDuration(duration, '0秒')}`;
  81: }
  82: 
  83: function normalizeTaskStatus(status: string | null | undefined) {
  84:   return String(status || '').trim().toLowerCase();
  85: }
  86: 
  87: function matchesTaskStatusFilter(task: PlanTask, filter: TaskStatusFilter) {
  88:   const status = normalizeTaskStatus(task.status);
  89:   if (filter === 'all') return true;
  90:   if (filter === 'running') return ['running', 'processing', 'stopping'].includes(status);
  91:   if (filter === 'queued') return ['pending', 'queued', 'waiting'].includes(status);
  92:   if (filter === 'completed') return ['completed', 'done', 'passed', 'accepted'].includes(status);
  93:   return true;
  94: }
