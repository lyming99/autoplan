 130: function formatTaskPlanGroupSummary(group: TaskPlanGroup) {
 131:   const timedTasks = group.tasks as TimedPlanTask[];
 132:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
 133:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
 134:   const timeSummary = latestFinishedAt
 135:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
 136:     : latestUpdatedAt
 137:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
 138:       : '暂无时间记录';
 139:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
 140: }
