 230:       return toEventMetaRecord(JSON.parse(value));
 231:     } catch {
 232:       return null;
 233:     }
 234:   }
 235:   if (typeof value === 'object' && !Array.isArray(value)) return value as EventMetaRecord;
 236:   return null;
 237: }
