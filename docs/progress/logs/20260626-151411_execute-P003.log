 239: function readEventMeta(event: AppEvent) {
 240:   return toEventMetaRecord((event as AppEvent & { meta?: unknown }).meta);
 241: }
 242: 
 243: function readMetaText(meta: EventMetaRecord | null, keys: string[]) {
 244:   if (!meta) return '';
 245:   for (const key of keys) {
 246:     const value = meta[key];
 247:     if (typeof value === 'string') {
 248:       const text = value.trim();
 249:       if (text) return text;
 250:     }
 251:     if (typeof value === 'number' && Number.isFinite(value)) return String(value);
 252:   }
 253:   return '';
 254: }
 255: 
 256: function readMetaNumber(meta: EventMetaRecord | null, keys: string[]) {
 257:   const text = readMetaText(meta, keys);
 258:   if (!text) return null;
 259:   const value = Number(text);
 260:   return Number.isFinite(value) ? value : null;
 261: }
 262: 
 263: function includesAny(text: string, keywords: string[]) {
 264:   return keywords.some((keyword) => text.includes(keyword));
 265: }
 266: 
 267: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 268:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 269:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 270:     return 'stopping';
 271:   }
 272:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 273:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 274:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 275:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 276:   return 'updated';
 277: }
 278: 
 279: function isTaskEventType(type: string) {
 280:   return /^task[.:_-]/i.test(type);
 281: }
 282: 
 283: function sameEventText(left: string, right: string) {
 284:   return left.replace(/\s+/g, ' ').trim() === right.replace(/\s+/g, ' ').trim();
 285: }
