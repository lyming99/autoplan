 146: function taskPlanGroupKey(task: TimedPlanTask) {
 147:   const planId = readPlanId(task);
 148:   if (planId !== null) return `plan:${planId}`;
 149:   if (task.file_path) return `file:${task.file_path}`;
 150:   const title = taskPlanGroupTitle(task);
 151:   if (title !== '未命名计划') return `title:${title}`;
 152:   return 'unknown-plan';
 153: }
