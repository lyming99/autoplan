 155: function groupTasksByPlan(tasks: PlanTask[]) {
 156:   const groups = new Map<string, TaskPlanGroup>();
 157:   tasks.forEach((task, index) => {
 158:     const timedTask = task as TimedPlanTask;
 159:     const key = taskPlanGroupKey(timedTask);
 160:     const existingGroup = groups.get(key);
 161:     if (existingGroup) {
 162:       existingGroup.tasks.push(task);
 163:       if (existingGroup.title === '未命名计划') existingGroup.title = taskPlanGroupTitle(task);
 164:       return;
 165:     }
 166: 
 167:     groups.set(key, {
 168:       key,
 169:       title: taskPlanGroupTitle(task),
 170:       tasks: [task],
 171:       firstIndex: index,
 172:       sortTime: null,
 173:     });
 174:   });
 175: 
 176:   return Array.from(groups.values())
 177:     .map((group) => {
 178:       const indexedTasks = group.tasks.map((task, index) => ({ task, index }));
 179:       const sortedTasks = indexedTasks
 180:         .sort((left, right) => {
 181:           const leftTime = taskSortTime(left.task as TimedPlanTask);
 182:           const rightTime = taskSortTime(right.task as TimedPlanTask);
 183:           if (leftTime !== null && rightTime !== null && leftTime !== rightTime) return rightTime - leftTime;
 184:           if (leftTime !== null && rightTime === null) return -1;
 185:           if (leftTime === null && rightTime !== null) return 1;
 186:           return left.index - right.index;
 187:         })
 188:         .map(({ task }) => task);
 189:       return {
 190:         ...group,
 191:         tasks: sortedTasks,
 192:         sortTime: latestTaskTime(group.tasks as TimedPlanTask[]),
 193:       };
 194:     })
 195:     .sort((left, right) => {
 196:       if (left.sortTime !== null && right.sortTime !== null && left.sortTime !== right.sortTime) {
 197:         return right.sortTime - left.sortTime;
 198:       }
 199:       if (left.sortTime !== null && right.sortTime === null) return -1;
 200:       if (left.sortTime === null && right.sortTime !== null) return 1;
 201:       return left.firstIndex - right.firstIndex;
 202:     });
 203: }
