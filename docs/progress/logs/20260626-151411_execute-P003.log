 346: function toSearchText(value: unknown, depth = 0): string {
 347:   if (value === null || value === undefined || depth > 6) return '';
 348:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 349:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 350:   if (typeof value === 'object') {
 351:     return Object.values(value as Record<string, unknown>)
 352:       .map((item) => toSearchText(item, depth + 1))
 353:       .join(' ');
 354:   }
 355:   return '';
 356: }
