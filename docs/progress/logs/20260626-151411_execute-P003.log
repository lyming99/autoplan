 205: function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
 206:   const timedTasks = tasks as TimedPlanTask[];
 207:   const hasPlanIds = timedTasks.some((task) => readPlanId(task) !== null);
 208:   if (!hasPlanIds) return planCount === 1 ? timedTasks : [];
 209:   return timedTasks.filter((task) => readPlanId(task) === plan.id);
 210: }
