 212: function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
 213:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
 214:   const completedMs = tasks.reduce(
 215:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
 216:     0,
 217:   );
 218: 
 219:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
 220: }
