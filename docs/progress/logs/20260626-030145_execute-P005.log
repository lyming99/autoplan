 744: function createFilteredWorkspaceItems(
 745:   snapshot: AppSnapshot | null | undefined,
 746:   searchState: WorkspaceSearchState,
 747: ): WorkspaceFilterableItems {
 748:   if (!snapshot) {
 749:     return { requirements: [], feedback: [], plans: [], tasks: [], events: [] };
 750:   }
 751:   if (searchState.query.isEmpty) {
 752:     return {
 753:       requirements: snapshot.requirements,
 754:       feedback: snapshot.feedback,
 755:       plans: snapshot.plans,
 756:       tasks: snapshot.tasks,
 757:       events: snapshot.events,
 758:     };
 759:   }
 760: 
 761:   return {
 762:     requirements: filterItemsBySearchGroup(
 763:       snapshot.requirements,
 764:       searchState.groups,
 765:       WORKSPACE_SEARCH_SOURCE_TYPES.REQUIREMENT,
 766:     ),
 767:     feedback: filterItemsBySearchGroup(snapshot.feedback, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.FEEDBACK),
 768:     plans: filterItemsBySearchGroup(snapshot.plans, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.PLAN),
 769:     tasks: filterItemsBySearchGroup(snapshot.tasks, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK),
 770:     events: filterItemsBySearchGroup(snapshot.events, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.EVENT),
 771:   };
 772: }
 773: 
 774: function filterItemsBySearchGroup<T extends { id: number }>(
 775:   items: T[],
 776:   groups: WorkspaceSearchGroup[],
 777:   source: WorkspaceSearchSourceType,
 778: ) {
 779:   const group = groups.find((item) => item.source === source);
 780:   if (!group?.results.length) return [];
 781: 
 782:   const recordIds = new Set(group.results.map((result) => result.recordId));
 783:   return items.filter((item) => recordIds.has(item.id));
 784: }
