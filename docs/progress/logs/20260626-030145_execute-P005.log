+  const finishedAt = normalizeOptionalString(task.finished_at) || null;
+  const isRunning = task.status === TASK_EVENT_STATUS.RUNNING;
+  const runDurationMs = isRunning ? taskRunDurationMs(startedAt, nowIso()) : undefined;
