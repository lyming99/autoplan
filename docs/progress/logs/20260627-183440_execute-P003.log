const FALLBACK_SEARCH_PRIORITY = 99;
const WORKSPACE_SEARCH_LOCATION_HIGHLIGHT_MS = 2400;
const WORKSPACE_SEARCH_LOCATION_SCROLL_BEHAVIOR = 'smooth';

