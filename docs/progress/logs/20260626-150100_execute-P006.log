561: function loadRendererTsModule(modulePath, cache = new Map()) {
562:   const absolutePath = path.resolve(modulePath);
563:   const cachedModule = cache.get(absolutePath);
564:   if (cachedModule) return cachedModule.exports;
565: 
566:   const ts = require('typescript');
567:   const module = { exports: {} };
568:   cache.set(absolutePath, module);
