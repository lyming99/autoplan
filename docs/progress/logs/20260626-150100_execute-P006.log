610: function resolveRendererModule(fromDir, request, rendererRoot) {
611:   const basePath = path.resolve(fromDir, request);
612:   const candidates = [
613:     basePath,
614:     `${basePath}.ts`,
615:     `${basePath}.tsx`,
616:     `${basePath}.js`,
617:     `${basePath}.jsx`,
618:     path.join(basePath, 'index.ts'),
619:     path.join(basePath, 'index.tsx'),
620:     path.join(basePath, 'index.js'),
621:   ];
622:   const resolvedPath = candidates.find((candidate) => fs.existsSync(candidate) && fs.statSync(candidate).isFile());
623:   assert.ok(resolvedPath, `应能解析前端模块 ${request}`);
624: 
625:   const relativePath = path.relative(rendererRoot, resolvedPath);
626:   assert.ok(
627:     relativePath && !relativePath.startsWith('..') && !path.isAbsolute(relativePath),
628:     `前端 smoke 模块应限制在 renderer 目录内：${request}`,
629:   );
630:   return resolvedPath;
631: }
