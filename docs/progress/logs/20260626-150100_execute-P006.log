+function createSpawnOnlyChild() {
+  const { EventEmitter } = require('node:events');
+  const child = new EventEmitter();
+  child.unref = () => {};
+  child.kill = () => {};
+  child.killed = false;
+  child.pid = Math.floor(Math.random() * 1e6);
+  setImmediate(() => child.emit('spawn'));
+  return child;
+}
