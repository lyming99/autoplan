+.scope-segmented .seg-opt { flex-direction: column; align-items: flex-start; white-space: normal; }
+.effort-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 10px; }
+.effort-opt { position: relative; min-width: 0; padding: 12px 14px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); text-align: left; cursor: pointer; transition: border-color 0.14s, box-shadow 0.14s, background 0.14s; }
+.effort-opt:hover { border-color: #c6d1e3; background: var(--bg-soft); }
+.effort-opt.active { border-color: var(--brand-500); background: var(--brand-50); box-shadow: 0 0 0 3px var(--brand-50); }
+.eff-name { display: flex; align-items: center; gap: 8px; color: var(--text-1); font-size: 13px; font-weight: 800; }
+.eff-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-4); }
+.effort-opt.active .eff-dot { background: var(--brand-600); }
+.eff-desc { display: block; margin-top: 5px; color: var(--text-3); font-size: 11.5px; line-height: 1.5; }
+.settings-footer { position: sticky; bottom: 0; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 16px; padding: 12px 0 0; border-top: 1px solid var(--line-soft); background: linear-gradient(180deg, rgba(255,255,255,0.74), var(--bg-elevated) 42%); backdrop-filter: blur(8px); }
+.settings-footer .spacer { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; margin-left: auto; }
+.dirty-note { min-width: 0; color: var(--text-3); font-size: 12px; line-height: 1.45; }
