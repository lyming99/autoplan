 .input-affix { display: flex; align-items: stretch; }
 .input-affix .field-input { border-radius: var(--r-sm) 0 0 var(--r-sm); }
 .input-affix .affix { display: grid; place-items: center; padding: 0 12px; border: 1px solid var(--line); border-left: 0; border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--bg-soft); color: var(--text-3); font-size: 12px; font-weight: 700; }
-.settings-actions { justify-content: flex-end; margin-top: 10px; padding: 12px 0 0; }
+.segmented { display: inline-flex; gap: 2px; flex-wrap: wrap; max-width: 100%; padding: 3px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); }
+.seg-opt { display: inline-flex; align-items: center; gap: 8px; min-width: 0; padding: 7px 14px; border: 0; border-radius: 7px; background: transparent; color: var(--text-2); font-size: 12.5px; font-weight: 700; white-space: nowrap; transition: background 0.14s, color 0.14s, box-shadow 0.14s; }
