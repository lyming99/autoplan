 321:     const planPath = await resolvePlanPath(project.workspace_path, plan.file_path);
 322:     const markdown = await fs.promises.readFile(planPath, 'utf8');
 323:     return planReadResult(plan, markdown, null);
 324:   } catch (error) {
 325:     return planReadResult(plan, '', planReadErrorMessage(error));
 326:   }
 327: }
