 329: async function resolvePlanPath(workspacePath, filePath) {
 330:   const workspaceRoot = path.resolve(workspacePath);
 331:   const requestedPath = path.resolve(workspaceRoot, filePath);
 332:   if (!isInsidePath(workspaceRoot, requestedPath)) {
 333:     throw planReadError('PLAN_PATH_OUTSIDE_WORKSPACE', '计划文件路径超出项目工作区');
 334:   }
 335: 
 336:   let workspaceRealPath;
 337:   try {
 338:     workspaceRealPath = await fs.promises.realpath(workspaceRoot);
 339:   } catch {
 340:     throw planReadError('WORKSPACE_UNAVAILABLE', '项目工作区不存在或无法访问');
 341:   }
 342: 
