 310:   if (!project) return planReadResult({ project_id: projectId, id: planId }, '', '项目不存在');
 311: 
 312:   const plan = db.get(
 313:     'SELECT id, project_id, file_path, hash, updated_at FROM plans WHERE id = ? AND project_id = ?',
 314:     [planId, projectId],
 315:   );
 316:   if (!plan) return planReadResult({ project_id: projectId, id: planId }, '', '计划不存在');
 317:   if (!String(project.workspace_path || '').trim()) return planReadResult(plan, '', '项目工作区路径为空');
 318:   if (!String(plan.file_path || '').trim()) return planReadResult(plan, '', '计划文件路径为空');
