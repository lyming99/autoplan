 1798:     : '';
 1799:   const contexts = [providerContext, reasoningContext, codexContext].filter(Boolean).join(' · ');
 1800:   return `${action}${separator}${taskLabel}：${taskTitle}${contexts ? `（${contexts}）` : ''}`;
 1801: }
