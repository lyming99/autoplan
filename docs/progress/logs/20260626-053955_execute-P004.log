 1389:   async runCodex(workspace, prompt, label, operation = {}) {
 1390:     const projectIdForEmit = operation.projectId;
 1391:     const runtime = this.runtime(projectIdForEmit);
 1392:     if (!runtime) throw new Error('projectId is required for codex operations');
 1393:     const projectStatus = projectIdForEmit ? this.status(projectIdForEmit) : null;
 1394:     const agentCliConfig = effectiveAgentCliConfig(projectStatus, operation);
 1395:     const agentCliProvider = agentCliConfig.provider;
 1396:     const agentCliCommand = agentCliConfig.command;
 1397:     const codexReasoningEffort = agentCliConfig.codexReasoningEffort;
 1398:     const isCodexProvider = agentCliProvider === DEFAULT_AGENT_CLI_PROVIDER;
 1399:     const logDir = path.join(workspace, 'docs', 'progress', 'logs');
 1400:     fs.mkdirSync(logDir, { recursive: true });
 1401:     const prefix = `${timestampForPath()}_${safePart(label)}`;
 1402:     const logFile = path.join(logDir, `${prefix}.log`);
 1403:     const lastFile = path.join(logDir, `${prefix}.last.txt`);
 1404:     const hasSessionOption = isCodexProvider && hasCodexSessionOption(operation);
 1405:     const requestedSessionId = isCodexProvider ? operationCodexSessionId(operation) : '';
 1406:     const activeOperation = {
 1407:       ...operation,
 1408:       label,
 1409:       logFile,
 1410:       lastFile,
 1411:       agentCliProvider,
 1412:       agentCliCommand,
 1413:       ...(isCodexProvider ? { codexReasoningEffort } : {}),
 1414:       ...(isCodexProvider
 1415:         ? {
 1416:             codexSessionId: requestedSessionId || null,
 1417:             codexSessionRequestedId: requestedSessionId || null,
 1418:             codexSessionMode: requestedSessionId ? 'resume' : 'new',
 1419:             codexSessionState: requestedSessionId ? 'resume' : 'new',
 1420:           }
 1421:         : {}),
 1422:       logBuffer: '',
 1423:       activity: isCodexProvider ? new CodexActivityPrinter(200) : null,
 1424:       startedAt: nowIso(),
 1425:     };
 1426:     if (!isCodexProvider) clearCodexSessionFields(activeOperation);
 1427:     let operationKey = null;
 1428:     let capturedSessionId = '';
 1429:     let sessionScanBuffer = '';
 1430:     const stream = fs.createWriteStream(logFile, { encoding: 'utf8' });
 1431:     const appendInternalLog = (message) => {
 1432:       const text = `\n[AutoPlan] ${message}\n`;
 1433:       stream.write(text);
 1434:       activeOperation.logBuffer = `${activeOperation.logBuffer || ''}${text}`;
 1435:       if (activeOperation.logBuffer.length > 24000) {
 1436:         activeOperation.logBuffer = activeOperation.logBuffer.slice(-16000);
 1437:       }
 1438:     };
 1439:     const resultFor = (attempt, mode) => {
 1440:       if (activeOperation.activity && typeof activeOperation.activity.flush === 'function') {
 1441:         activeOperation.activity.flush();
 1442:       }
 1443:       const exitCode = typeof attempt?.exitCode === 'number' ? attempt.exitCode : -1;
 1444:       const sessionId = capturedSessionId || (mode === 'resume' ? requestedSessionId : '');
 1445:       const codexSessionFields = isCodexProvider
 1446:         ? codexSessionContextFields({
 1447:             codexSessionId: sessionId,
 1448:             codexSessionRequestedId: requestedSessionId,
 1449:             codexSessionMode: mode,
 1450:             codexSessionFallback: mode === 'new' && Boolean(requestedSessionId),
 1451:           })
 1452:         : {};
 1453:       return {
 1454:         exitCode,
 1455:         logFile,
 1456:         lastFile,
 1457:         provider: activeOperation.agentCliProvider,
 1458:         agentCliProvider: activeOperation.agentCliProvider,
 1459:         command: activeOperation.agentCliCommand,
 1460:         agentCliCommand: activeOperation.agentCliCommand,
 1461:         ...(isCodexProvider ? { codexReasoningEffort: activeOperation.codexReasoningEffort } : {}),
 1462:         activity: activeOperation.activity ? activeOperation.activity.getLines() : [],
 1463:         errorMessage: attempt?.errorMessage || '',
 1464:         ...(isCodexProvider
 1465:           ? {
 1466:               sessionId: sessionId || null,
 1467:               codexSessionId: sessionId || null,
 1468:               codexSessionMode: mode,
 1469:               resumed: mode === 'resume',
 1470:             }
 1471:           : {}),
 1472:         ...codexSessionFields,
 1473:       };
 1474:     };
 1475:     const runAttempt = async (args, mode) => {
 1476:       if (isCodexProvider) {
 1477:         activeOperation.codexSessionMode = mode;
 1478:         activeOperation.codexSessionState = activeOperation.codexSessionFallback ? 'fallback-new' : mode;
 1479:         activeOperation.codexSessionId = mode === 'resume' ? requestedSessionId || null : capturedSessionId || null;
 1480:       }
 1481:       return runAgentCliAttempt({
 1482:         workspace,
 1483:         prompt,
 1484:         lastFile,
 1485:         logFile,
 1486:         runtime,
 1487:         activeOperation,
 1488:         operationKey,
 1489:         onOperationKey: (nextOperationKey) => {
 1490:           operationKey = nextOperationKey;
 1491:         },
 1492:         registerRuntimeOperation,
 1493:         waitForChild,
 1494:         stream,
 1495:         provider: activeOperation.agentCliProvider,
 1496:         command: activeOperation.agentCliCommand,
 1497:         codexArgs: args,
 1498:         onChunk: (text) => {
 1499:           if (!isCodexProvider) return;
 1500:           sessionScanBuffer = `${sessionScanBuffer}${text}`.slice(-4000);
 1501:           const parsedSessionId = extractCodexSessionId(sessionScanBuffer);
 1502:           if (parsedSessionId) {
 1503:             capturedSessionId = parsedSessionId;
 1504:             activeOperation.codexSessionId = parsedSessionId;
 1505:           }
 1506:         },
 1507:       });
 1508:     };
 1509:     const tailTimer = setInterval(() => {
 1510:       if (projectIdForEmit) this.emitUpdate(projectIdForEmit);
 1511:     }, 600);
 1512:     try {
 1513:       if (!isCodexProvider) {
 1514:         const attempt = await runAttempt([], '');
 1515:         return resultFor(attempt, '');
 1516:       }
 1517: 
 1518:       if (requestedSessionId) {
 1519:         this.addEvent(projectIdForEmit, 'codex.session.resume.started', `尝试恢复 Codex 会话 ${shortCodexSessionId(requestedSessionId)}`, {
 1520:           ...codexSessionContextFields({
 1521:             codexSessionId: requestedSessionId,
 1522:             codexSessionRequestedId: requestedSessionId,
 1523:             codexSessionMode: 'resume',
 1524:           }),
 1525:           sessionId: requestedSessionId,
 1526:           label,
 1527:           planId: operation.planId || null,
 1528:           taskId: operation.taskId || null,
 1529:         });
 1530:         const resume = await runAttempt(codexResumeSessionArgs(requestedSessionId, lastFile, { reasoningEffort: codexReasoningEffort }), 'resume');
 1531:         const resumeFailed = resume.exitCode !== 0 && !extractCodexSessionId(resume.output) && isCodexResumeFailure(resume.output);
 1532:         if (!resumeFailed) return resultFor(resume, 'resume');
 1533: 
 1534:         this.addEvent(projectIdForEmit, 'codex.session.resume.failed', `恢复 Codex 会话失败，已回退新建：${shortCodexSessionId(requestedSessionId)}`, {
 1535:           ...codexSessionContextFields({
 1536:             codexSessionRequestedId: requestedSessionId,
 1537:             codexSessionMode: 'new',
 1538:             codexSessionState: 'fallback-new',
 1539:             codexSessionFallback: true,
 1540:           }),
 1541:           sessionId: requestedSessionId,
 1542:           label,
 1543:           planId: operation.planId || null,
 1544:           taskId: operation.taskId || null,
 1545:           exitCode: resume.exitCode,
 1546:           log: logFile,
 1547:         });
 1548:         activeOperation.codexSessionFallback = true;
 1549:         activeOperation.codexSessionRequestedId = requestedSessionId;
 1550:         activeOperation.codexSessionId = null;
 1551:         activeOperation.codexSessionMode = 'new';
 1552:         activeOperation.codexSessionState = 'fallback-new';
 1553:         appendInternalLog(`Codex resume failed for session ${requestedSessionId}; falling back to a new session.`);
 1554:       } else if (hasSessionOption) {
 1555:         this.addEvent(projectIdForEmit, 'codex.session.resume.skipped', 'Codex session id 为空，已新建会话', {
 1556:           ...codexSessionContextFields({ codexSessionMode: 'new' }),
 1557:           label,
 1558:           planId: operation.planId || null,
 1559:           taskId: operation.taskId || null,
 1560:           reason: 'empty_session_id',
 1561:         });
 1562:         appendInternalLog('Codex session id was empty; starting a new session.');
 1563:       }
 1564: 
 1565:       const fresh = await runAttempt(codexNewSessionArgs(workspace, lastFile, { reasoningEffort: codexReasoningEffort }), 'new');
 1566:       return resultFor(fresh, 'new');
 1567:     } finally {
 1568:       clearInterval(tailTimer);
 1569:       stream.end();
 1570:       if (operationKey && runtime.activeOperations.has(operationKey)) {
 1571:         this.archiveOperation(projectIdForEmit, operationKey);
 1572:       }
 1573:     }
 1574:   }
