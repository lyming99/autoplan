 1350:         ...agentCliContextFields(op),
 1351:         logFile: op.logFile || null,
 1352:         lastFile: op.lastFile || null,
 1353:         errorMessage: op.errorMessage || '',
 1354:         startedAt: op.startedAt || null,
 1355:         finishedAt: nowIso(),
 1356:         exitCode: typeof op.exitCode === 'number' ? op.exitCode : null,
 1357:         logTail: (op.logBuffer || '').slice(-8000),
 1358:         activity: op.activity ? op.activity.getLines() : [],
 1359:         ...(op.agentCliProvider === DEFAULT_AGENT_CLI_PROVIDER ? codexSessionContextFields(op) : {}),
