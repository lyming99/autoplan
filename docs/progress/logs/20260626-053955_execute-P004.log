 1788:       [TASK_EVENT_TYPES.SUCCEEDED]: '结束了',
 1789:       [TASK_EVENT_TYPES.FAILED]: '执行失败',
 1790:       [TASK_EVENT_TYPES.STOP_REQUESTED]: '请求停止',
 1791:       [TASK_EVENT_TYPES.STOPPED]: '停止了',
 1792:       [TASK_EVENT_TYPES.INTERRUPTED]: '中断了',
 1793:     }[type] || '更新了';
 1794:   const providerContext = meta?.agentCliProvider ? agentCliProviderDisplayName(meta.agentCliProvider) : '';
 1795:   const codexContext = meta?.agentCliProvider === DEFAULT_AGENT_CLI_PROVIDER ? codexSessionReadableLabel(meta) : '';
 1796:   const reasoningContext = meta?.agentCliProvider === DEFAULT_AGENT_CLI_PROVIDER && meta?.codexReasoningEffort
