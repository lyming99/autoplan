    startedAt: operation.startedAt || null,
    ...(operation.finishedAt ? { finishedAt: operation.finishedAt } : {}),
    ...(typeof operation.exitCode === 'number' ? { exitCode: operation.exitCode } : {}),
    ...(operation.logFile ? { logFile: operation.logFile } : {}),
