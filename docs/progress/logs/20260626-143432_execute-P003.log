341: function toSearchText(value: unknown, depth = 0): string {
342:   if (value === null || value === undefined || depth > 6) return '';
343:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
344:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
345:   if (typeof value === 'object') {
346:     return Object.values(value as Record<string, unknown>)
347:       .map((item) => toSearchText(item, depth + 1))
348:       .join(' ');
349:   }
350:   return '';
351: }
