262: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
263:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
264:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
265:     return 'stopping';
266:   }
267:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
268:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
269:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
270:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
271:   return 'updated';
272: }
