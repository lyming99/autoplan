.field-label { display: flex; align-items: center; gap: 6px; color: var(--text-2); font-size: 12px; font-weight: 700; }
.field-label .tag { margin-left: 4px; padding: 1px 6px; border: 1px solid var(--line); border-radius: 4px; background: var(--bg-soft); color: var(--text-4); font-size: 10px; font-weight: 800; }
.field-input, .field-select { width: 100%; padding: 9px 11px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); font: inherit; font-size: 13px; transition: border-color 0.14s, box-shadow 0.14s; }
.field-input:focus, .field-select:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.field-input.mono, .field-select.mono { font-family: var(--font-mono); font-size: 12px; }
.field-hint { color: var(--text-3); font-size: 11.5px; line-height: 1.5; }
.field-hint code, .inline-banner code { padding: 0 5px; border: 1px solid var(--line); border-radius: 4px; background: var(--bg-soft); font-size: 11px; }
.input-affix { display: flex; align-items: stretch; }
.input-affix .field-input { border-radius: var(--r-sm) 0 0 var(--r-sm); }
.input-affix .affix { display: grid; place-items: center; padding: 0 12px; border: 1px solid var(--line); border-left: 0; border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--bg-soft); color: var(--text-3); font-size: 12px; font-weight: 700; }
.settings-actions { justify-content: flex-end; margin-top: 10px; padding: 12px 0 0; }
.info-row { display: grid; grid-template-columns: 130px minmax(0,1fr); gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--line-soft); }
.info-row:last-of-type { border-bottom: 0; }
.info-key { color: var(--text-3); font-size: 12px; font-weight: 700; }
.info-val { min-width: 0; color: var(--text-1); font-size: 13px; overflow-wrap: anywhere; }
.info-val .mono { font-family: var(--font-mono); font-size: 12.5px; }
.mcp-status { display: inline-flex; align-items: center; gap: 6px; padding: 3px 9px; border-radius: 999px; background: var(--bg-soft); color: var(--text-2); font-size: 11.5px; font-weight: 750; }
.mcp-status::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
.mcp-status.ok { color: var(--success); background: var(--success-bg); }
.mcp-status.warn { color: var(--warning); background: var(--warning-bg); }
.tool-tags { display: flex; flex-wrap: wrap; gap: 6px; min-width: 0; }
.tool-tag { display: inline-flex; align-items: center; max-width: 100%; padding: 4px 8px; border: 1px solid var(--line-soft); border-radius: 999px; background: var(--bg-soft); color: var(--brand-700); font-family: var(--font-mono); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inline-banner { display: flex; gap: 10px; margin-top: 12px; padding: 10px 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); color: var(--text-2); font-size: 12px; line-height: 1.55; }
.inline-banner.info { border-color: rgba(45,126,255,0.22); background: var(--info-bg); }
.dim { color: var(--text-4); }

/* 表单型卡片（如循环控制）：head 之后给 body 留内边距 */
.editor.card { display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
.editor > .card-head { flex: 0 0 auto; }
.editor > .field,
.editor > .button-row,
.editor > .control-row { padding: 0 18px; }
.editor > .field:first-of-type { padding-top: 16px; }
.editor > .button-row { padding: 4px 18px 18px; flex-wrap: wrap; }
.editor .button-row button {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 7px 14px; border: 1px solid var(--line); border-radius: var(--r-sm);
  background: var(--bg-elevated); color: var(--text-1); font-size: 12.5px; font-weight: 600;
  transition: background 0.14s, border-color 0.14s;
}
.editor .button-row button:hover { background: var(--bg-hover); }
.editor .button-row button[type="submit"] { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
.editor .button-row button[type="submit"]:hover { background: var(--brand-700); }

.chip { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; letter-spacing: 0.02em; text-transform: uppercase; }
.chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.chip-pending { color: var(--text-3); background: var(--bg-soft); }
.chip-running { color: var(--info); background: var(--info-bg); }
.chip-completed { color: var(--success); background: var(--success-bg); }
.chip-failed { color: var(--danger); background: var(--danger-bg); }
.chip-stopped { color: var(--warning); background: var(--warning-bg); }
.chip-waiting { color: var(--warning); background: var(--warning-bg); }

.empty { color: var(--text-3); padding: 28px 18px; text-align: center; font-size: 13px; }
.error-banner { padding: 12px 16px; margin-bottom: 16px; border-radius: var(--r-md); background: var(--danger-bg); border: 1px solid #f3c2c4; color: var(--danger); font-size: 13px; }
.req { color: var(--danger); }
.danger-text { color: var(--danger); }

.app-icon { display: inline-block; flex: 0 0 auto; width: var(--icon-size, 1em); height: var(--icon-size, 1em); color: inherit; vertical-align: -0.14em; }
.app-icon * { vector-effect: non-scaling-stroke; }
.app-icon-muted { color: var(--text-3); }
.app-icon-brand { color: var(--brand-600); }
.app-icon-success { color: var(--success); }
.app-icon-warning { color: var(--warning); }
.app-icon-danger { color: var(--danger); }
.icon-with-text { display: inline-flex; align-items: center; gap: 6px; }
.icon-surface { display: inline-grid; place-items: center; width: var(--icon-surface-size, 36px); height: var(--icon-surface-size, 36px); border-radius: 50%; color: var(--icon-surface-color, currentColor); background: var(--icon-surface-bg, transparent); }
.icon-surface-brand { --icon-surface-color: var(--brand-600); --icon-surface-bg: var(--brand-50); }
.icon-surface-success { --icon-surface-color: var(--success); --icon-surface-bg: var(--success-bg); }
.icon-surface-warning { --icon-surface-color: var(--warning); --icon-surface-bg: var(--warning-bg); }
.icon-surface-danger { --icon-surface-color: var(--danger); --icon-surface-bg: var(--danger-bg); }

.list { display: grid; gap: 10px; padding: 16px 18px; }
.list.compact { max-height: none; overflow: auto; }
.item { min-width: 0; border: 1px solid var(--line-soft); border-radius: var(--r-md); padding: 12px; background: var(--bg-soft); }
.item-title { display: flex; justify-content: space-between; gap: 12px; min-width: 0; font-weight: 650; align-items: center; }
.item-title > span:first-child { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-title-right { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; min-width: 0; flex: 0 0 auto; }
.item-actions { display: inline-flex; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: 4px; }
.item-actions .btn-link { padding: 3px 6px; font-size: 12px; white-space: nowrap; }
.item-actions .danger-link { color: var(--danger); }
.item-actions .btn-link:disabled { color: var(--text-4); cursor: not-allowed; text-decoration: none; }
.item-body { margin-top: 10px; color: var(--text-2); overflow-wrap: anywhere; }
.plain-text { line-height: 1.55; white-space: pre-wrap; word-break: break-word; }
.plan-card-list { display: flex; flex-direction: column; gap: 10px; padding: 12px; }
.plan-card {
  display: grid; gap: 0; min-width: 0; padding: 13px 15px;
  border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-elevated);
  transition: border-color 0.14s, background 0.14s, box-shadow 0.14s;
}
.plan-card:hover { border-color: var(--line); box-shadow: var(--shadow-sm); }
.plan-card.selected { border-color: #d6e0f3; background: var(--brand-50); }
.plan-card.running { border-color: rgba(45,126,255,0.28); }
.plan-card.draft { background: linear-gradient(180deg, var(--bg-elevated), rgba(255,247,237,0.72)); }
.plan-card.completed { background: linear-gradient(180deg, var(--bg-elevated), rgba(236,253,245,0.7)); }
.plan-top { display: flex; align-items: center; gap: 8px; min-width: 0; flex-wrap: wrap; }
.plan-path {
  flex: 1 1 160px; min-width: 0; max-width: 100%; overflow: hidden; color: var(--text-1);
  font-family: var(--font-mono); font-size: 12.5px; font-weight: 600; text-overflow: ellipsis; white-space: nowrap;
}
.plan-title { margin-top: 4px; color: var(--text-1); font-size: 13px; font-weight: 600; line-height: 1.45; overflow-wrap: anywhere; }
.plan-title.muted { color: var(--text-3); font-weight: 500; }
.plan-progress { margin-top: 11px; }
.progress-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 6px; font-size: 11.5px; }
.progress-head .ph-left { color: var(--text-2); font-weight: 600; }
.progress-head .ph-right { flex: 0 0 auto; color: var(--text-3); font-family: var(--font-mono); }
.progress { height: 6px; overflow: hidden; border-radius: 999px; background: var(--line); }
.progress > span { display: block; height: 100%; border-radius: 999px; background: var(--brand-grad); transition: width 0.3s; }
.progress.success > span { background: var(--success); }
.progress.running > span { background: var(--info); }
.plan-progress-subline { margin-top: 5px; color: var(--text-3); font-size: 11px; }
.concurrency-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 11px; }
.conc-item { display: inline-flex; align-items: center; gap: 5px; color: var(--text-2); font-size: 11.5px; }
.conc-item b { color: var(--text-1); font-family: var(--font-mono); font-size: 12px; }
.conc-item.parallel b { color: var(--success); }
.conc-item.batch b { color: var(--info); }
.conc-item.serial b { color: var(--warning); }
.conc-item.blocked { max-width: 100%; color: var(--danger); overflow-wrap: anywhere; }
.plan-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; min-width: 0; margin-top: 11px; color: var(--text-3); font-size: 11px; }
.plan-meta .mono { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.meta-dot { flex: 0 0 auto; width: 3px; height: 3px; border-radius: 50%; background: var(--text-4); }
.cli-tag { display: inline-flex; align-items: center; gap: 4px; min-width: 0; color: var(--text-2); font-size: 11px; font-weight: 600; }
.plan-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; min-width: 0; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--line-soft); }
.plan-primary-actions, .plan-secondary-actions { display: inline-flex; align-items: center; gap: 4px; flex-wrap: wrap; min-width: 0; }
.plan-secondary-actions .btn-link { padding: 3px 5px; }
.plan-select-button.active { color: var(--brand-700); text-decoration: underline; }
.plan-validation { margin-left: auto; color: var(--text-3); font-size: 11px; white-space: nowrap; }
.plan-validation.passed { color: var(--success); }
.plan-validation.pending { color: var(--text-3); }
.plan-list-error { margin: 10px 12px 0; }
.task-list-panel { display: flex; flex: 1 1 auto; flex-direction: column; min-height: 0; }
.task-list-panel .list { flex: 1 1 auto; min-height: 0; padding-top: 10px; }
.task-groups { display: flex; flex-direction: column; gap: 14px; }
.task-plan-group {
  display: grid; gap: 8px; min-width: 0; padding: 10px;
  border: 1px solid transparent; border-radius: var(--r-lg); background: var(--bg-elevated);
}
.task-plan-group.has-running, .task-plan-group:has(.chip-running) { border-color: rgba(45,126,255,0.2); background: linear-gradient(180deg, var(--bg-elevated), rgba(239,246,255,0.76)); }
.task-plan-group-head {
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  width: 100%; min-width: 0; padding: 4px 2px 8px; border: 0; background: transparent; text-align: left;
}
.task-plan-group-toggle { cursor: pointer; }
.task-plan-group-toggle:hover .task-plan-group-title { color: var(--brand-700); }
.task-plan-group-title-wrap { display: inline-flex; align-items: center; gap: 8px; min-width: 0; flex: 1 1 auto; }
.task-plan-group-chevron { flex: 0 0 auto; color: var(--text-3); font-size: 11px; transition: transform 0.14s; }
.task-plan-group.is-collapsed .task-plan-group-chevron { transform: rotate(-90deg); }
.task-plan-group-dot { flex: 0 0 auto; width: 8px; height: 8px; border-radius: 50%; background: var(--text-4); }
.task-plan-group.has-running .task-plan-group-dot, .task-plan-group:has(.chip-running) .task-plan-group-dot { background: var(--info); box-shadow: 0 0 0 4px var(--info-bg); }
.task-plan-group-meta { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; min-width: 0; flex: 0 1 50%; }
.task-plan-group-counts {
  flex: 0 0 auto; padding: 2px 8px; border-radius: 999px; background: var(--bg-soft);
  color: var(--text-3); font-size: 11px; font-weight: 700; white-space: nowrap;
}
.task-plan-group-title {
  min-width: 0; flex: 1 1 auto; overflow: hidden; color: var(--text-1);
  font-family: var(--font-mono); font-size: 12px; font-weight: 750; line-height: 1.45; text-overflow: ellipsis; white-space: nowrap;
}
.task-plan-group-summary {
  flex: 1 1 auto; min-width: 0; color: var(--text-3); font-size: 12px; line-height: 1.45;
  overflow: hidden; text-align: right; text-overflow: ellipsis; white-space: nowrap;
}
.task-plan-group-items { display: flex; flex-direction: column; gap: 10px; min-width: 0; }
.task-plan-group .item, .task-item {
  min-width: 0; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md);
  background: var(--bg-soft);
}
.task-plan-group .item.running, .task-plan-group .item:has(.chip-running), .task-item.running { border-color: rgba(45,126,255,0.22); background: var(--info-bg); }
.task-plan-group .item-title, .task-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
.task-key {
  flex: 0 0 auto; padding: 2px 7px; border-radius: 6px; background: var(--brand-50);
  color: var(--brand-700); font-family: var(--font-mono); font-size: 10.5px; font-weight: 800;
}
.task-title { flex: 1 1 auto; min-width: 0; overflow: hidden; color: var(--text-1); font-size: 13px; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.task-duration { flex: 0 0 auto; color: var(--text-3); font-family: var(--font-mono); font-size: 10.5px; white-space: nowrap; }
.task-duration.running { color: var(--info); font-weight: 700; }
.task-file, .task-file-link {
  display: inline-flex; align-items: center; max-width: 100%; justify-content: flex-start; margin-top: 8px;
  padding: 0; color: var(--text-2); text-align: left; white-space: normal; word-break: break-word; overflow-wrap: anywhere;
}
.task-actions { display: flex; align-items: center; justify-content: flex-end; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
.task-meta { color: var(--text-3); font-size: 11px; text-align: right; }
.task-filter-tabs {
  display: flex; align-items: center; gap: 6px; padding: 12px 18px 8px;
  border-bottom: 1px solid var(--line-soft);
}
.task-filter-tab {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  min-width: 0; min-height: 32px; flex: 1 1 0; padding: 6px 9px;
  border: 1px solid var(--line); border-radius: 999px; background: var(--bg-elevated);
  color: var(--text-2); font-size: 12px; font-weight: 700; white-space: nowrap;
  transition: background 0.14s, border-color 0.14s, color 0.14s;
}
.task-filter-tab:hover { background: var(--bg-hover); }
.task-filter-tab.active { border-color: var(--brand-600); background: var(--brand-50); color: var(--brand-600); }
.task-filter-count {
  display: inline-grid; place-items: center; min-width: 20px; height: 20px; padding: 0 6px;
  border-radius: 999px; background: var(--bg-soft); color: inherit; font-size: 11px; font-weight: 800;
}
.task-filter-tab.active .task-filter-count { background: rgba(255,255,255,0.72); }
.plan-selection-bar {
  display: flex; align-items: center; justify-content: space-between; gap: 10px;
  padding: 9px 12px; border-bottom: 1px solid var(--line-soft); color: var(--text-3); font-size: 12px;
}
.plan-selection-bar.is-active { background: var(--brand-50); color: var(--brand-700); }
.plan-selection-summary { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.plan-selection-clear { flex: 0 0 auto; }
.plan-selection-clear:disabled { color: var(--text-4); }
.task-body-stack { display: grid; gap: 8px; min-width: 0; }
.task-scope-files, .scope-files { display: flex; flex-wrap: wrap; gap: 6px; min-width: 0; margin-top: 8px; }
.task-scope-chip {
  display: inline-flex; align-items: center; gap: 6px; max-width: 100%; min-width: 0;
  padding: 4px 8px; border: 1px solid var(--line-soft); border-radius: 999px;
  background: var(--bg-elevated); color: var(--text-2); font-size: 11px; line-height: 1.35;
}
.task-scope-chip .mono { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.task-scope-chip small { flex: 0 0 auto; color: var(--text-4); font-size: 10px; }
.task-scope-chip.openable { border-color: rgba(41,151,90,0.26); background: var(--success-bg); color: var(--success); }
.task-scope-chip.validation, .task-scope-chip[title="完整验收任务"] { border-color: rgba(45,126,255,0.24); background: var(--info-bg); color: var(--info); }
.task-scope-chip.unknown, .task-scope-chip.special { border-color: rgba(220,158,54,0.28); background: var(--warning-bg); color: var(--warning); }
.markdown-reader { min-width: 0; max-width: 100%; color: var(--text-1); font-size: 13.5px; line-height: 1.72; overflow-wrap: anywhere; }
.markdown-reader > :first-child { margin-top: 0; }
.markdown-reader > :last-child { margin-bottom: 0; }
.markdown-reader-empty { padding: 28px 18px; border: 1px dashed var(--line); border-radius: var(--r-md); background: var(--bg-soft); color: var(--text-3); text-align: center; font-size: 13px; }
.markdown-reader h1 { margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--line-soft); font-size: 22px; line-height: 1.3; font-weight: 800; }
.markdown-reader h2 { margin: 24px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--line-soft); font-size: 18px; line-height: 1.35; font-weight: 750; }
.markdown-reader h3 { margin: 20px 0 8px; font-size: 15.5px; line-height: 1.4; font-weight: 700; }
.markdown-reader h4, .markdown-reader h5, .markdown-reader h6 { margin: 16px 0 8px; font-size: 14px; line-height: 1.4; font-weight: 700; }
.markdown-reader p { margin: 0 0 12px; color: var(--text-2); }
.markdown-reader a { color: var(--brand-600); overflow-wrap: anywhere; word-break: break-word; }
.markdown-reader a:hover { text-decoration: underline; }
.markdown-scope-files { display: inline-flex; flex-wrap: wrap; align-items: center; gap: 5px; vertical-align: baseline; }
.markdown-scope-label { padding: 2px 6px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 800; }
.markdown-scope-link {
  max-width: min(100%, 360px); padding: 2px 7px; border: 1px solid var(--line-soft); border-radius: 999px;
  background: var(--bg-elevated); color: var(--brand-600); font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.markdown-scope-link:hover:not(:disabled) { border-color: var(--brand-500); background: var(--brand-50); text-decoration: none; }
.markdown-scope-link.special, .markdown-scope-link:disabled { color: var(--text-4); cursor: not-allowed; }
.markdown-reader ul, .markdown-reader ol { margin: 0 0 14px; padding-left: 1.45em; color: var(--text-2); }
.markdown-reader li { margin: 4px 0; }
.markdown-reader li > p { margin: 6px 0; }
.markdown-reader .contains-task-list { list-style: none; padding-left: 1.2em; }
.markdown-reader .task-list-item { margin-left: -1.2em; }
.markdown-reader input[type="checkbox"] { width: auto; margin: 0 7px 0 0; accent-color: var(--brand-600); vertical-align: -2px; }
.markdown-reader .task-list-item > input[type="checkbox"] { margin-top: 0.42em; }
.markdown-reader blockquote { margin: 14px 0; padding: 10px 14px; border-left: 3px solid var(--brand-500); border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--brand-50); color: var(--text-2); }
.markdown-reader blockquote p { color: inherit; }
.markdown-reader code { padding: 2px 5px; border: 1px solid var(--line-soft); border-radius: var(--r-sm); background: var(--bg-soft); color: var(--text-1); font-family: var(--font-mono); font-size: 0.92em; word-break: break-word; }
.markdown-reader pre { max-width: 100%; margin: 14px 0; padding: 12px 14px; overflow: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,0.65); }
.markdown-reader pre code { display: block; padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text-1); white-space: pre; word-break: normal; overflow-wrap: normal; }
.markdown-reader pre:focus-visible, .markdown-reader-table:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
.markdown-reader-table { max-width: 100%; margin: 14px 0; overflow-x: auto; border: 1px solid var(--line); border-radius: var(--r-md); }
.markdown-reader-table table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 13px; }
.markdown-reader th, .markdown-reader td { padding: 8px 10px; border: 1px solid var(--line); text-align: left; vertical-align: top; }
.markdown-reader th { background: var(--bg-soft); color: var(--text-1); font-weight: 700; }
.markdown-reader tr:nth-child(even) td { background: rgba(248,250,253,0.65); }
.markdown-reader hr { margin: 20px 0; border: 0; border-top: 1px solid var(--line); }
.markdown-reader img { max-width: 100%; height: auto; border-radius: var(--r-md); box-shadow: var(--shadow-sm); }
.meta { margin-top: 6px; color: var(--text-3); font-size: 12px; word-break: break-all; overflow-wrap: anywhere; }
.event-list { min-width: 0; }
.event-item { display: grid; gap: 8px; border-left: 3px solid transparent; }
.event-title { align-items: flex-start; }
.event-title > span:first-child { white-space: normal; overflow: visible; text-overflow: clip; overflow-wrap: anywhere; line-height: 1.45; }
.event-badge { flex: 0 0 auto; display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; white-space: nowrap; }
.event-badge-start, .event-badge-updated { color: var(--info); background: var(--info-bg); }
.event-badge-success { color: var(--success); background: var(--success-bg); }
.event-badge-failed { color: var(--danger); background: var(--danger-bg); }
.event-badge-stopped, .event-badge-stopping { color: var(--warning); background: var(--warning-bg); }
.event-item-start { border-left-color: var(--info); }
.event-item-success { border-left-color: var(--success); }
.event-item-failed { border-left-color: var(--danger); }
.event-item-stopped, .event-item-stopping { border-left-color: var(--warning); }
.event-item-updated { border-left-color: var(--info); }
.event-item .item-body, .event-meta { margin-top: 0; }
.button-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; }

/* 需求/反馈卡片：进度 + 操作脚 + 追加任务 */
.intake-progress { margin-top: 12px; }
.intake-item .item-foot {
  display: flex; align-items: center; gap: 12px; margin-top: 12px;
  padding-top: 10px; border-top: 1px solid var(--line-soft);
}
.intake-item .item-foot .meta { margin-top: 0; margin-left: auto; }
.intake-item .item-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
.intake-item .danger-link { color: var(--danger); }
.intake-item .danger-link:hover { text-decoration: underline; }
.append-row {
  display: flex; gap: 8px; margin-top: 12px;
  padding: 10px; border-radius: var(--r-sm);
  background: var(--bg-soft); border: 1px dashed var(--line);
}
.append-input { flex: 1 1 auto; padding: 7px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); font: inherit; font-size: 12.5px; }
.append-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.inline-editor { display: grid; gap: 10px; margin-top: 12px; }
.inline-editor .field { margin-bottom: 0; }
.inline-editor textarea { min-height: 140px; }
.attachment-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
.attachment-thumb, .attachment-file { display: grid; gap: 6px; width: 120px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); }
.attachment-thumb img { width: 100%; aspect-ratio: 1; border-radius: 4px; object-fit: cover; background: var(--brand-50); }
.attachment-thumb span, .attachment-file span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
.attachment-file small { color: var(--text-3); font-size: 12px; }

.modal-mask { position: fixed; inset: 0; z-index: 100; overflow: auto; background: rgba(23,32,51,0.42); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 24px; }
.modal { width: 100%; max-width: 480px; background: var(--bg-elevated); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); overflow: hidden; }
.modal-confirm { max-width: 400px; text-align: center; padding: 28px 24px 0; }
.modal-head { display: flex; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line-soft); }
.modal-head h3 { font-size: 16px; font-weight: 700; }
.modal-close { margin-left: auto; width: 30px; height: 30px; border-radius: 8px; border: 0; background: transparent; color: var(--text-3); display: grid; place-items: center; }
.modal-close:hover { background: var(--bg-hover); color: var(--text-1); }
.modal-form { padding: 20px 22px; }
.modal-confirm p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin: 8px 0 4px; }
.modal-danger-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 50%; background: var(--danger-bg); color: var(--danger); margin: 0 auto 14px; }
.modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--line-soft); background: var(--bg-soft); }

.parallel-confirm-modal { max-width: min(680px, calc(100vw - 48px)); max-height: min(86dvh, 760px); display: flex; flex-direction: column; }
.parallel-confirm-body { display: grid; gap: 12px; min-height: 0; overflow: auto; padding: 18px 22px; color: var(--text-2); font-size: 13px; line-height: 1.55; }
.parallel-confirm-body p { margin: 0; }
.parallel-batch-card { display: grid; gap: 10px; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
.parallel-batch-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; min-width: 0; }
.parallel-batch-head strong { color: var(--text-1); font-size: 13px; }
.parallel-batch-head span { min-width: 0; color: var(--text-3); font-size: 12px; text-align: right; overflow-wrap: anywhere; }
.parallel-batch-card ul, .parallel-serial-reasons ul { display: grid; gap: 8px; margin: 0; padding-left: 18px; }
.parallel-batch-card li { min-width: 0; }
.parallel-batch-card li span, .parallel-batch-card li small { display: block; min-width: 0; overflow-wrap: anywhere; }
.parallel-batch-card li small { margin-top: 2px; color: var(--text-3); font-size: 11px; }
.parallel-serial-reasons { padding: 10px 12px; border: 1px dashed var(--line); border-radius: var(--r-md); background: var(--bg-elevated); }
.parallel-serial-reasons summary { cursor: pointer; color: var(--brand-600); font-weight: 700; }
.parallel-serial-reasons ul { margin-top: 10px; color: var(--text-3); font-size: 12px; }

.plan-reader-modal { width: 100%; max-width: min(920px, calc(100vw - 48px)); max-height: min(86dvh, 860px); display: flex; flex-direction: column; }
.plan-reader-head { flex: 0 0 auto; align-items: flex-start; }
.plan-reader-title { min-width: 0; display: flex; flex: 1 1 auto; flex-direction: column; gap: 5px; }
.plan-reader-path { max-width: 100%; overflow: hidden; color: var(--text-3); font-size: 12px; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
.plan-reader-actions { flex: 0 0 auto; }
.plan-reader-body { flex: 1 1 auto; min-height: 0; overflow: auto; overscroll-behavior: contain; padding: 16px 22px 22px; display: flex; flex-direction: column; gap: 14px; }
.plan-reader-body:focus-visible { outline: 2px solid var(--brand-500); outline-offset: -4px; }
.plan-reader-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin: 0; }
.plan-reader-summary-item { min-width: 0; padding: 10px 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
.plan-reader-summary-item dt { display: block; margin-bottom: 4px; color: var(--text-3); font-size: 11px; font-weight: 700; }
.plan-reader-summary-item dd { display: block; min-width: 0; margin: 0; overflow: hidden; color: var(--text-1); font-size: 12.5px; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.plan-reader-content { min-width: 0; padding: 16px; overflow: visible; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); box-shadow: var(--shadow-sm); }
.plan-reader-loading, .plan-reader-error { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; padding: 14px 16px; border-radius: var(--r-md); font-size: 13px; line-height: 1.5; }
.plan-reader-loading { border: 1px dashed var(--line); background: var(--bg-soft); color: var(--text-3); }
.plan-reader-error { border: 1px solid rgba(229,72,77,0.28); background: var(--danger-bg); color: var(--danger); }

