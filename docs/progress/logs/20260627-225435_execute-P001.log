 222: export function MarkdownReader({
 223:   markdown,
 224:   className,
 225:   emptyMessage = '暂无计划正文',
 226:   ariaLabel = 'Markdown 正文',
 227:   onOpenScopeFile,
 228: }: MarkdownReaderProps) {
 229:   const content = markdown ?? '';
 230:   const classes = ['markdown-reader', className].filter(Boolean).join(' ');
 231: 
 232:   if (!content.trim()) {
 233:     return (
 234:       <div className={`${classes} markdown-reader-empty`} role="status" aria-live="polite">
 235:         {emptyMessage}
 236:       </div>
 237:     );
 238:   }
 239: 
 240:   return (
 241:     <div className={classes} role="region" aria-label={ariaLabel}>
 242:       <ReactMarkdown
 243:         components={createMarkdownComponents(onOpenScopeFile)}
 244:         remarkPlugins={[remarkGfm]}
 245:         urlTransform={safeUrlTransform}
 246:       >
 247:         {exposeHtmlComments(content)}
 248:       </ReactMarkdown>
 249:     </div>
 250:   );
 251: }
 252: 
