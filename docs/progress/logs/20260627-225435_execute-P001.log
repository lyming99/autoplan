 208:       const text = childrenText(children);
 209:       const nextChildren = text ? renderScopeCommentParts(text, onOpenScopeFile) : children;
 210:       return <li {...props}>{nextChildren}</li>;
 211:     },
 212:     code({ node: _node, children, ...props }) {
 213:       const text = childrenText(children);
 214:       if (!props.className && text.startsWith('<!--') && /scope|scopes|files?|影响范围|并发键/i.test(text)) {
 215:         return <>{renderScopeCommentParts(`\`${text}\``, onOpenScopeFile)}</>;
 216:       }
 217:       return <code {...props}>{children}</code>;
 218:     },
 219:   };
 220: }
