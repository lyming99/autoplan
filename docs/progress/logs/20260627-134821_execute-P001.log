  101: function normalizeTaskStatus(status: string | null | undefined) {
  102:   return String(status || '').trim().toLowerCase();
  103: }
  104: 
  105: function matchesTaskStatusFilter(task: PlanTask, filter: TaskStatusFilter) {
  106:   const status = normalizeTaskStatus(task.status);
  107:   if (filter === 'all') return true;
  108:   if (filter === 'running') return ['running', 'processing', 'stopping'].includes(status);
  109:   if (filter === 'queued') return ['pending', 'queued', 'waiting'].includes(status);
  110:   if (filter === 'completed') return ['completed', 'done', 'passed', 'accepted'].includes(status);
  111:   return true;
  112: }
  113: 
  114: function readTaskTime(value: string | null | undefined) {
  115:   const time = Date.parse(String(value || ''));
  116:   return Number.isFinite(time) ? time : null;
  117: }
  118: 
  119: function taskSortTime(task: TimedPlanTask) {
  120:   return readTaskTime(task.finished_at) ?? readTaskTime(task.started_at) ?? readTaskTime(task.updated_at);
  121: }
  122: 
  123: function latestTaskTime(tasks: TimedPlanTask[]) {
  124:   const fieldGroups: Array<Array<keyof TimedPlanTask>> = [['finished_at'], ['started_at'], ['updated_at']];
  125:   for (const fields of fieldGroups) {
  126:     const times = tasks.flatMap((task) => fields.map((field) => readTaskTime(task[field] as string | null | undefined)));
  127:     const validTimes = times.filter((time): time is number => time !== null);
  128:     if (validTimes.length) return Math.max(...validTimes);
  129:   }
  130:   return null;
  131: }
  132: 
  133: function latestTaskTimestamp(tasks: TimedPlanTask[], field: 'finished_at' | 'updated_at') {
  134:   let latestValue = '';
  135:   let latestTime: number | null = null;
  136:   tasks.forEach((task) => {
  137:     const value = task[field];
  138:     const time = readTaskTime(value);
  139:     if (time === null) return;
  140:     if (latestTime === null || time > latestTime) {
  141:       latestTime = time;
  142:       latestValue = value || '';
  143:     }
  144:   });
  145:   return latestValue;
  146: }
