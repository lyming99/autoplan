   77: function readDurationMs(task: TimedPlanTask) {
   78:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
   79:   const duration = Number(task.duration_ms);
   80:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
   81: }
   82: 
   83: function getTaskDurationMs(task: TimedPlanTask) {
   84:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
   85:   return readDurationMs(task);
   86: }
   87: 
   88: function readPlanId(task: TimedPlanTask) {
   89:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
   90:   const planId = Number(task.plan_id);
   91:   return Number.isFinite(planId) ? planId : null;
   92: }
   93: 
   94: function formatTaskDuration(task: TimedPlanTask) {
   95:   const duration = getTaskDurationMs(task);
