  177:       running: stats.running + (matchesTaskStatusFilter(task, 'running') ? 1 : 0),
  178:       completed: stats.completed + (matchesTaskStatusFilter(task, 'completed') ? 1 : 0),
  179:     }),
  180:     { total: 0, running: 0, completed: 0 },
  181:   );
  182: }
