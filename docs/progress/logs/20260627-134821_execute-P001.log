  167:   if (task.file_path) return { key: `file:${task.file_path}`, source: 'file', sourceId: task.file_path };
  168:   const title = taskPlanGroupTitle(task);
  169:   if (title !== '未命名计划') return { key: `title:${title}`, source: 'title', sourceId: title };
  170:   return { key: 'unknown-plan', source: 'unknown', sourceId: null };
  171: }
