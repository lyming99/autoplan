  149:   const timedTasks = group.tasks as TimedPlanTask[];
  150:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
  151:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
  152:   const timeSummary = latestFinishedAt
  153:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
  154:     : latestUpdatedAt
  155:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
  156:       : '暂无时间记录';
  157:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
  158: }
