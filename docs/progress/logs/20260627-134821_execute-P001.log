  137:     const value = task[field];
  138:     const time = readTaskTime(value);
  139:     if (time === null) return;
  140:     if (latestTime === null || time > latestTime) {
  141:       latestTime = time;
  142:       latestValue = value || '';
  143:     }
  144:   });
  145:   return latestValue;
  146: }
  147: 
  148: function formatTaskPlanGroupSummary(group: TaskPlanGroup) {
  149:   const timedTasks = group.tasks as TimedPlanTask[];
  150:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
  151:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
  152:   const timeSummary = latestFinishedAt
  153:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
  154:     : latestUpdatedAt
  155:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
  156:       : '暂无时间记录';
  157:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
  158: }
  159: 
  160: function taskPlanGroupTitle(task: PlanTask) {
  161:   return String(task.plan_title || task.file_path || '未命名计划').trim() || '未命名计划';
  162: }
  163: 
  164: function taskPlanGroupIdentity(task: TimedPlanTask): TaskPlanGroupIdentity {
  165:   const planId = readPlanId(task);
  166:   if (planId !== null) return { key: `plan:${planId}`, source: 'plan', sourceId: String(planId) };
  167:   if (task.file_path) return { key: `file:${task.file_path}`, source: 'file', sourceId: task.file_path };
  168:   const title = taskPlanGroupTitle(task);
  169:   if (title !== '未命名计划') return { key: `title:${title}`, source: 'title', sourceId: title };
  170:   return { key: 'unknown-plan', source: 'unknown', sourceId: null };
  171: }
  172: 
  173: function getTaskPlanGroupStats(tasks: PlanTask[]): TaskPlanGroupStats {
  174:   return tasks.reduce<TaskPlanGroupStats>(
  175:     (stats, task) => ({
  176:       total: stats.total + 1,
  177:       running: stats.running + (matchesTaskStatusFilter(task, 'running') ? 1 : 0),
  178:       completed: stats.completed + (matchesTaskStatusFilter(task, 'completed') ? 1 : 0),
  179:     }),
  180:     { total: 0, running: 0, completed: 0 },
  181:   );
  182: }
  183: 
  184: function groupTasksByPlan(tasks: PlanTask[]) {
  185:   const groups = new Map<string, TaskPlanGroup>();
  186:   tasks.forEach((task, index) => {
  187:     const timedTask = task as TimedPlanTask;
  188:     const identity = taskPlanGroupIdentity(timedTask);
  189:     const key = identity.key;
  190:     const existingGroup = groups.get(key);
  191:     if (existingGroup) {
  192:       existingGroup.tasks.push(task);
  193:       if (existingGroup.title === '未命名计划') existingGroup.title = taskPlanGroupTitle(task);
  194:       return;
  195:     }
  196: 
  197:     groups.set(key, {
  198:       key,
  199:       source: identity.source,
  200:       sourceId: identity.sourceId,
  201:       title: taskPlanGroupTitle(task),
  202:       tasks: [task],
  203:       firstIndex: index,
  204:       sortTime: null,
  205:       stats: { total: 0, running: 0, completed: 0 },
  206:       hasRunningTask: false,
  207:     });
  208:   });
  209: 
  210:   return Array.from(groups.values())
