 1064: function filterItemsBySearchGroup<T extends { id: number }>(
 1065:   items: T[],
 1066:   groups: WorkspaceSearchGroup[],
 1067:   source: WorkspaceSearchSourceType,
 1068: ) {
 1069:   const group = groups.find((item) => item.source === source);
 1070:   if (!group?.results.length) return [];
 1071: 
 1072:   const recordIds = new Set(group.results.map((result) => result.recordId));
 1073:   return items.filter((item) => recordIds.has(item.id));
 1074: }
 1075: 
 1076: function filterTasksBySearchGroups(
 1077:   tasks: PlanTask[],
 1078:   plans: Plan[],
 1079:   groups: WorkspaceSearchGroup[],
 1080: ) {
 1081:   const directTasks = filterItemsBySearchGroup(tasks, groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK);
 1082:   if (!plans.length) return directTasks;
 1083: 
 1084:   const taskIds = new Set(directTasks.map((task) => task.id));
 1085:   const planIds = new Set(plans.map((plan) => plan.id));
 1086:   const planFilePaths = new Set(plans.map((plan) => plan.file_path).filter(Boolean));
 1087:   const planTasks = tasks.filter(
 1088:     (task) => planIds.has(task.plan_id) || (!!task.file_path && planFilePaths.has(task.file_path)),
 1089:   );
 1090: 
 1091:   return [...directTasks, ...planTasks.filter((task) => !taskIds.has(task.id))];
 1092: }
