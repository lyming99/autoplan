+      fs.mkdirSync(path.dirname(planFile), { recursive: true });
+      fs.writeFileSync(
+        planFile,
+        ['# 附件计划 smoke', '', '## 任务计划', '- [ ] P001: 使用附件上下文 <!-- scope: unknown -->', ''].join('\n'),
