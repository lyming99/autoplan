 311: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 312:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 313:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 314:     return 'stopping';
 315:   }
 316:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 317:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 318:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 319:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 320:   return 'updated';
 321: }
