 415:   if (readingPlan.id !== latestPlan.id || readingPlan.project_id !== latestPlan.project_id) return false;
 416: 
 417:   const readFilePath = result?.file_path || readingPlan.file_path || '';
 418:   const readHash = result?.hash || readingPlan.hash || '';
 419:   const readUpdatedAt = result?.updated_at || readingPlan.updated_at || '';
 420:   return (
 421:     (latestPlan.file_path || '') !== readFilePath ||
 422:     (latestPlan.hash || '') !== readHash ||
 423:     (latestPlan.updated_at || '') !== readUpdatedAt ||
 424:     (latestPlan.status || '') !== (readingPlan.status || '')
 425:   );
 426: }
 427: 
 428: const PLAN_READER_FOCUSABLE_SELECTOR = [
 429:   'a[href]',
 430:   'button:not([disabled])',
 431:   'input:not([disabled]):not([type="hidden"])',
 432:   'select:not([disabled])',
 433:   'textarea:not([disabled])',
 434:   '[tabindex]:not([tabindex="-1"])',
 435: ].join(',');
 436: 
 437: function getPlanReaderFocusableElements(container: HTMLElement) {
 438:   return Array.from(container.querySelectorAll<HTMLElement>(PLAN_READER_FOCUSABLE_SELECTOR)).filter(
 439:     (element) => element.getClientRects().length > 0 && element.getAttribute('aria-hidden') !== 'true',
 440:   );
 441: }
 442: 
 443: function parallelRunDisabledReason(plan: Plan, hasRunningTask: boolean) {
 444:   if (hasRunningTask) return '该计划已有任务执行中';
 445:   if (plan.validation_passed || plan.status === 'completed') return '计划已完成';
 446:   if (!plan.concurrency_suggestion?.hasSafeParallelBatches) return '暂无安全可并发批次';
 447:   return '';
 448: }
 449: 
 450: function scopeFileLabel(file: PlanTask['scope_files'][number]) {
 451:   if (file.isUnknown) return 'unknown';
 452:   if (file.isValidation) return 'validation';
 453:   return file.path;
 454: }
 455: 
 456: function scopeFileStatus(file: PlanTask['scope_files'][number]) {
 457:   if (file.isUnknown) return '无法判断影响范围';
 458:   if (file.isValidation) return '完整验收任务';
 459:   if (file.canOpen) return '可打开';
 460:   return file.reason || (file.exists ? '不可打开' : '文件不存在');
 461: }
