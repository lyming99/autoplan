 381:   if (value === null || value === undefined || depth > 6) return '';
 382:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 383:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 384:   if (typeof value === 'object') {
 385:     return Object.values(value as Record<string, unknown>)
 386:       .map((item) => toSearchText(item, depth + 1))
 387:       .join(' ');
 388:   }
 389:   return '';
