+  assert.equal(emptyValidationPlan.validation_passed, 1, '空验收命令应标记 validation_passed');
+  const emptyValidationEvent = db.get(
+    `SELECT * FROM events
+     WHERE project_id = ? AND type = 'plan.completed'
