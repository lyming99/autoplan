+
+  const spawned = [];
+  const codexSessionId = 'cccccccc-cccc-4ccc-8ccc-cccccccccccc';
+  const { LoopService: PatchedLoopService } = loadPatchedLoopService({
+    spawnOverride: (command, args) => {
+      const entry = { command, args, prompt: '' };
+      spawned.push(entry);
