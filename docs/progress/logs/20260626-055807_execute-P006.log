+    body: requirementBody,
+    agentCliProvider: 'codex',
+    agentCliCommand: '',
+    codexReasoningEffort: 'high',
+  });
+  const requirement = db.get('SELECT * FROM requirements WHERE project_id = ? AND body = ?', [
