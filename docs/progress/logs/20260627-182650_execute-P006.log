 948: function resolveRendererModule(fromDir, request, rendererRoot) {
 949:   const basePath = path.resolve(fromDir, request);
 950:   const candidates = [
 951:     basePath,
 952:     `${basePath}.ts`,
 953:     `${basePath}.tsx`,
 954:     `${basePath}.js`,
 955:     `${basePath}.jsx`,
 956:     path.join(basePath, 'index.ts'),
 957:     path.join(basePath, 'index.tsx'),
 958:     path.join(basePath, 'index.js'),
