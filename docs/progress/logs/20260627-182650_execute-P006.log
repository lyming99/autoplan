 519: async function assertPlanReadRegression(
 520:   db,
 521:   loop,
 522:   { projectId, otherProjectId, otherWorkspace, planId, plan, planFile, originalPlanText },
 523: ) {
 524:   const readPlan = loadMainPlanReadHandler(db, loop);
 525: 
 526:   const existingRead = await readPlan(null, { projectId, planId });
 527:   assert.equal(existingRead.ok, true, '读取存在的 Plan 文件应成功');
 528:   assert.equal(existingRead.id, planId, '读取存在的 Plan 应返回 plan id');
 529:   assert.equal(existingRead.project_id, projectId, '读取存在的 Plan 应返回项目 id');
 530:   assert.equal(existingRead.file_path, plan.file_path, '读取存在的 Plan 应返回相对路径');
 531:   assert.equal(existingRead.markdown, originalPlanText, '读取存在的 Plan 应返回完整 Markdown');
 532:   assert.equal(existingRead.error, null, '读取存在的 Plan 不应返回错误');
 533:   assert.equal(existingRead.task_total, 6, '读取 Plan 应返回已同步任务总数');
 534:   assert.equal(existingRead.task_completed, 0, '读取 Plan 应返回已完成任务数');
