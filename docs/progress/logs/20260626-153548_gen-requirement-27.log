#!/usr/bin/env python3
"""Create and push a release tag for the GitHub Actions release workflow."""

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


TAG_PREFIX = "v"


class ReleaseError(RuntimeError):
    """A user-facing release preflight error."""


def run_git(args: list[str], *, capture: bool = True) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            ["git", *args],
            check=False,
            capture_output=capture,
            text=True,
            encoding="utf-8",
        )
    except FileNotFoundError as exc:
        raise ReleaseError("鏈壘鍒?Git锛岃鍏堝畨瑁?Git 骞剁‘璁?git 鍛戒护宸插姞鍏?PATH銆?) from exc


def require_success(result: subprocess.CompletedProcess[str], message: str) -> None:
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        if detail:
            raise ReleaseError(f"{message}\n{detail}")
        raise ReleaseError(message)


def ensure_git_available() -> None:
    if shutil.which("git") is None:
        raise ReleaseError("鏈壘鍒?Git锛岃鍏堝畨瑁?Git 骞剁‘璁?git 鍛戒护宸插姞鍏?PATH銆?)


def ensure_gh_hint() -> None:
    if shutil.which("gh") is None:
        print(
            "鎻愮ず锛氭湭妫€娴嬪埌 GitHub CLI锛坓h锛夈€倀ag 鎺ㄩ€佷粛鍙Е鍙?Actions锛涘闇€鏈湴纭鐧诲綍鐘舵€侊紝璇峰畨瑁呭苟杩愯 gh auth login銆?,
            file=sys.stderr,
        )


def validate_tag(tag: str) -> None:
    if not tag.startswith(TAG_PREFIX) or len(tag) == 1:
        raise ReleaseError("tag 蹇呴』浠?v 寮€澶达紝渚嬪 v0.2.0銆?)
    if any(char.isspace() for char in tag):
        raise ReleaseError("tag 涓嶈兘鍖呭惈绌虹櫧瀛楃銆?)
    invalid_chars = set("~^:?*[\\")
    if any(char in invalid_chars for char in tag) or ".." in tag or tag.endswith("."):
        raise ReleaseError("tag 鍖呭惈 Git 涓嶆敮鎸佺殑瀛楃锛岃浣跨敤绫讳技 v0.2.0 鐨勬牸寮忋€?)
    result = run_git(["check-ref-format", f"refs/tags/{tag}"])
    require_success(result, "tag 鏍煎紡涓嶇鍚?Git ref 瑙勮寖銆?)


def ensure_repository() -> None:
    result = run_git(["rev-parse", "--is-inside-work-tree"])
    require_success(result, "褰撳墠鐩綍涓嶆槸 Git 浠撳簱锛岃鍦ㄩ」鐩牴鐩綍杩愯銆?)
    if result.stdout.strip() != "true":
        raise ReleaseError("褰撳墠鐩綍涓嶆槸 Git 宸ヤ綔鍖猴紝璇峰湪椤圭洰鏍圭洰褰曡繍琛屻€?)


def ensure_clean_worktree() -> None:
    result = run_git(["status", "--porcelain"])
    require_success(result, "鏃犳硶璇诲彇 Git 宸ヤ綔鍖虹姸鎬併€?)
    if result.stdout.strip():
        raise ReleaseError("宸ヤ綔鍖哄瓨鍦ㄦ湭鎻愪氦鎴栨湭璺熻釜鏂囦欢锛岃鍏堟彁浜ゃ€佹殏瀛樻垨娓呯悊鍚庡啀鍙戝竷銆?)


def ensure_remote(remote: str) -> None:
    result = run_git(["remote", "get-url", remote])
    require_success(result, f"鏈壘鍒拌繙绔?{remote}锛岃鍏堥厤缃?Git 杩滅銆?)


def ensure_tag_absent(tag: str, remote: str) -> None:
    local = run_git(["rev-parse", "--verify", f"refs/tags/{tag}"])
    if local.returncode == 0:
        raise ReleaseError(f"鏈湴 tag 宸插瓨鍦細{tag}銆?)

    remote_result = run_git(["ls-remote", "--tags", remote, tag])
