const CODEX_SESSION_ID_RES = Object.freeze([
  new RegExp("'`'"\\\\bsession\\\\s+id:\\\\s*("'${CODEX_SESSION_UUID_RE_SOURCE})'"\\\\b"'`, '"'i'),
