  90: 
  91: function readTaskTime(value: string | null | undefined) {
  92:   const time = Date.parse(String(value || ''));
  93:   return Number.isFinite(time) ? time : null;
  94: }
  95: 
  96: function taskSortTime(task: TimedPlanTask) {
  97:   return readTaskTime(task.finished_at) ?? readTaskTime(task.started_at) ?? readTaskTime(task.updated_at);
  98: }
  99: 
 100: function latestTaskTime(tasks: TimedPlanTask[]) {
 101:   const fieldGroups: Array<Array<keyof TimedPlanTask>> = [['finished_at'], ['started_at'], ['updated_at']];
 102:   for (const fields of fieldGroups) {
 103:     const times = tasks.flatMap((task) => fields.map((field) => readTaskTime(task[field] as string | null | undefined)));
 104:     const validTimes = times.filter((time): time is number => time !== null);
 105:     if (validTimes.length) return Math.max(...validTimes);
 106:   }
 107:   return null;
 108: }
 109: 
 110: function taskPlanGroupTitle(task: PlanTask) {
 111:   return String(task.plan_title || task.file_path || '未命名计划').trim() || '未命名计划';
 112: }
 113: 
 114: function taskPlanGroupKey(task: TimedPlanTask, index: number) {
 115:   const planId = readPlanId(task);
 116:   if (planId !== null) return `plan:${planId}`;
 117:   if (task.file_path) return `file:${task.file_path}`;
 118:   return `unknown:${index}`;
 119: }
 120: 
 121: function groupTasksByPlan(tasks: PlanTask[]) {
 122:   const groups = new Map<string, TaskPlanGroup>();
 123:   tasks.forEach((task, index) => {
 124:     const timedTask = task as TimedPlanTask;
 125:     const key = taskPlanGroupKey(timedTask, index);
 126:     const existingGroup = groups.get(key);
 127:     if (existingGroup) {
 128:       existingGroup.tasks.push(task);
 129:       if (existingGroup.title === '未命名计划') existingGroup.title = taskPlanGroupTitle(task);
 130:       return;
 131:     }
 132: 
 133:     groups.set(key, {
 134:       key,
 135:       title: taskPlanGroupTitle(task),
 136:       tasks: [task],
 137:       firstIndex: index,
 138:       sortTime: null,
 139:     });
 140:   });
 141: 
 142:   return Array.from(groups.values())
 143:     .map((group) => {
 144:       const indexedTasks = group.tasks.map((task, index) => ({ task, index }));
 145:       const sortedTasks = indexedTasks
 146:         .sort((left, right) => {
 147:           const leftTime = taskSortTime(left.task as TimedPlanTask);
 148:           const rightTime = taskSortTime(right.task as TimedPlanTask);
 149:           if (leftTime !== null && rightTime !== null && leftTime !== rightTime) return rightTime - leftTime;
 150:           if (leftTime !== null && rightTime === null) return -1;
 151:           if (leftTime === null && rightTime !== null) return 1;
 152:           return left.index - right.index;
 153:         })
 154:         .map(({ task }) => task);
 155:       return {
 156:         ...group,
 157:         tasks: sortedTasks,
 158:         sortTime: latestTaskTime(group.tasks as TimedPlanTask[]),
 159:       };
 160:     })
 161:     .sort((left, right) => {
 162:       if (left.sortTime !== null && right.sortTime !== null && left.sortTime !== right.sortTime) {
 163:         return right.sortTime - left.sortTime;
 164:       }
 165:       if (left.sortTime !== null && right.sortTime === null) return -1;
 166:       if (left.sortTime === null && right.sortTime !== null) return 1;
 167:       return left.firstIndex - right.firstIndex;
 168:     });
 169: }
