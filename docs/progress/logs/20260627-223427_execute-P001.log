 485:                 <small>{disabledReason || '可调整'}</small>
 486:                 <button
 487:                   type="button"
 488:                   className={`btn-link plan-select-button${selected ? ' active' : ''}`}
 489:                   aria-pressed={selected}
 490:                   data-testid="plan-select-toggle"
 491:                   onClick={() => selectPlan(plan)}
 492:                 >
 493:                   {selected ? '取消选择' : '查看任务'}
 494:                 </button>
 495:                 <button
 496:                   type="button"
 497:                   className="btn-link"
 498:                   disabled={reordering || Boolean(disabledReason) || !previousPlan || !canReorderPlan(previousPlan)}
 499:                   onClick={() => movePlan(plan, -1)}
 500:                 >
 501:                   上移
 502:                 </button>
 503:                 <button
 504:                   type="button"
 505:                   className="btn-link"
 506:                   disabled={reordering || Boolean(disabledReason) || !nextPlan || !canReorderPlan(nextPlan)}
 507:                   onClick={() => movePlan(plan, 1)}
 508:                 >
 509:                   下移
 510:                 </button>
 511:                 {isDraftPlan(plan) ? (
 512:                   <button
 513:                     type="button"
 514:                     className="btn-link"
 515:                     disabled={draftRunningPlanId === plan.id || Boolean(draftRunDisabledReason)}
 516:                     title={draftRunDisabledReason || undefined}
 517:                     onClick={() => runDraftPlan(plan)}
 518:                   >
 519:                     {draftRunningPlanId === plan.id ? '启动中…' : '执行草稿'}
 520:                   </button>
 521:                 ) : null}
 522:               </div>
 523:             );
 524:           })}
 525:         </div>
 526:       ) : null}
 527: 
 528:       <BasePlanList
 529:         {...props}
 530:         onRunParallel={onRunParallel}
 531:         emptyText={activeStatus === 'all' ? emptyText : '当前分类暂无 Plan。'}
 532:         plans={visiblePlans}
 533:         totalPlanCount={props.totalPlanCount ?? plans.length}
 534:       />
 535:     </>
 536:   );
 537: }
 538: 
 539: function comparePlanOrder(left: Plan, right: Plan) {
 540:   return (
--- src/renderer/components/PlanLists.tsx 540-620
 540:   return (
 541:     Number(left.sort_order || 0) - Number(right.sort_order || 0) ||
 542:     String(left.created_at || '').localeCompare(String(right.created_at || '')) ||
 543:     Number(left.id || 0) - Number(right.id || 0)
 544:   );
 545: }
 546: 
 547: function planStatusCounts(plans: Plan[]): Record<PlanStatusTab, number> {
 548:   return plans.reduce(
 549:     (counts, plan) => {
 550:       counts.all += 1;
 551:       if (isDraftPlan(plan)) counts.draft += 1;
 552:       else if (isCompletedPlan(plan)) counts.completed += 1;
 553:       else counts.running += 1;
 554:       return counts;
 555:     },
 556:     { all: 0, running: 0, completed: 0, draft: 0 },
 557:   );
 558: }
 559: 
 560: function planMatchesStatusTab(plan: Plan, status: PlanStatusTab) {
 561:   if (status === 'all') return true;
 562:   if (status === 'draft') return isDraftPlan(plan);
 563:   if (status === 'completed') return isCompletedPlan(plan);
 564:   return !isDraftPlan(plan) && !isCompletedPlan(plan);
 565: }
 566: 
 567: function isDraftPlan(plan: Plan) {
 568:   return plan.is_draft || plan.status === 'draft';
 569: }
 570: 
 571: function isCompletedPlan(plan: Plan) {
 572:   return Boolean(plan.validation_passed) || plan.status === 'completed';
 573: }
 574: 
 575: function canReorderPlan(plan: Plan) {
 576:   return !['running', 'completed'].includes(String(plan.status || '')) && !plan.validation_passed;
 577: }
 578: 
 579: function reorderDisabledReason(plan: Plan) {
 580:   if (plan.status === 'running') return '执行中不可移动';
 581:   if (isCompletedPlan(plan)) return '已完成不可移动';
 582:   return '';
 583: }
 584: 
 585: function draftPlanRunDisabledReason(plan: Plan, tasks: PlanTask[]) {
 586:   if (!isDraftPlan(plan)) return '';
 587:   if (plan.concurrency_suggestion?.hasSafeParallelBatches) return '';
 588:   return firstPendingTaskForPlan(plan, tasks) ? '' : '草稿计划暂无可执行任务';
 589: }
 590: 
 591: function firstPendingTaskForPlan(plan: Plan, tasks: PlanTask[]) {
 592:   return tasks
 593:     .filter((task) => Number(task.plan_id) === Number(plan.id) && task.status === 'pending')
 594:     .sort((left, right) => Number(left.sort_order || 0) - Number(right.sort_order || 0) || Number(left.id || 0) - Number(right.id || 0))[0] || null;
 595: }
