 387:   async function movePlan(plan: Plan, direction: -1 | 1) {
 388:     if (!onReorderPlans || reordering) return;
 389:     const fromIndex = orderedPlans.findIndex((item) => item.id === plan.id);
 390:     const toIndex = fromIndex + direction;
 391:     const target = orderedPlans[toIndex];
 392:     if (fromIndex < 0 || !target || !canReorderPlan(plan) || !canReorderPlan(target)) return;
 393: 
 394:     const nextPlans = [...orderedPlans];
 395:     nextPlans[fromIndex] = target;
 396:     nextPlans[toIndex] = plan;
 397:     setReordering(true);
 398:     try {
 399:       await onReorderPlans(nextPlans);
 400:     } finally {
 401:       setReordering(false);
 402:     }
 403:   }
