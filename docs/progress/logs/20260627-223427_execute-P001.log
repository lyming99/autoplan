  96: .stat-info::after { background: var(--info-bg); }
  97: .stat-success::after { background: var(--success-bg); }
  98: .stat-warning::after { background: var(--warning-bg); }
  99: .stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; line-height: 0; }
 100: .stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }

