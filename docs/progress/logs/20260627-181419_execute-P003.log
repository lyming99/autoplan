 364: function createRankedWorkspaceSearchResult(
 365:   candidate: WorkspaceSearchCandidate,
 366:   query: WorkspaceSearchQuery,
 367: ): RankedWorkspaceSearchResult | null {
 368:   const searchableText = candidate.fields.map((field) => field.value.toLowerCase()).join(' ');
 369:   if (!doesTextMatchQuery(searchableText, query)) {
 370:     return null;
 371:   }
 372: 
 373:   const matches = candidate.fields
 374:     .filter((field) => doesFieldMatchQuery(field, query))
 375:     .map((field): WorkspaceSearchMatch => ({
 376:       field: field.field,
 377:       label: field.label,
 378:       value: field.value,
 379:       snippet: createSearchSnippet(field.value, query),
 380:     }));
 381:   if (matches.length === 0) {
 382:     return null;
 383:   }
 384: 
 385:   const priority = matches.reduce(
 386:     (best, match) => Math.min(best, getSearchFieldPriority(match.field)),
 387:     FALLBACK_SEARCH_PRIORITY,
 388:   );
 389:   const updatedAtMs = getTimestampMs(candidate.updatedAt);
 390: 
 391:   return {
 392:     priority,
 393:     updatedAtMs,
 394:     result: {
 395:       id: `${candidate.source}:${candidate.recordId}`,
 396:       source: candidate.source,
 397:       targetTab: candidate.location.targetTab,
 398:       location: candidate.location,
 399:       recordId: candidate.recordId,
 400:       title: candidate.title,
 401:       summary: candidate.summary,
 402:       status: candidate.status,
 403:       updatedAt: candidate.updatedAt,
 404:       matches,
 405:     },
 406:   };
 407: }
