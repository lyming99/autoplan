src\styles.css:283:.projects-main { height: calc(100vh - 77px); overflow: auto; padding: 28px 32px 48px; }
src\styles.css:284:.projects-hero { display: flex; align-items: flex-end; gap: 20px; flex-wrap: wrap; margin-bottom: 22px; }
src\styles.css:285:.projects-hero h2 { font-size: 24px; font-weight: 800; }
src\styles.css:286:.projects-hero p { font-size: 13px; color: var(--text-3); margin-top: 6px; }
src\styles.css:291:.projects-toolbar { margin-bottom: 20px; }
src\styles.css:294:.project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
src\styles.css:295:.project-card { position: relative; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
src\styles.css:296:.project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
src\styles.css:297:.project-card-top { display: flex; align-items: flex-start; gap: 12px; }
src\styles.css:298:.project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
src\styles.css:299:.project-info { min-width: 0; flex: 1 1 auto; }
src\styles.css:300:.project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
src\styles.css:301:.project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
src\styles.css:302:.project-card-menu { flex: 0 0 auto; }
src\styles.css:314:.project-desc { font-size: 12.5px; color: var(--text-2); line-height: 1.55; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
src\styles.css:315:.project-loop-status { display: flex; align-items: center; gap: 8px; margin-top: 12px; color: var(--text-2); font-size: 12px; font-weight: 600; }
src\styles.css:316:.project-loop-status .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
src\styles.css:317:.project-loop-status .led.stopped { box-shadow: 0 0 0 3px var(--line); }
src\styles.css:318:.project-loop-interval { margin-left: auto; color: var(--text-3); font-family: var(--font-mono); font-weight: 500; }
src\styles.css:319:.project-cli-badge { padding: 1px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 600; }
src\styles.css:321:.project-meta { font-size: 11px; color: var(--text-4); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line-soft); }
src\styles.css:331:.project-switcher { margin: 0 4px 10px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); }
src\styles.css:332:.project-label { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; color: var(--text-4); margin-bottom: 8px; }
src\styles.css:333:.project-select { width: 100%; padding: 8px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); font: inherit; font-size: 13px; font-weight: 600; color: var(--text-1); }
