def get_method(name):
    match = re.search(rf'"'^  (?:async )?{re.escape(name)}'"\\(["'^'"\\n]*\\) \\{{', source, re.M)
    if not match:
        raise RuntimeError(f'method not found: {name}')
    i = match.start()
    brace = 0
    in_string = None
    escape = False
    for pos in range(match.start(), len(source)):
        ch = source[pos]
        if in_string:
            if escape:
                escape = False
                continue
            if ch == '\\\\':
                escape = True
                continue
            if ch == in_string:
                in_string = None
            continue
        if ch in ('\"', \"'\", '"'`'"'):
            in_string = ch
            continue
        if ch == '{':
            brace += 1
        elif ch == '}':
            brace -= 1
            if brace == 0:
                return source[i:pos + 1]
    raise RuntimeError(f'end not found: {name}')

