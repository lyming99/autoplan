    this.ensureColumn('events', 'project_id', 'INTEGER');
    this.ensureColumn('project_states', 'agent_cli_provider', "TEXT NOT NULL DEFAULT 'codex'");
    this.ensureColumn('project_states', 'agent_cli_command', "TEXT NOT NULL DEFAULT ''");

