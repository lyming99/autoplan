   85:   if (!plans.length) return directTasks;
   86: 
   87:   const taskIds = new Set(directTasks.map((task) => task.id));
   88:   const planIds = new Set(plans.map((plan) => plan.id));
   89:   const planFilePaths = new Set(plans.map((plan) => readPlanTaskAssociationFilePath(plan)).filter(Boolean));
   90:   const planTasks = tasks.filter((task) => {
   91:     const planId = readPlanTaskAssociationPlanId(task);
   92:     if (planId !== null) return planIds.has(planId);
   93:     const filePath = readPlanTaskAssociationFilePath(task);
   94:     return Boolean(filePath && planFilePaths.has(filePath));
   95:   });
   96: 
   97:   return [...directTasks, ...planTasks.filter((task) => !taskIds.has(task.id))];
   98: }
