   66: 
   67: export function filterItemsBySearchGroup<T extends { id: number }>(
   68:   items: T[],
   69:   groups: WorkspaceSearchGroup[],
   70:   source: WorkspaceSearchSourceType,
   71: ) {
   72:   const group = groups.find((item) => item.source === source);
   73:   if (!group?.results.length) return [];
   74: 
   75:   const recordIds = new Set(group.results.map((result) => result.recordId));
   76:   return items.filter((item) => recordIds.has(item.id));
   77: }
