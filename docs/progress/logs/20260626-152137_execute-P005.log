 373: async function assertFinalAcceptanceTaskSmoke(db, loop, workspace, projectId) {
 374:   const planRel = path.join('docs', 'plan', 'final-acceptance-smoke.md');
 375:   const planFile = path.join(workspace, planRel);
 376:   fs.mkdirSync(path.dirname(planFile), { recursive: true });
 377:   fs.writeFileSync(
 378:     planFile,
 379:     [
 380:       '# Final acceptance smoke',
 381:       '',
 382:       '## 任务计划',
 383:       '- [x] P001: 完成开发修改 <!-- scope: smoke/dev.js -->',
 384:       '- [ ] P002: 完整验收 <!-- scope: validation -->',
 385:       '',
 386:       '## 总体验收标准',
 387:       '- 最后节点执行完整验收命令。',
 388:       '',
 389:     ].join('\n'),
 390:     'utf8',
 391:   );
 392:   const planId = insertPlan(db, projectId, planRel, 'final-acceptance-smoke');
 393:   loop.syncPlanTasks(planId, planFile);
 394:   const acceptanceTask = db.get('SELECT * FROM plan_tasks WHERE plan_id = ? AND task_key = ?', [planId, 'P002']);
 395:   assert.equal(acceptanceTask.scope, 'validation', 'final acceptance task should use validation scope');
 396: 
 397:   const originalRunCodex = loop.runCodex.bind(loop);
 398:   let codexCalled = false;
 399:   try {
 400:     loop.runCodex = async () => {
 401:       codexCalled = true;
 402:       return { exitCode: 1, output: 'unexpected codex execution' };
 403:     };
 404:     await loop.processPlan(workspace, db.get('SELECT * FROM plans WHERE id = ?', [planId]));
 405:   } finally {
 406:     loop.runCodex = originalRunCodex;
 407:   }
 408: 
 409:   assert.equal(codexCalled, false, 'final acceptance task should run validation directly instead of Codex');
 410:   const acceptedPlan = db.get('SELECT * FROM plans WHERE id = ?', [planId]);
 411:   const acceptedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [acceptanceTask.id]);
 412:   assert.equal(acceptedPlan.status, 'completed', 'final acceptance task should complete the plan');
 413:   assert.equal(acceptedPlan.validation_passed, 1, 'final acceptance task should mark validation_passed');
 414:   assert.equal(acceptedTask.status, 'completed', 'final acceptance task should be completed');
 415:   assert.match(fs.readFileSync(planFile, 'utf8'), /- \[x\] P002: 完整验收/, 'final acceptance checkbox should be checked');
 416:   const acceptanceEvents = taskEventsByKey(loop.snapshot(projectId), 'P002');
 417:   assertTaskEventOrder(acceptanceEvents, ['task.succeeded', 'task.started'], 'final acceptance task events');
 418:   assert.equal(acceptanceEvents[0].meta.acceptanceTask, true, 'final acceptance success event should be marked');
 419: }
