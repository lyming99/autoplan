+    agentCliProvider: 'codex',
+    agentCliCommand: '',
+    codexReasoningEffort: 'high',
+  }, context), 'MCP create_project');
+  const mcpProjectId = mcpProjectResult.projectId;
+  assert.ok(mcpProjectId, 'MCP create_project 应返回 projectId');
