+    : normalizeOptionalAgentCliProvider(readFirstOwnValue(current, AGENT_CLI_PROVIDER_COLUMNS));
+  const command = hasAnyOwnProperty(input, AGENT_CLI_COMMAND_INPUT_KEYS)
