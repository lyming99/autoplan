+          ? readFirstOwnValue(input, CODEX_REASONING_EFFORT_COLUMNS)
+          : readFirstOwnValue(current, CODEX_REASONING_EFFORT_COLUMNS),
+      )
+    : null;
+  return { provider, command, codexReasoningEffort };
+}
+
