const assert = require('node:assert/strict');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { AppDatabase, nowIso } = require('./src/database');
const { LoopService, nextIntakeAgentCliConfig } = require('./src/loopService');

(async () => {
  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan-p002-'));
  const db = new AppDatabase(path.join(tempRoot, 'autoplan.sqlite'));
  await db.init();
  const loop = new LoopService(db);
  const projectId = loop.defaultProjectId();

  for (const table of ['requirements', 'feedback']) {
    const columns = new Set(db.all("'`PRAGMA table_info(${table})`).map((column) => column.name));
    assert.equal(columns.has('"'agent_cli_provider'), true, "'`${table} should have provider column`);
    assert.equal(columns.has('"'agent_cli_command'), true, "'`${table} should have command column`);
    assert.equal(columns.has('"'codex_reasoning_effort'), true, "'`${table} should have reasoning effort column`);
  }

  assert.deepEqual(nextIntakeAgentCliConfig({}, {}), {
    provider: null,
    command: '"'',
    codexReasoningEffort: null,
  });
  assert.deepEqual(nextIntakeAgentCliConfig({}, {
    agentCliProvider: 'bad-provider',
    agentCliCommand: '  ',
    codexReasoningEffort: 'invalid',
  }), {
    provider: 'codex',
    command: '',
    codexReasoningEffort: 'medium',
  });
  assert.deepEqual(nextIntakeAgentCliConfig({}, {
    agent_cli_provider: 'claude',
    agent_cli_command: ' claude-custom ',
    codex_reasoning_effort: 'high',
  }), {
    provider: 'claude',
    command: 'claude-custom',
    codexReasoningEffort: null,
  });

  const now = nowIso();
  db.insert(
    "'`INSERT INTO requirements (project_id, title, body, status, agent_cli_provider, agent_cli_command, codex_reasoning_effort, created_at, updated_at)
     VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,
    [projectId, '"'r', 'body', 'open', 'bad-provider', '  ', 'invalid', now, now],
  );
  db.insert(
    "'`INSERT INTO feedback (project_id, title, body, status, agent_cli_provider, agent_cli_command, codex_reasoning_effort, created_at, updated_at)
     VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,
    [projectId, '"'f', 'body', 'open', 'claude', ' claude-custom ', 'high', now, now],
  );

  const snapshot = loop.snapshot(projectId);
  assert.equal(snapshot.requirements[0].agent_cli_provider, 'codex');
  assert.equal(snapshot.requirements[0].agent_cli_command, '');
  assert.equal(snapshot.requirements[0].codex_reasoning_effort, 'medium');
  assert.equal(snapshot.feedback[0].agent_cli_provider, 'claude');
  assert.equal(snapshot.feedback[0].agent_cli_command, 'claude-custom');
  assert.equal(snapshot.feedback[0].codex_reasoning_effort, null);

  db.close();
  fs.rmSync(tempRoot, { recursive: true, force: true });
})();
