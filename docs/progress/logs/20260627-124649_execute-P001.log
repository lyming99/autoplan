+       VALUES (?, ?, ?, ?, ?)`,
+      [name, input.workspacePath || '', input.description || '', now, now],
+    );
+    this.loop.ensureProjectState(id);
+    if (this.loop.hasRuntimeConfigInput(input)) {
+      this.loop.configure(id, input);
