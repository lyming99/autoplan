  376:   candidate: WorkspaceSearchCandidate,
  377:   query: WorkspaceSearchQuery,
  378: ): RankedWorkspaceSearchResult | null {
  379:   const searchableText = candidate.fields.map((field) => field.value.toLowerCase()).join(' ');
  380:   if (!doesTextMatchQuery(searchableText, query)) {
  381:     return null;
  382:   }
  383: 
  384:   const matches = candidate.fields
  385:     .filter((field) => doesFieldMatchQuery(field, query))
  386:     .map((field): WorkspaceSearchMatch => ({
  387:       field: field.field,
  388:       label: field.label,
  389:       value: field.value,
  390:       snippet: createSearchSnippet(field.value, query),
