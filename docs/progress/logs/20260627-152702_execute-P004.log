 197:     return current.dataUrl === next.dataUrl && current.size === next.size;
 198:   }
 199:   return current.id === next.id;
 200: }
 201: 
 202: function resolveWorkspaceTab(tab: string | null): WorkspaceTab {
 203:   return tabs.some((item) => item.id === tab) ? (tab as WorkspaceTab) : DEFAULT_WORKSPACE_TAB;
 204: }
 205: 
 206: function normalizeCodexReasoningEffort(value?: string | null): CodexReasoningEffort {
 207:   const effort = String(value || '').trim().toLowerCase();
 208:   if (effort === 'low' || effort === 'high' || effort === 'xhigh') return effort;
 209:   return defaultCodexReasoningEffort;
 210: }
 211: 
 212: function loopFormFromProjectState(state: ProjectState): LoopFormState {
 213:   return {
 214:     workspacePath: state.workspace_path || '',
 215:     intervalSeconds: String(state.interval_seconds || 5),
 216:     validationCommand: state.validation_command ?? '',
 217:     agentCliProvider: state.agent_cli_provider || 'codex',
 218:     agentCliCommand: state.agent_cli_command || '',
 219:     codexReasoningEffort: normalizeCodexReasoningEffort(state.codex_reasoning_effort),
 220:   };
 221: }
 222: 
 223: function loopConfigurePayloadFromForm(projectId: number, form: LoopFormState): LoopConfigInput {
 224:   const payload: LoopConfigInput = {
 225:     projectId,
 226:     workspacePath: form.workspacePath,
 227:     intervalSeconds: Number(form.intervalSeconds || 5),
 228:     validationCommand: form.validationCommand,
 229:     agentCliProvider: form.agentCliProvider || 'codex',
 230:     agentCliCommand: form.agentCliCommand.trim(),
 231:   };
 232:   if (form.agentCliProvider !== 'claude') {
 233:     payload.codexReasoningEffort = form.codexReasoningEffort;
 234:   }
 235:   return payload;
 236: }
 237: 
 238: function loopFormsEqual(left: LoopFormState, right: LoopFormState) {
 239:   return left.workspacePath === right.workspacePath
 240:     && left.intervalSeconds === right.intervalSeconds
 241:     && left.validationCommand === right.validationCommand
 242:     && left.agentCliProvider === right.agentCliProvider
 243:     && left.agentCliCommand === right.agentCliCommand
 244:     && left.codexReasoningEffort === right.codexReasoningEffort;
 245: }
