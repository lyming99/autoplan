  160:     ? crypto.randomUUID()
  161:     : `${Date.now()}-${index}-${Math.random().toString(36).slice(2)}`;
  162:   return {
  163:     id: `${PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE}:${idSuffix}`,
  164:     source: PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE,
  165:     dataUrl,
