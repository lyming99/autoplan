1038: function createFilteredWorkspaceItems(
1039:   snapshot: AppSnapshot | null | undefined,
1040:   searchState: WorkspaceSearchState,
1041: ): WorkspaceFilterableItems {
1042:   if (!snapshot) {
1043:     return { requirements: [], feedback: [], plans: [], tasks: [], events: [] };
1044:   }
1045:   if (searchState.query.isEmpty) {
1046:     return {
1047:       requirements: snapshot.requirements,
1048:       feedback: snapshot.feedback,
1049:       plans: snapshot.plans,
1050:       tasks: snapshot.tasks,
1051:       events: snapshot.events,
1052:     };
1053:   }
1054: 
1055:   const plans = filterItemsBySearchGroup(snapshot.plans, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.PLAN);
1056:   const tasks = filterTasksBySearchGroups(snapshot.tasks, plans, searchState.groups);
1057: 
1058:   return {
1059:     requirements: filterItemsBySearchGroup(
1060:       snapshot.requirements,
1061:       searchState.groups,
1062:       WORKSPACE_SEARCH_SOURCE_TYPES.REQUIREMENT,
1063:     ),
1064:     feedback: filterItemsBySearchGroup(snapshot.feedback, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.FEEDBACK),
1065:     plans,
1066:     tasks,
1067:     events: filterItemsBySearchGroup(snapshot.events, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.EVENT),
1068:   };
1069: }
