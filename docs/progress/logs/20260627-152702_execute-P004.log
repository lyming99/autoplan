  150: async function createPendingClipboardImageAttachment(file: File, index: number): Promise<PendingAttachment | null> {
  151:   if (!file.type.startsWith('image/')) return null;
  152:   const type = file.type || 'image/png';
  153:   const extension = getImageExtension(type);
