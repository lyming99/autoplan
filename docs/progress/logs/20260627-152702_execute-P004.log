1028: function countSearchableItems(snapshot: AppSnapshot) {
1029:   return (
1030:     snapshot.requirements.length +
1031:     snapshot.feedback.length +
1032:     snapshot.plans.length +
1033:     snapshot.tasks.length +
1034:     snapshot.events.length
1035:   );
1036: }
