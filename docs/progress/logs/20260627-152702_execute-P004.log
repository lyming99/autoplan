1071: function filterItemsBySearchGroup<T extends { id: number }>(
1072:   items: T[],
1073:   groups: WorkspaceSearchGroup[],
1074:   source: WorkspaceSearchSourceType,
1075: ) {
1076:   const group = groups.find((item) => item.source === source);
