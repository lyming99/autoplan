+    if (match.index === undefined) continue;
+    if (match.index > lastIndex) parts.push(text.slice(lastIndex, match.index));
+    const files = String(match[1] || '')
+      .split(scopeSplitPattern)
+      .map((item) => normalizeScopeFilePath(item))
+      .filter(Boolean);
+    parts.push(
