+          return (
+            <button
+              type="button"
+              key={`${match.index}-${filePath}`}
+              className={`markdown-scope-link mono${special ? ' special' : ''}`}
+              disabled={special}
+              title={special ? '该 scope 不是可打开文件' : `打开 ${filePath}`}
