diff --git a/src/styles.css b/src/styles.css
index fc895894b01023bf9af616a9f21c6be03c105dff..5d09921d707eca67d5a82f9ad9679be1a79c45fc
--- a/src/styles.css
+++ b/src/styles.css
@@ -90,6 +90,84 @@
   padding-bottom: 2px;
 }
 
+.plan-selection-bar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+  margin: 10px 0;
+  padding: 9px 12px;
+  border: 1px solid var(--line-soft);
+  border-radius: var(--r-md);
+  background: var(--bg-soft);
+  color: var(--text-2);
+  font-size: 12px;
+}
+
+.plan-selection-bar.is-active {
+  border-color: var(--brand-300);
+  background: var(--brand-50);
+  color: var(--brand-700);
+}
+
+.plan-selection-summary {
+  min-width: 0;
+  overflow: hidden;
+  font-weight: 700;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.plan-selection-clear:disabled {
+  cursor: not-allowed;
+  opacity: 0.55;
+}
+
+.plan-selection-list {
+  margin-bottom: 12px;
+}
+
+.plan-select-row {
+  border: 1px solid transparent;
+  transition: border-color 0.14s ease, background 0.14s ease, box-shadow 0.14s ease;
+}
+
+.plan-select-row.is-selected {
+  border-color: var(--brand-400);
+  background: var(--brand-50);
+  box-shadow: inset 3px 0 0 var(--brand-500);
+}
+
+.plan-select-row-title {
+  min-width: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.plan-selected-badge {
+  display: inline-flex;
+  align-items: center;
+  padding: 2px 7px;
+  border-radius: 999px;
+  background: var(--brand-100);
+  color: var(--brand-700);
+  font-size: 11px;
+  font-weight: 800;
+}
+
+.plan-select-button.active {
+  color: var(--brand-700);
+  font-weight: 800;
+}
+
+.plan-select-button:focus-visible,
+.plan-selection-clear:focus-visible {
+  outline: 2px solid var(--brand-400);
+  outline-offset: 2px;
+  border-radius: 6px;
+}
+
 @media (max-width: 760px) {
   .task-plan-group-meta {
     width: 100%;
