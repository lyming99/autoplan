(async () => {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan cmd test '));
  const fake = path.join(root, 'fake claude.cmd');
  fs.writeFileSync(fake, '@echo off\\r\\necho args:%*\\r\\nset /p PROMPT=\\r\\necho reply:%PROMPT%\\r\\n', 'utf8');
  await new Promise((resolve) => {
