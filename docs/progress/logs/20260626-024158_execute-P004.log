"'$script = @'"'
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { spawn } = require('node:child_process');
(async () => {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan cmd test '));
  const fake = path.join(root, 'fake claude.cmd');
  fs.writeFileSync(fake, '@echo off\\r\\necho args:%*\\r\\nset /p PROMPT=\\r\\necho reply:%PROMPT%\\r\\n', 'utf8');
  for (const argv of [
    ['/d', '/s', '/c', fake, '--print', '--output-format', 'text'],
    ['/d', '/s', '/c', "'`"${fake}"`, '"'--print', '--output-format', 'text'],
  ]) {
    await new Promise((resolve) => {
      const child = spawn(process.env.ComSpec || 'cmd.exe', argv, { cwd: root });
      let out = '';
      let err = '';
      child.stdout.on('data', (chunk) => out += chunk);
      child.stderr.on('data', (chunk) => err += chunk);
      child.on('error', (error) => { console.log('ERROR', argv[3], error.code, error.message); resolve(); });
      child.on('exit', (code) => { console.log('EXIT', code, JSON.stringify(argv), JSON.stringify(out), JSON.stringify(err)); resolve(); });
      child.stdin.end('hello\\n');
    });
  }
  fs.rmSync(root, { recursive: true, force: true });
})();
