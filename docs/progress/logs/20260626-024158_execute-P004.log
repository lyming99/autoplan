**Exploring PowerShell with Node.js**

I’m finding that passing `$script` to Node.js with `node -e` can get a bit tricky because of the quotes. It seems to pass a single argument, but the quotes might create some confusion. Instead of using heredoc, I think it's better to pipe to Node with PowerShell's `@'...'@` syntax, which works well with `| node -`. Okay, that sounds like the right approach!
codex
改用 PowerShell 管道传脚本，避免 `node -e` 引号干扰。
exec
powershell.exe -Command '$ErrorActionPreference='"'Stop';
@'
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { spawn } = require('node:child_process');
function quote(value) { return '\"' + String(value).split('\"').join('\"\"') + '\"'; }
(async () => {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan cmd test '));
  const fake = path.join(root, 'fake claude.cmd');
  fs.writeFileSync(fake, '@echo off\\r\\necho args:%*\\r\\nset /p PROMPT=\\r\\necho reply:%PROMPT%\\r\\n', 'utf8');
  for (const line of [
    "'`${quote(fake)} --print --output-format text`,
    `call ${quote(fake)} --print --output-format text`,
  ]) {
    await new Promise((resolve) => {
      const child = spawn(process.env.ComSpec || '"'cmd.exe', ['/d', '/s', '/c', line], { cwd: root });
      let out = '';
      let err = '';
      child.stdout.on('data', (chunk) => out += chunk);
      child.stderr.on('data', (chunk) => err += chunk);
      child.on('error', (error) => { console.log('ERROR', error.code, error.message); resolve(); });
      child.on('exit', (code) => { console.log('LINE', JSON.stringify(line), 'EXIT', code, JSON.stringify(out), JSON.stringify(err)); resolve(); });
      child.stdin.end('hello\\n');
    });
  }
  fs.rmSync(root, { recursive: true, force: true });
})();
