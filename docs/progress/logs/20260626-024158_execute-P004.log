"'$script = @'"'
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const assert = require('node:assert');
const { runAgentCliAttempt } = require('./src/agentCli');

(async () => {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan-claude-test-'));
  const fake = path.join(dir, process.platform === 'win32' ? 'fake-claude.cmd' : 'fake-claude');
  if (process.platform === 'win32') {
    fs.writeFileSync(fake, '@echo off\\r\\nset /p PROMPT=\\r\\necho reply:%PROMPT%\\r\\necho errlog 1>&2\\r\\n', 'utf8');
  } else {
    fs.writeFileSync(fake, '#"'!/bin/sh'"\\nIFS= read -r PROMPT\\nprintf \"reply:%s\\\\n\" \""'$PROMPT"'"\\nprintf \"errlog\\\\n\" >&2\\n', { encoding: 'utf8', mode: 0o755 });
  }
  const logFile = path.join(dir, 'run.log');
  const lastFile = path.join(dir, 'last.txt');
  const stream = fs.createWriteStream(logFile, { encoding: 'utf8' });
  const runtime = { activeOperations: new Map(), activeChildren: new Map() };
  const activeOperation = {};
  const result = await runAgentCliAttempt({
    workspace: dir,
    prompt: 'hello',
    lastFile,
    logFile,
    runtime,
    activeOperation,
    registerRuntimeOperation: (rt, child, op) => {
      rt.activeOperations.set('op', op);
      rt.activeChildren.set('op', child);
      return 'op';
    },
    waitForChild: (child) => new Promise((resolve) => {
      child.on('exit', (code) => resolve(code ?? 0));
      child.on('error', () => resolve(-1));
    }),
    stream,
    provider: 'claude',
    command: fake,
  });
  stream.end();
  await new Promise((resolve) => stream.on('finish', resolve));
  assert.equal(result.exitCode, 0);
  assert.equal(result.agentCliProvider, 'claude');
  assert.equal(fs.readFileSync(lastFile, 'utf8').trim(), 'reply:hello');
  const log = fs.readFileSync(logFile, 'utf8');
  assert.match(log, /reply:hello/);
  assert.match(log, /errlog/);
  fs.rmSync(dir, { recursive: true, force: true });
})().catch((error) => {
  console.error(error);
  process.exit(1);
});
