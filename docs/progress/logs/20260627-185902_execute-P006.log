  431:   fs.writeFileSync(
  432:     planFile,
  433:     [
  434:       '# Final acceptance smoke',
  435:       '',
  436:       '## 任务计划',
  437:       '- [x] P001: 完成开发修改 <!-- scope: smoke/dev.js -->',
  438:       '- [ ] P002: 完整验收 <!-- scope: validation -->',
  439:       '',
  440:       '## 总体验收标准',
  441:       '- 最后节点执行完整验收命令。',
  442:       '',
  443:     ].join('\n'),
  444:     'utf8',
  445:   );
  446:   const planId = insertPlan(db, projectId, planRel, 'final-acceptance-smoke');
  447:   loop.syncPlanTasks(planId, planFile);
  448:   const acceptanceTask = db.get('SELECT * FROM plan_tasks WHERE plan_id = ? AND task_key = ?', [planId, 'P002']);
  449:   assert.equal(acceptanceTask.scope, 'validation', 'final acceptance task should use validation scope');
  450: 
  451:   const originalRunCodex = loop.runCodex.bind(loop);
  452:   let codexCalled = false;
  453:   try {
  454:     loop.runCodex = async () => {
  455:       codexCalled = true;
  456:       return { exitCode: 1, output: 'unexpected codex execution' };
  457:     };
  458:     await loop.processPlan(workspace, db.get('SELECT * FROM plans WHERE id = ?', [planId]));
  459:   } finally {
  460:     loop.runCodex = originalRunCodex;
  461:   }
  462: 
  463:   assert.equal(codexCalled, false, 'final acceptance task should run validation directly instead of Codex');
  464:   const acceptedPlan = db.get('SELECT * FROM plans WHERE id = ?', [planId]);
  465:   const acceptedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [acceptanceTask.id]);
  466:   assert.equal(acceptedPlan.status, 'completed', 'final acceptance task should complete the plan');
  467:   assert.equal(acceptedPlan.validation_passed, 1, 'final acceptance task should mark validation_passed');
