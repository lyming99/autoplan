  475: function assertSearchHit(searchState, source, field, valuePattern, label) {
  476:   assert.ok(searchState.total > 0, `${label}：应返回搜索结果`);
  477:   const result = searchState.results.find(
  478:     (item) => item.source === source && item.matches.some((match) => match.field === field),
  479:   );
  480:   assert.ok(result, `${label}：应包含 ${source}/${field} 命中`);
  481:   const match = result.matches.find((item) => item.field === field);
  482:   assert.match(match.value, valuePattern, `${label}：命中值应包含关键字`);
  483:   assert.match(match.snippet, valuePattern, `${label}：摘要片段应包含关键字`);
  484:   assert.ok(
  485:     searchState.groups.some((group) => group.source === source && group.count > 0),
  486:     `${label}：来源分组应统计命中数量`,
  487:   );
  488:   return result;
  489: }
