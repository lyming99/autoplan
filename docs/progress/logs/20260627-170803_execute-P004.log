diff --git a/src/renderer/components/PlanLists.tsx b/src/renderer/components/PlanLists.tsx
index 95019bf52eef140423ea5673c9dd3945c5cb84c5..99d4d134dde4cb85eede5538bb0f69c2ebdc786b
