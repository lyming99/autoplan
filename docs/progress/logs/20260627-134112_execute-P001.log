  SCOPE: 'scope',
  RAW_LINE: 'rawLine',
  EVENT_TYPE: 'eventType',
  EVENT_MESSAGE: 'eventMessage',
  EVENT_META: 'eventMeta',
} as const;

export type WorkspaceSearchHitField =
  (typeof WORKSPACE_SEARCH_HIT_FIELDS)[keyof typeof WORKSPACE_SEARCH_HIT_FIELDS];

