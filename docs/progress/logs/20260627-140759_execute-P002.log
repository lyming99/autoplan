+        resolve();
+      });
+    });
+
+    const address = this.httpServer.address();
+    const port = typeof address === 'object' && address ? address.port : this.config.port;
+    this.state = {
+      enabled: true,
+      running: true,
+      transport: 'http',
+      host: this.config.host,
+      port,
+      path: this.config.path,
+      url: `http://${this.config.host}:${port}${this.config.path}`,
