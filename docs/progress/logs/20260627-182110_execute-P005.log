 366: function locateWorkspaceSearchResult(result: WorkspaceSearchResult) {
 367:   const target = getWorkspaceSearchAnchorCandidates(result)
 368:     .map((anchorId) => document.getElementById(anchorId))
 369:     .find((element): element is HTMLElement => element instanceof HTMLElement);
 370: 
 371:   if (!target) return false;
 372: 
 373:   const previousTabIndex = target.getAttribute('tabindex');
 374:   const highlightMs = Math.max(600, Number(result.location.highlightMs) || 2400);
 375:   target.scrollIntoView({ behavior: result.location.scrollBehavior, block: 'center', inline: 'nearest' });
 376:   target.classList.remove('search-locate-highlight');
 377:   void target.offsetWidth;
 378:   target.classList.add('search-locate-highlight');
 379:   target.setAttribute('tabindex', previousTabIndex ?? '-1');
 380:   target.focus({ preventScroll: true });
 381: 
 382:   window.setTimeout(() => {
 383:     target.classList.remove('search-locate-highlight');
 384:     if (previousTabIndex === null) target.removeAttribute('tabindex');
 385:   }, highlightMs);
 386: 
 387:   return true;
 388: }
 389: 
 390: function getWorkspaceSearchAnchorCandidates(result: WorkspaceSearchResult) {
 391:   const candidates = [
 392:     result.anchorId,
 393:     result.location.anchorId,
 394:     `workspace-${result.targetType}-${result.targetId}`,
 135:   box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18), var(--shadow-sm);
