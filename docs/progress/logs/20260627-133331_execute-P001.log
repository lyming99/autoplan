 347: function createRankedWorkspaceSearchResult(
 348:   candidate: WorkspaceSearchCandidate,
 349:   query: WorkspaceSearchQuery,
 350: ): RankedWorkspaceSearchResult | null {
 351:   const searchableText = candidate.fields.map((field) => field.value.toLowerCase()).join(' ');
 352:   if (!doesTextMatchQuery(searchableText, query)) {
 353:     return null;
 354:   }
 355: 
 356:   const matches = candidate.fields
 357:     .filter((field) => doesFieldMatchQuery(field, query))
 358:     .map((field): WorkspaceSearchMatch => ({
 359:       field: field.field,
 360:       label: field.label,
 361:       value: field.value,
 362:       snippet: createSearchSnippet(field.value, query),
 363:     }));
 364:   if (matches.length === 0) {
 365:     return null;
 366:   }
 367: 
 368:   const priority = matches.reduce(
 369:     (best, match) => Math.min(best, getSearchFieldPriority(match.field)),
 370:     FALLBACK_SEARCH_PRIORITY,
 371:   );
 372:   const updatedAtMs = getTimestampMs(candidate.updatedAt);
 373: 
 374:   return {
 375:     priority,
 376:     updatedAtMs,
 377:     result: {
 378:       id: `${candidate.source}:${candidate.recordId}`,
 379:       source: candidate.source,
 380:       targetTab: getWorkspaceSearchTargetTab(candidate.source),
 381:       recordId: candidate.recordId,
 382:       title: candidate.title,
 383:       summary: candidate.summary,
 384:       status: candidate.status,
 385:       updatedAt: candidate.updatedAt,
 386:       matches,
 387:     },
 388:   };
 389: }
