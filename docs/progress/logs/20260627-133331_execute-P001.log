 110: function createPendingPathAttachment(file: File): PendingAttachment | null {
 111:   const path = getFilePath(file);
 112:   if (!path) return null;
 113:   const name = file.name || path.split(/[\\/]/).pop() || '附件';
 114:   const type = file.type || 'application/octet-stream';
 115:   return {
 116:     id: `${PENDING_ATTACHMENT_SOURCES.PATH}:${path}:${file.size}`,
 117:     source: PENDING_ATTACHMENT_SOURCES.PATH,
 118:     path,
 119:     name,
 120:     size: file.size,
 121:     type,
 122:     previewUrl: toSafeFileUrl(path),
 123:   };
 124: }
 125: 
 126: function getImageExtension(type: string) {
 127:   if (type === 'image/jpeg') return 'jpg';
 128:   const subtype = type.startsWith('image/') ? type.slice('image/'.length) : 'png';
 129:   return subtype.replace(/[^a-z0-9]+/gi, '').toLowerCase() || 'png';
 130: }
 131: 
 132: function readFileAsDataUrl(file: File) {
 133:   return new Promise<string>((resolve, reject) => {
 134:     const reader = new FileReader();
 135:     reader.onload = () => resolve(String(reader.result || ''));
 136:     reader.onerror = () => reject(reader.error || new Error('读取剪贴板图片失败'));
 137:     reader.readAsDataURL(file);
 138:   });
 139: }
 140: 
 141: async function createPendingClipboardImageAttachment(file: File, index: number): Promise<PendingAttachment | null> {
 142:   if (!file.type.startsWith('image/')) return null;
 143:   const type = file.type || 'image/png';
 144:   const extension = getImageExtension(type);
 145:   const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
 146:   const fallbackName = `pasted-image-${timestamp}-${index + 1}.${extension}`;
 147:   const name = file.name || fallbackName;
 148:   const dataUrl = await readFileAsDataUrl(file);
 149:   if (!dataUrl) return null;
 150:   const idSuffix = typeof crypto !== 'undefined' && 'randomUUID' in crypto
 151:     ? crypto.randomUUID()
 152:     : `${Date.now()}-${index}-${Math.random().toString(36).slice(2)}`;
 153:   return {
 154:     id: `${PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE}:${idSuffix}`,
 155:     source: PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE,
 156:     dataUrl,
 157:     name,
 158:     size: file.size,
 159:     type,
 160:     previewUrl: dataUrl,
 161:   };
 162: }
 163: 
 164: function appendPendingAttachments(
 165:   setPendingAttachments: Dispatch<SetStateAction<Record<IntakeType, PendingAttachment[]>>>,
 166:   type: IntakeType,
 167:   attachments: PendingAttachment[],
 168: ) {
 169:   if (!attachments.length) return;
 170:   setPendingAttachments((current) => {
 171:     const nextItems = [...current[type]];
 172:     for (const attachment of attachments) {
 173:       if (!nextItems.some((item) => isSamePendingAttachment(item, attachment))) nextItems.push(attachment);
 174:     }
 175:     return nextItems.length === current[type].length ? current : { ...current, [type]: nextItems };
 176:   });
 177: }
 178: 
 179: function isSamePendingAttachment(current: PendingAttachment, next: PendingAttachment) {
 180:   if (current.source !== next.source) return false;
 181:   if (current.source === PENDING_ATTACHMENT_SOURCES.PATH && next.source === PENDING_ATTACHMENT_SOURCES.PATH) {
 182:     return current.path === next.path && current.size === next.size;
 183:   }
 184:   if (
 185:     current.source === PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE &&
 186:     next.source === PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE
 187:   ) {
 188:     return current.dataUrl === next.dataUrl && current.size === next.size;
 189:   }
 190:   return current.id === next.id;
 191: }
