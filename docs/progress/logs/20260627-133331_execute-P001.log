  31:   const queryLabel = searchState.query.raw.trim().replace(/\s+/g, ' ') || searchState.query.normalized;
  32: 
  33:   return (
  34:     <section className="search-results card" aria-label="统一搜索结果概览" aria-live="polite">
  35:       <div className="search-results-head">
  36:         <div>
  37:           <h2>搜索结果概览</h2>
  38:           <p>
  39:             “{queryLabel}” 命中 <b>{searchState.total}</b> 条结果
  40:           </p>
  41:         </div>
  42:         <button type="button" className="search-results-clear" onClick={onClear}>
  43:           清空搜索
  44:         </button>
  45:       </div>
  46: 
  47:       <div className="search-source-strip" aria-label="按来源统计的命中数量">
  48:         {searchState.groups.map((group) => (
  49:           <button
  50:             type="button"
  51:             className={`search-source-chip${group.count ? '' : ' is-empty'}`}
  52:             disabled={group.count === 0}
  53:             key={group.source}
  54:             onClick={() => onSelectGroup(group.targetTab)}
  55:           >
  56:             <Icon name={sourceIconNames[group.source]} size={14} aria-hidden="true" />
  57:             <span>{group.label}</span>
  58:             <b>{group.count}</b>
  59:           </button>
  60:         ))}
  61:       </div>
  62: 
  63:       {searchState.total === 0 ? (
  64:         <div className="search-results-empty">
  65:           <div>没有找到与“{queryLabel}”匹配的记录。</div>
  66:           <button type="button" className="btn btn-sm" onClick={onClear}>
  67:             清空搜索，恢复全部列表
  68:           </button>
  69:         </div>
  70:       ) : (
  71:         <div className="search-results-body">
  72:           <div className="search-result-groups">
  73:             {searchState.groups.map((group) => (
  74:               <SearchResultGroup
  75:                 group={group}
  76:                 key={group.source}
  77:                 onSelectGroup={onSelectGroup}
  78:                 onSelectResult={onSelectResult}
  79:               />
  80:             ))}
  81:           </div>
  82:         </div>
  83:       )}
  84:     </section>
  85:   );
  86: }
  87: 
  88: function SearchResultGroup({
  89:   group,
  90:   onSelectGroup,
  91:   onSelectResult,
  92: }: {
  93:   group: WorkspaceSearchGroup;
  94:   onSelectGroup: (targetTab: WorkspaceTab) => void;
  95:   onSelectResult: (result: WorkspaceSearchResult) => void;
  96: }) {
  97:   const visibleResults = group.results.slice(0, GROUP_RESULT_LIMIT);
  98:   const hiddenCount = Math.max(0, group.count - visibleResults.length);
  99: 
 100:   return (
 101:     <section className={`search-result-group${group.count ? '' : ' is-empty'}`}>
 102:       <div className="search-result-group-head">
 103:         <div className="search-result-group-title">
 104:           <Icon name={sourceIconNames[group.source]} size={16} aria-hidden="true" />
 105:           <span>{group.label}</span>
 106:         </div>
 107:         <span className="search-result-group-count">{group.count} 条</span>
 108:       </div>
 109: 
 110:       {visibleResults.length ? (
 111:         <div className="search-result-items">
 112:           {visibleResults.map((result) => (
 113:             <SearchResultItem key={result.id} result={result} onSelect={onSelectResult} />
 114:           ))}
 115:           {hiddenCount ? (
 116:             <button type="button" className="search-result-more" onClick={() => onSelectGroup(group.targetTab)}>
 117:               在{group.label}中查看其余 {hiddenCount} 条
 118:             </button>
 119:           ) : null}
 120:         </div>
 121:       ) : (
 122:         <div className="search-result-group-empty">无匹配</div>
 123:       )}
 124:     </section>
 125:   );
 126: }
 127: 
 128: function SearchResultItem({
 129:   onSelect,
 130:   result,
 131: }: {
 132:   onSelect: (result: WorkspaceSearchResult) => void;
 133:   result: WorkspaceSearchResult;
 134: }) {
 135:   const primaryMatch = result.matches[0];
 136:   const snippet = primaryMatch?.snippet || result.summary;
 137:   const updatedAt = formatChinaDateTime(result.updatedAt);
 138: 
 139:   return (
 140:     <button type="button" className="search-result-item" onClick={() => onSelect(result)}>
 141:       <span className="search-result-item-top">
 142:         <span className="search-result-title">{result.title}</span>
 143:         {result.status ? <span className="search-result-status">{result.status}</span> : null}
 144:       </span>
 145:       <span className="search-result-snippet">
 146:         {primaryMatch ? `${primaryMatch.label}：` : ''}
 147:         {snippet}
 148:       </span>
 149:       <span className="search-result-meta">
 150:         <span>{primaryMatch ? '点击后切换到对应列表' : '点击查看匹配记录'}</span>
 151:         {updatedAt ? <span>{updatedAt}</span> : null}
 152:       </span>
 153:     </button>
 154:   );
 155: }
