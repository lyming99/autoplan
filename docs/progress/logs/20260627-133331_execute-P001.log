1023: function createFilteredWorkspaceItems(
1024:   snapshot: AppSnapshot | null | undefined,
1025:   searchState: WorkspaceSearchState,
1026: ): WorkspaceFilterableItems {
1027:   if (!snapshot) {
1028:     return { requirements: [], feedback: [], plans: [], tasks: [], events: [] };
1029:   }
1030:   if (searchState.query.isEmpty) {
1031:     return {
1032:       requirements: snapshot.requirements,
1033:       feedback: snapshot.feedback,
1034:       plans: snapshot.plans,
1035:       tasks: snapshot.tasks,
1036:       events: snapshot.events,
1037:     };
1038:   }
1039: 
1040:   const plans = filterItemsBySearchGroup(snapshot.plans, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.PLAN);
1041:   const tasks = filterTasksBySearchGroups(snapshot.tasks, plans, searchState.groups);
1042: 
1043:   return {
1044:     requirements: filterItemsBySearchGroup(
1045:       snapshot.requirements,
1046:       searchState.groups,
1047:       WORKSPACE_SEARCH_SOURCE_TYPES.REQUIREMENT,
1048:     ),
1049:     feedback: filterItemsBySearchGroup(snapshot.feedback, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.FEEDBACK),
1050:     plans,
1051:     tasks,
1052:     events: filterItemsBySearchGroup(snapshot.events, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.EVENT),
1053:   };
1054: }
1055: 
1056: function filterItemsBySearchGroup<T extends { id: number }>(
1057:   items: T[],
1058:   groups: WorkspaceSearchGroup[],
1059:   source: WorkspaceSearchSourceType,
1060: ) {
1061:   const group = groups.find((item) => item.source === source);
1062:   if (!group?.results.length) return [];
1063: 
1064:   const recordIds = new Set(group.results.map((result) => result.recordId));
1065:   return items.filter((item) => recordIds.has(item.id));
1066: }
1067: 
1068: function filterTasksBySearchGroups(
1069:   tasks: PlanTask[],
1070:   plans: Plan[],
1071:   groups: WorkspaceSearchGroup[],
1072: ) {
1073:   const directTasks = filterItemsBySearchGroup(tasks, groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK);
1074:   if (!plans.length) return directTasks;
1075: 
1076:   const taskIds = new Set(directTasks.map((task) => task.id));
1077:   const planIds = new Set(plans.map((plan) => plan.id));
1078:   const planFilePaths = new Set(plans.map((plan) => plan.file_path).filter(Boolean));
1079:   const planTasks = tasks.filter(
1080:     (task) => planIds.has(task.plan_id) || (!!task.file_path && planFilePaths.has(task.file_path)),
1081:   );
1082: 
1083:   return [...directTasks, ...planTasks.filter((task) => !taskIds.has(task.id))];
1084: }
