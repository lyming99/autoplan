import type {
  AppSnapshot,
  WorkspaceSearchGroup,
  WorkspaceSearchHitField,
  WorkspaceSearchMatch,
  WorkspaceSearchQuery,
  WorkspaceSearchResult,
  WorkspaceSearchSourceConfig,
