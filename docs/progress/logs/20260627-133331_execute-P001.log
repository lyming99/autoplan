1086: function withTaskCliProviderTitle(task: PlanTask, fallbackProvider?: string | null): PlanTask {
1087:   const providerLabel = agentCliProviderLabel(readAgentCliProvider({ agentCliProvider: task.agentCliProvider || fallbackProvider }));
1088:   if (!providerLabel || task.title.startsWith(`[${providerLabel}] `)) return task;
1089:   return { ...task, title: `[${providerLabel}] ${task.title}` };
1090: }
1091: 
1092: function agentCliConfigSummary(state?: ProjectState | null) {
1093:   const provider = readAgentCliProvider(state);
1094:   const providerLabel = agentCliProviderLabel(provider);
1095:   if (provider === 'claude') return providerLabel;
1096:   return `${providerLabel} · 思考${codexReasoningEffortLabel(readCodexReasoningEffort(state))}`;
1097: }
