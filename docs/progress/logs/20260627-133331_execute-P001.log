 232:     && left.validationCommand === right.validationCommand
 233:     && left.agentCliProvider === right.agentCliProvider
 234:     && left.agentCliCommand === right.agentCliCommand
 235:     && left.codexReasoningEffort === right.codexReasoningEffort;
 236: }
