 119: function AttachmentView({ attachment }: { attachment: Attachment }) {
 120:   const url = window.autoplan.toFileUrl(attachment.stored_path);
 121:   const name = attachment.original_name || attachment.stored_path;
 122:   if (String(attachment.mime_type || '').startsWith('image/')) {
 123:     return (
 124:       <a className="attachment-thumb" href={url} target="_blank" rel="noreferrer" title={name}>
 125:         <img src={url} alt={name} />
 126:         <span>{name}</span>
 127:       </a>
 128:     );
 129:   }
 130:   return (
 131:     <a className="attachment-file" href={url} target="_blank" rel="noreferrer">
 132:       <span>{name}</span>
 133:       <small>{formatBytes(attachment.size)}</small>
 134:     </a>
