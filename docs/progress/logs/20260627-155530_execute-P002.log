+    if (!Array.isArray(planIds)) throw new Error('计划顺序无效');
+
+    const orderedIds = planIds.map((id) => Number(id));
+    if (orderedIds.some((id) => !Number.isInteger(id) || id <= 0)) throw new Error('计划顺序包含非法 ID');
