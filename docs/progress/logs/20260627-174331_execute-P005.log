+function main() {
+  const options = parseArgs(process.argv.slice(2));
+  if (options.platform !== 'macos') {
+    info(`No specialized checks configured for ${options.platform}; skipping.`);
+    return;
+  }
+  verifyMacArtifacts(options);
+}
