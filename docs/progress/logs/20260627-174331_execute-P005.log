+  const zipNames = new Set(artifacts.filter((artifact) => artifact.ext === 'zip').map((artifact) => artifact.name));
+  const referenced = [...content.matchAll(/[^\s'"/]+-mac-(?:x64|arm64)\.zip/g)].map((match) => match[0]);
