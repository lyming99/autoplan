import { useNavigate, useParams, useSearchParams } from 'react-router-dom';
import { PENDING_ATTACHMENT_SOURCES, WORKSPACE_SEARCH_SOURCE_TYPES } from '../types';
import type {
  AppSnapshot,
  IntakeType,
  PendingAttachment,
  Plan,
  PlanTask,
