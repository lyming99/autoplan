function WorkspaceSearchBox({
  hitCount,
  onQueryChange,
  query,
  totalCount,
}: {
  hitCount: number;
  onQueryChange: (query: string) => void;
  query: string;
  totalCount: number;
}) {
  const hasQuery = Boolean(normalizeSearchQuery(query));
  const resultLabel = hasQuery ? `命中 ${hitCount} 条` : `可搜索 ${totalCount} 条`;

  return (
    <div className="workspace-search" role="search" aria-label="工作区搜索">
      <div className="workspace-search-field">
        <Icon name="search" size={16} className="workspace-search-icon" aria-hidden="true" />
        <input
          aria-label="搜索当前工作区"
          className="workspace-search-input search-input"
          onChange={(event) => onQueryChange(event.target.value)}
          onKeyDown={(event) => {
            if (event.key === 'Escape' && query) {
              event.preventDefault();
              onQueryChange('');
            }
          }}
          placeholder="搜索需求、反馈、任务、Plan 或事件"
          value={query}
        />
        {query ? (
          <button
            type="button"
            className="workspace-search-clear"
            onClick={() => onQueryChange('')}
            aria-label="清空工作区搜索关键字"
          >
            <Icon name="close" size={15} aria-hidden="true" />
          </button>
        ) : null}
      </div>
      <span className={`workspace-search-count${hasQuery && hitCount === 0 ? ' is-empty' : ''}`} aria-live="polite">
        {resultLabel}
      </span>
    </div>
  );
}

function normalizeSearchQuery(value: string) {
  return value.trim().toLowerCase().replace(/\s+/g, ' ');
}

function countSearchableItems(snapshot: AppSnapshot) {
  return (
    snapshot.requirements.length +
    snapshot.feedback.length +
    snapshot.plans.length +
    snapshot.tasks.length +
    snapshot.events.length
  );
}

function createFilteredWorkspaceItems(
  snapshot: AppSnapshot | null | undefined,
  searchState: WorkspaceSearchState,
): WorkspaceFilterableItems {
  if (!snapshot) {
    return { requirements: [], feedback: [], plans: [], tasks: [], events: [] };
  }
  if (searchState.query.isEmpty) {
    return {
      requirements: snapshot.requirements,
      feedback: snapshot.feedback,
      plans: snapshot.plans,
      tasks: snapshot.tasks,
      events: snapshot.events,
    };
  }

  return {
    requirements: filterItemsBySearchGroup(
      snapshot.requirements,
      searchState.groups,
      WORKSPACE_SEARCH_SOURCE_TYPES.REQUIREMENT,
    ),
    feedback: filterItemsBySearchGroup(snapshot.feedback, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.FEEDBACK),
    plans: filterItemsBySearchGroup(snapshot.plans, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.PLAN),
    tasks: filterItemsBySearchGroup(snapshot.tasks, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK),
    events: filterItemsBySearchGroup(snapshot.events, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.EVENT),
  };
}

function filterItemsBySearchGroup<T extends { id: number }>(
  items: T[],
  groups: WorkspaceSearchGroup[],
  source: WorkspaceSearchSourceType,
) {
  const group = groups.find((item) => item.source === source);
  if (!group?.results.length) return [];

  const recordIds = new Set(group.results.map((result) => result.recordId));
  return items.filter((item) => recordIds.has(item.id));
}

function withTaskCliProviderTitle(task: PlanTask, fallbackProvider?: string | null): PlanTask {
  const providerLabel = agentCliProviderLabel(task.agentCliProvider || fallbackProvider);
  if (!providerLabel || task.title.startsWith(`[${providerLabel}] `)) return task;
  return { ...task, title: `[${providerLabel}] ${task.title}` };
}

function SettingsView({
  loopForm,
  setLoopForm,
  onSubmit,
  onToggleRun,
  running,
}: {
  loopForm: LoopFormState;
  setLoopForm: Dispatch<SetStateAction<LoopFormState>>;
  onSubmit: (event: FormEvent<HTMLFormElement>) => void;
  onToggleRun: () => void;
  running: boolean;
}) {
  return (
    <div className="settings-layout">
      <form className="editor card settings-card" onSubmit={onSubmit}>
        <div className="card-head">
          <h2>循环控制</h2>
          <span className="hint">工作区路径、循环间隔、验收命令与 CLI 后端</span>
        </div>
        <label className="field">
          工作区路径
          <input
            value={loopForm.workspacePath}
            onChange={(event) => setLoopForm((current) => ({ ...current, workspacePath: event.target.value }))}
            placeholder="D:\project\GitHub\my-app"
          />
        </label>
        <label className="field">
          间隔秒数
          <input
            min="1"
            type="number"
            value={loopForm.intervalSeconds}
            onChange={(event) => setLoopForm((current) => ({ ...current, intervalSeconds: event.target.value }))}
          />
        </label>
        <label className="field">
          验收命令（留空则不校验）
          <input
            value={loopForm.validationCommand}
            onChange={(event) => setLoopForm((current) => ({ ...current, validationCommand: event.target.value }))}
            placeholder="留空则跳过外部验收命令"
          />
        </label>
        <label className="field">
          CLI 后端
          <select
            value={loopForm.agentCliProvider}
            onChange={(event) => setLoopForm((current) => ({ ...current, agentCliProvider: event.target.value }))}
          >
            <option value="codex">Codex CLI</option>
            <option value="claude">Claude CLI</option>
          </select>
          {loopForm.agentCliProvider === 'claude' ? (
            <small className="field-hint">需本机已安装 claude CLI 并完成认证</small>
          ) : null}
        </label>
        <label className="field">
          CLI 命令路径（留空用默认）
          <input
            className="mono"
            value={loopForm.agentCliCommand}
            onChange={(event) => setLoopForm((current) => ({ ...current, agentCliCommand: event.target.value }))}
            placeholder={loopForm.agentCliProvider === 'claude' ? 'claude' : 'codex'}
          />
        </label>
        <div className="button-row">
          <button type="submit">保存配置</button>
          <button type="button" onClick={onToggleRun}>
            {running ? '停止' : '启动'}
          </button>
        </div>
      </form>
    </div>
  );
}

function OverviewView({
  snapshot,
  state,
  onGoTasks,
}: {
  snapshot: AppSnapshot;
  state: ProjectState | null;
  onGoTasks: () => void;
}) {
  const reqCount = snapshot.requirements.length;
  const planCount = snapshot.plans.length;
  const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
  const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
  const totalTasks = snapshot.tasks.length;

  const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
  const currentPhase = state?.phase || 'idle';
  const activeIndex = phases.indexOf(currentPhase);
  const operation = snapshot.activeOperation || snapshot.lastOperation;
  const operationActive = Boolean(snapshot.activeOperation);
  const operationProvider = operation?.agentCliProvider || state?.agent_cli_provider;
  const operationProviderLabel = agentCliProviderLabel(operationProvider);
  const operationSessionLabel = operationProviderLabel === 'Codex' ? operation?.codexSessionLabel : '';
  const operationTime = operation?.startedAt ? `开始于 ${formatChinaTime(operation.startedAt)}` : '';
  const operationExit =
    operation && !operationActive && typeof operation.exitCode === 'number'
      ? `退出码 ${operation.exitCode}${operation.exitCode === 0 ? '（成功）' : '（失败）'}`
      : '';
  const operationHint = operation
    ? [operationProviderLabel, operationTime, operationSessionLabel, operationExit].filter(Boolean).join(' · ')
    : '等待下一次执行';
  const operationTitle = operation
    ? `${operationActive ? '执行日志' : '最近执行'} · ${operationProviderLabel} · ${operation.label}`
    : `执行日志 · ${operationProviderLabel}`;

  return (
    <>
      <div className="stat-grid">
        <StatCard icon="requirement" value={String(reqCount)} label="需求" accent="brand" />
        <StatCard
          icon="plan"
          value={String(planCount)}
          label="计划"
          sub={runningPlan ? `${runningPlan.completed_tasks}/${runningPlan.total_tasks} 任务` : '无进行中'}
          accent="info"
        />
        <StatCard icon="tasks" value={`${doneTasks}/${totalTasks}`} label="任务进度" accent="success" />
        <StatCard
          icon="settings"
          value={agentCliProviderLabel(state?.agent_cli_provider)}
          label="CLI 后端"
          sub={`间隔 ${state?.interval_seconds || 5}s`}
          accent="warning"
        />
      </div>

      <div className="overview-grid">
        <div className="overview-main-column">
          <section className="card live-log-card">
            <div className="card-head log-card-head">
              <div className="log-title-line">
                <h2>
                  <span className={`live-dot${operationActive ? '' : ' idle'}`} /> {operationTitle}
                </h2>
                <span className="hint">{operationHint}</span>
                <span className={`log-phase-chip ${state?.running ? 'running' : 'stopped'}`}>
                  {state?.running ? '循环运行中' : '循环已停止'} · {operationProviderLabel} · {currentPhase}
                </span>
              </div>
              <div className="log-summary">
                <span>
                  需求 <b>{snapshot.requirements.length}</b>
                </span>
                <span>
                  反馈 <b>{snapshot.feedback.length}</b>
                </span>
                <span>
                  Plan <b>{snapshot.plans.length}</b>
                </span>
              </div>
            </div>
            <CodexLog
              log={operation?.logTail || ''}
              activity={operation?.activity || []}
              context={operation || null}
              provider={operationProvider}
            />
          </section>
        </div>

        <div className="overview-side-column">
          <section className="card">
            <div className="card-head">
              <h2>循环阶段流水线</h2>
            </div>
            <div className="card-body">
              <div className="pipeline">
                {phases.map((phase, index) => {
                  const done = activeIndex > index;
                  const active = activeIndex === index;
                  return (
                    <div className={`pipe-step ${done ? 'done' : ''} ${active ? 'active' : ''}`} key={phase}>
                      <div className="pipe-node">
                        {done ? (
                          <Icon name="complete" size={18} className="pipe-status-icon" aria-hidden="true" />
                        ) : active ? (
                          <Icon name="run" size={18} className="pipe-status-icon" aria-hidden="true" />
                        ) : (
                          index + 1
                        )}
                      </div>
                      <div className="pipe-label">{phaseLabel(phase)}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          </section>

          <section className="card">
            <div className="card-head">
              <h2>近期事件</h2>
              <span className="spacer">
                <button type="button" className="btn-link" onClick={onGoTasks}>
                  查看任务
                  <Icon name="enter" size={14} aria-hidden />
                </button>
              </span>
            </div>
            <div className="card-body">
              <EventList events={snapshot.events.slice(0, 8)} />
            </div>
          </section>
        </div>
      </div>
    </>
  );
}

function StatCard({
  icon,
  value,
  label,
  sub,
  accent,
}: {
  icon: IconName;
  value: string;
  label: string;
  sub?: string;
  accent: 'brand' | 'info' | 'success' | 'warning';
}) {
  return (
    <div className={`stat stat-${accent}`}>
      <div className="stat-ico">
        <Icon name={icon} size={20} aria-hidden="true" />
      </div>
      <div className="stat-value">{value}</div>
      <div className="stat-label">{label}</div>
      {sub ? <div className="stat-delta">{sub}</div> : null}
    </div>
  );
}

function tabTitle(tab: WorkspaceTab) {
  return { overview: '概览', requirement: '需求模块', feedback: '反馈模块', tasks: '任务与计划', events: '事件流', settings: '设置' }[tab];
}

function tabSubtitle(tab: WorkspaceTab, project: Project | null) {
  const base = {
    overview: '循环状态、阶段流水线与各模块一览',
    requirement: '收集需求，发送后由循环自动生成开发计划',
    feedback: '收集反馈，关联需求并由循环生成开发计划',
    tasks: 'Plan 与任务进度',
    events: '循环运行日志与任务执行记录',
    settings: '工作区路径、循环间隔、验收命令与 CLI 后端',
  }[tab];
  return project ? `${base} · ${project.name}` : base;
}

function phaseLabel(phase: string) {
  return (
    {
      idle: '空闲',
      scan: '扫描',
      'generate-plan': '生成计划',
      'execute-task': '执行任务',
      validate: '验收',
      completed: '完成',
      waiting: '等待',
      error: '异常',
    }[phase] || phase
  );
}


---FILE:types---
export type IntakeType = 'requirement' | 'feedback';
export type WorkspaceTab = 'overview' | 'requirement' | 'feedback' | 'tasks' | 'events' | 'settings';
export type AgentCliProvider = 'codex' | 'claude' | string;
export type CodexReasoningEffort = 'low' | 'medium' | 'high' | string;

export const WORKSPACE_SEARCH_SOURCE_TYPES = {
  REQUIREMENT: 'requirement',
  FEEDBACK: 'feedback',
  PLAN: 'plan',
  TASK: 'task',
  EVENT: 'event',
} as const;

export type WorkspaceSearchSourceType =
  (typeof WORKSPACE_SEARCH_SOURCE_TYPES)[keyof typeof WORKSPACE_SEARCH_SOURCE_TYPES];

export const WORKSPACE_SEARCH_HIT_FIELDS = {
  TITLE: 'title',
  BODY: 'body',
  STATUS: 'status',
  MARKDOWN: 'markdown',
  FILE_PATH: 'filePath',
  SOURCE_PATH: 'sourcePath',
  TASK_KEY: 'taskKey',
  SCOPE: 'scope',
  RAW_LINE: 'rawLine',
  EVENT_TYPE: 'eventType',
  EVENT_MESSAGE: 'eventMessage',
  EVENT_META: 'eventMeta',
} as const;

export type WorkspaceSearchHitField =
  (typeof WORKSPACE_SEARCH_HIT_FIELDS)[keyof typeof WORKSPACE_SEARCH_HIT_FIELDS];

export interface WorkspaceSearchQuery {
  raw: string;
  normalized: string;
  terms: string[];
  isEmpty: boolean;
}

export interface WorkspaceSearchSourceConfig {
  type: WorkspaceSearchSourceType;
  label: string;
  targetTab: WorkspaceTab;
}

export interface WorkspaceSearchMatch {
  field: WorkspaceSearchHitField;
  label: string;
  value: string;
  snippet?: string;
}

export interface WorkspaceSearchResult {
  id: string;
  source: WorkspaceSearchSourceType;
  targetTab: WorkspaceTab;
  recordId: number;
  title: string;
  summary: string;
  status: string | null;
  updatedAt: string;
  matches: WorkspaceSearchMatch[];
}

export interface WorkspaceSearchGroup {
  source: WorkspaceSearchSourceType;
  label: string;
  targetTab: WorkspaceTab;
  count: number;
  results: WorkspaceSearchResult[];
}

export interface WorkspaceSearchState {
  query: WorkspaceSearchQuery;
  total: number;
  results: WorkspaceSearchResult[];
  groups: WorkspaceSearchGroup[];
}

export interface Project {
  id: number;
  name: string;
  workspace_path: string;
  description: string;
  created_at: string;
  updated_at: string;
  running?: number;
  phase?: string;
  interval_seconds?: number;
  validation_command?: string;
  agent_cli_provider?: AgentCliProvider;
  agent_cli_command?: string;
}

export interface ProjectState {
  project_id: number;
  running: number;
  phase: string;
  interval_seconds: number;
  validation_command: string;
  last_issue_hash?: string | null;
  last_error?: string | null;
  agent_cli_provider?: AgentCliProvider;
  agent_cli_command?: string;
  updated_at: string;
  /** 由 snapshot 合并自 project.workspace_path */
  workspace_path?: string;
}

export interface Requirement {
  id: number;
  project_id: number;
  title: string;
  body: string;
  status: string;
  source_path?: string | null;
  source_hash?: string | null;
  agent_cli_provider?: AgentCliProvider | null;
  agent_cli_command?: string;
  codex_reasoning_effort?: CodexReasoningEffort | null;
  linked_plan_id?: number | null;
  plan_status?: string | null;
  plan_completed?: number | null;
  plan_total?: number | null;
  created_at: string;
  updated_at: string;
}

export interface Feedback {
  id: number;
  project_id: number;
  requirement_id?: number | null;
  title: string;
  body: string;
  status: string;
  agent_cli_provider?: AgentCliProvider | null;
  agent_cli_command?: string;
  codex_reasoning_effort?: CodexReasoningEffort | null;
  linked_plan_id?: number | null;
  plan_status?: string | null;
  plan_completed?: number | null;
  plan_total?: number | null;
  created_at: string;
  updated_at: string;
}

export interface Attachment {
  id: number;
  project_id: number;
  owner_type: IntakeType;
  owner_id: number;
  original_name: string;
  stored_path: string;
  mime_type?: string | null;
  size: number;
  hash: string;
  created_at: string;
}

export interface Plan {
  id: number;
  project_id: number;
  issue_hash: string;
  file_path: string;
  hash: string;
  status: string;
  total_tasks: number;
  completed_tasks: number;
  validation_passed: number;
  created_at: string;
  updated_at: string;
}

export interface ReadPlanResult {
  ok: boolean;
  id: number | null;
  project_id: number | null;
  file_path: string;
  markdown: string;
  hash: string;
  updated_at: string;
  error: string | null;
}

export interface WorkspacePlanReadState {
  plan: Plan | null;
  result: ReadPlanResult | null;
  loading: boolean;
  error: string | null;
}

export type CodexSessionMode = 'new' | 'resume';

export type CodexSessionState = CodexSessionMode | 'fallback-new' | string;

export interface CodexSessionInfo {
  codexSessionId?: string | null;
  codexSessionShortId?: string | null;
  codexSessionMode?: CodexSessionMode | null;
  codexSessionState?: CodexSessionState | null;
  codexSessionLabel?: string | null;
  codexSessionRequestedId?: string | null;
  codexSessionRequestedShortId?: string | null;
  codexSessionFallback?: boolean | null;
}

export interface PlanTask extends CodexSessionInfo {
  id: number;
  plan_id: number;
  task_key: string;
  title: string;
  raw_line: string;
  scope: string;
  status: string;
  sort_order: number;
  started_at: string | null;
  finished_at: string | null;
  duration_ms: number;
  run_duration_ms?: number;
  codex_session_id: string | null;
  agentCliProvider?: string | null;
  agentCliCommand?: string | null;
  updated_at: string;
  /** JOIN plans 得到 */
  file_path: string;
}

export const TASK_EVENT_TYPES = {
  STARTED: 'task.started',
  SUCCEEDED: 'task.succeeded',
  FAILED: 'task.failed',
  STOP_REQUESTED: 'task.stop.requested',
  STOPPED: 'task.stopped',
  INTERRUPTED: 'task.interrupted',
} as const;

export const LEGACY_TASK_EVENT_TYPES = {
  EXECUTED: 'task.executed',
  STOPPING: 'task.stopping',
} as const;

export const TASK_EVENT_STATUS = {
  PENDING: 'pending',
  RUNNING: 'running',
  COMPLETED: 'completed',
  FAILED: 'failed',
  STOPPING: 'stopping',
  STOPPED: 'stopped',
  INTERRUPTED: 'interrupted',
} as const;

export type TaskEventType = (typeof TASK_EVENT_TYPES)[keyof typeof TASK_EVENT_TYPES];
export type LegacyTaskEventType = (typeof LEGACY_TASK_EVENT_TYPES)[keyof typeof LEGACY_TASK_EVENT_TYPES];
export type TaskEventStatus = (typeof TASK_EVENT_STATUS)[keyof typeof TASK_EVENT_STATUS];

export interface TaskEventSemantics {
  status: TaskEventStatus;
  label: string;
}

export const TASK_EVENT_SEMANTICS: Record<TaskEventType, TaskEventSemantics> = {
  [TASK_EVENT_TYPES.STARTED]: { status: TASK_EVENT_STATUS.RUNNING, label: '开始了任务' },
  [TASK_EVENT_TYPES.SUCCEEDED]: { status: TASK_EVENT_STATUS.COMPLETED, label: '结束了任务' },
  [TASK_EVENT_TYPES.FAILED]: { status: TASK_EVENT_STATUS.FAILED, label: '任务失败' },
  [TASK_EVENT_TYPES.STOP_REQUESTED]: { status: TASK_EVENT_STATUS.STOPPING, label: '请求停止任务' },
  [TASK_EVENT_TYPES.STOPPED]: { status: TASK_EVENT_STATUS.STOPPED, label: '已停止任务' },
  [TASK_EVENT_TYPES.INTERRUPTED]: { status: TASK_EVENT_STATUS.INTERRUPTED, label: '已中断任务' },
};

export const TASK_EVENT_COMPATIBILITY: Record<LegacyTaskEventType, TaskEventType> = {
  [LEGACY_TASK_EVENT_TYPES.EXECUTED]: TASK_EVENT_TYPES.SUCCEEDED,
  [LEGACY_TASK_EVENT_TYPES.STOPPING]: TASK_EVENT_TYPES.STOPPED,
};

export interface TaskEventMeta extends CodexSessionInfo {
  taskId?: number | null;
  taskKey?: string | null;
  taskTitle?: string | null;
  planId?: number | null;
  status?: TaskEventStatus | string | null;
  startedAt?: string | null;
  finishedAt?: string | null;
  durationMs?: number | null;
  runDurationMs?: number | null;
  exitCode?: number | null;
  log?: string | null;
  error?: string | null;
  agentCliProvider?: string | null;
  agentCliCommand?: string | null;
  [key: string]: unknown;
}

export type AppEventStructuredMeta = TaskEventMeta | Record<string, unknown>;
export type AppEventMeta = string | AppEventStructuredMeta;

export interface AppEvent<TMeta extends AppEventMeta | null = AppEventMeta | null> {
  id: number;
  project_id: number;
  type: string;
  message: string;
  meta?: TMeta;
  created_at: string;
}

export interface ScanFile {
  project_id: number;
  scan_type: string;
  file_path: string;
  hash: string;
  size: number;
  modified_at: string;
  scanned_at: string;
}

export interface AppSnapshot {
  activeProjectId: number | null;
  activeProject: Project | null;
  projects: Project[];
  state: ProjectState | null;
  requirements: Requirement[];
  feedback: Feedback[];
  attachments: Attachment[];
  plans: Plan[];
  tasks: PlanTask[];
  events: AppEvent<AppEventMeta | null>[];
  scans: ScanFile[];
  activeOperation: ActiveOperation | null;
  activeOperations: ActiveOperation[];
  lastOperation: ActiveOperation | null;
}

export interface ActivityLine {
  role: string;
  text: string;
  at: string;
}

export interface ActiveOperation extends CodexSessionInfo {
  label: string;
  projectId: number | null;
  planId: number | null;
  taskId: number | null;
  agentCliProvider?: string;
  agentCliCommand?: string;
  startedAt: string | null;
  finishedAt?: string | null;
  exitCode?: number | null;
  logTail: string;
  activity: ActivityLine[];
}

export const PENDING_ATTACHMENT_SOURCES = {
  PATH: 'path',
  CLIPBOARD_IMAGE: 'clipboard-image',
} as const;

export type PendingAttachmentSource =
  (typeof PENDING_ATTACHMENT_SOURCES)[keyof typeof PENDING_ATTACHMENT_SOURCES];

export interface PendingAttachmentBase {
  id: string;
  source: PendingAttachmentSource;
  name: string;
  size: number;
  /** MIME type */
  type: string;
  previewUrl: string;
}

export interface PendingPathAttachment extends PendingAttachmentBase {
  source: typeof PENDING_ATTACHMENT_SOURCES.PATH;
  path: string;
}

export interface PendingClipboardImageAttachment extends PendingAttachmentBase {
  source: typeof PENDING_ATTACHMENT_SOURCES.CLIPBOARD_IMAGE;
  dataUrl: string;
  base64?: string;
  dataBase64?: string;
  bytes?: number[] | ArrayBuffer | Uint8Array;
}

export type PendingAttachment = PendingPathAttachment | PendingClipboardImageAttachment;

export interface CreateIntakeInput {
  projectId: number;
  body: string;
  attachments: PendingAttachment[];
  title?: string;
  status?: string;
  autoRun?: boolean;
  requirementId?: number | null;
  agentCliProvider?: AgentCliProvider;
  agentCliCommand?: string;
  codexReasoningEffort?: CodexReasoningEffort;
}

export interface CreateProjectInput {
  name: string;
  workspacePath: string;
  description?: string;
  agentCliProvider?: AgentCliProvider;
  agentCliCommand?: string;
}

export interface UpdateProjectInput extends CreateProjectInput {
  id: number;
}

export interface LoopConfigInput {
  projectId: number;
  workspacePath?: string;
  intervalSeconds?: number;
  validationCommand?: string;
  agentCliProvider?: AgentCliProvider;
  agentCliCommand?: string;
}

export interface ProjectIdInput {
  projectId: number;
  manual?: boolean;
}

export interface RecordIdInput extends ProjectIdInput {
  id: number;
}

export interface TaskIdInput extends ProjectIdInput {
  taskId: number;
}

export interface ReadPlanInput extends ProjectIdInput {
  planId: number;
}

export interface IntakeActionInput extends ProjectIdInput {
  type: IntakeType;
  id: number;
  title?: string;
}

export interface UpdateRequirementInput extends RecordIdInput {
  title?: string;
  body?: string;
  status?: string;
  attachments?: PendingAttachment[];
  agentCliProvider?: AgentCliProvider;
  agentCliCommand?: string;
  codexReasoningEffort?: CodexReasoningEffort;
}

export interface UpdateFeedbackInput extends UpdateRequirementInput {
  requirementId?: number | null;
}

export interface AutoplanApi {
  snapshot: (projectId?: number | null) => Promise<AppSnapshot>;
  createProject: (input: CreateProjectInput) => Promise<AppSnapshot>;
  updateProject: (input: UpdateProjectInput) => Promise<AppSnapshot>;
  deleteProject: (input: ProjectIdInput) => Promise<AppSnapshot>;
  configureLoop: (config: LoopConfigInput) => Promise<AppSnapshot>;
  startLoop: (input: ProjectIdInput) => Promise<AppSnapshot>;
  stopLoop: (input: ProjectIdInput) => Promise<AppSnapshot>;
  runOnce: (input: ProjectIdInput) => Promise<AppSnapshot>;
  readPlan: (input: ReadPlanInput) => Promise<ReadPlanResult>;
  runTask: (input: TaskIdInput) => Promise<AppSnapshot>;
  stopTask: (input: TaskIdInput) => Promise<AppSnapshot>;
  createRequirement: (input: CreateIntakeInput) => Promise<AppSnapshot>;
  updateRequirement: (input: UpdateRequirementInput) => Promise<AppSnapshot>;
  deleteRequirement: (input: RecordIdInput) => Promise<AppSnapshot>;
  createFeedback: (input: CreateIntakeInput) => Promise<AppSnapshot>;
  updateFeedback: (input: UpdateFeedbackInput) => Promise<AppSnapshot>;
  deleteFeedback: (input: RecordIdInput) => Promise<AppSnapshot>;
  interruptIntake: (input: IntakeActionInput) => Promise<AppSnapshot>;
  resumeIntake: (input: IntakeActionInput) => Promise<AppSnapshot>;
  appendIntakeTask: (input: IntakeActionInput) => Promise<AppSnapshot>;
  getDroppedFilePath: (file: File) => string;
  toFileUrl: (filePath: string) => string;
  onLoopUpdate: (handler: (snapshot: AppSnapshot) => void) => () => void;
}

declare global {
  interface Window {
    autoplan: AutoplanApi;
  }
}


---FILE:styles---
/* ============================================================
   设计系统 · Design Tokens
   ============================================================ */
:root {
  color-scheme: light;
  font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  --font-mono: "Cascadia Code", Consolas, "Courier New", monospace;

  --brand-50: #eef4ff;
  --brand-100: #dbe7ff;
  --brand-500: #3b6ef5;
  --brand-600: #255fbd;
  --brand-700: #1d4a94;
  --brand-grad: linear-gradient(135deg, #4f7bff 0%, #6d5dfc 100%);

  --bg-app: #f4f6fb;
  --bg-elevated: #ffffff;
  --bg-soft: #f8fafd;
  --bg-hover: #eef2f9;
  --line: #e2e8f1;
  --line-soft: #eef2f8;

  --text-1: #172033;
  --text-2: #475067;
  --text-3: #7c879b;
  --text-4: #a4adc0;

  --success: #18a957;
  --success-bg: #e7f7ee;
  --warning: #e08600;
  --warning-bg: #fdf3e3;
  --danger: #e5484d;
  --danger-bg: #fdecec;
  --info: #2563eb;
  --info-bg: #e8f0ff;

  --r-sm: 6px;
  --r-md: 10px;
  --r-lg: 14px;
  --r-xl: 20px;
  --shadow-sm: 0 1px 2px rgba(23, 32, 51, 0.06);
  --shadow-md: 0 6px 18px rgba(23, 32, 51, 0.08);
  --shadow-lg: 0 18px 48px rgba(37, 62, 120, 0.14);

  background: var(--bg-app);
  color: var(--text-1);
}

* { box-sizing: border-box; }
html, body { height: 100%; margin: 0; }
body { overflow: hidden; font-size: 14px; -webkit-font-smoothing: antialiased; }
h1, h2, h3, p { margin: 0; }
button { font: inherit; cursor: pointer; }
a { color: var(--brand-600); text-decoration: none; }
.mono { font-family: var(--font-mono); }
.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
#root { height: 100vh; }

.btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 9px 16px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); color: var(--text-1); font-size: 13px; font-weight: 600; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
.btn:hover { background: var(--bg-hover); }
.btn:active { transform: translateY(1px); }
.btn-primary { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
.btn-primary:hover { background: var(--brand-700); }
.btn-danger { background: var(--danger); border-color: var(--danger); color: #fff; }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-link { display: inline-flex; align-items: center; gap: 5px; background: transparent; border: 0; color: var(--brand-600); font-size: 12px; font-weight: 600; padding: 4px 8px; }
.btn-link:hover { text-decoration: underline; }
button:focus-visible, a:focus-visible, [tabindex]:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
.btn-link:focus-visible, .modal-close:focus-visible { border-radius: var(--r-sm); box-shadow: 0 0 0 3px var(--brand-50); }

.card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); }
.card-head { display: flex; align-items: center; gap: 12px; padding: 16px 18px; border-bottom: 1px solid var(--line-soft); }
.card-head h2 { font-size: 14.5px; font-weight: 700; }
.card-head .hint { font-size: 12px; color: var(--text-3); }
.card-head .spacer { margin-left: auto; }
.card-body { padding: 16px 18px; }

/* 表单型卡片（如循环控制）：head 之后给 body 留内边距 */
.editor.card { display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
.editor > .card-head { flex: 0 0 auto; }
.editor > .field,
.editor > .button-row,
.editor > .control-row { padding: 0 18px; }
.editor > .field:first-of-type { padding-top: 16px; }
.editor > .button-row { padding: 4px 18px 18px; flex-wrap: wrap; }
.editor .button-row button {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 7px 14px; border: 1px solid var(--line); border-radius: var(--r-sm);
  background: var(--bg-elevated); color: var(--text-1); font-size: 12.5px; font-weight: 600;
  transition: background 0.14s, border-color 0.14s;
}
.editor .button-row button:hover { background: var(--bg-hover); }
.editor .button-row button[type="submit"] { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
.editor .button-row button[type="submit"]:hover { background: var(--brand-700); }

.chip { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; letter-spacing: 0.02em; text-transform: uppercase; }
.chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.chip-pending { color: var(--text-3); background: var(--bg-soft); }
.chip-running { color: var(--info); background: var(--info-bg); }
.chip-completed { color: var(--success); background: var(--success-bg); }
.chip-failed { color: var(--danger); background: var(--danger-bg); }
.chip-stopped { color: var(--warning); background: var(--warning-bg); }
.chip-waiting { color: var(--warning); background: var(--warning-bg); }

.empty { color: var(--text-3); padding: 28px 18px; text-align: center; font-size: 13px; }
.error-banner { padding: 12px 16px; margin-bottom: 16px; border-radius: var(--r-md); background: var(--danger-bg); border: 1px solid #f3c2c4; color: var(--danger); font-size: 13px; }
.req { color: var(--danger); }
.danger-text { color: var(--danger); }

.app-icon { display: inline-block; flex: 0 0 auto; width: var(--icon-size, 1em); height: var(--icon-size, 1em); color: inherit; vertical-align: -0.14em; }
.app-icon * { vector-effect: non-scaling-stroke; }
.app-icon-muted { color: var(--text-3); }
.app-icon-brand { color: var(--brand-600); }
.app-icon-success { color: var(--success); }
.app-icon-warning { color: var(--warning); }
.app-icon-danger { color: var(--danger); }
.icon-with-text { display: inline-flex; align-items: center; gap: 6px; }
.icon-surface { display: inline-grid; place-items: center; width: var(--icon-surface-size, 36px); height: var(--icon-surface-size, 36px); border-radius: 50%; color: var(--icon-surface-color, currentColor); background: var(--icon-surface-bg, transparent); }
.icon-surface-brand { --icon-surface-color: var(--brand-600); --icon-surface-bg: var(--brand-50); }
.icon-surface-success { --icon-surface-color: var(--success); --icon-surface-bg: var(--success-bg); }
.icon-surface-warning { --icon-surface-color: var(--warning); --icon-surface-bg: var(--warning-bg); }
.icon-surface-danger { --icon-surface-color: var(--danger); --icon-surface-bg: var(--danger-bg); }

.list { display: grid; gap: 10px; padding: 16px 18px; }
.list.compact { max-height: none; overflow: auto; }
.item { min-width: 0; border: 1px solid var(--line-soft); border-radius: var(--r-md); padding: 12px; background: var(--bg-soft); }
.item-title { display: flex; justify-content: space-between; gap: 12px; min-width: 0; font-weight: 650; align-items: center; }
.item-title > span:first-child { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-title-right { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; min-width: 0; flex: 0 0 auto; }
.item-actions { display: inline-flex; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: 4px; }
.item-actions .btn-link { padding: 3px 6px; font-size: 12px; white-space: nowrap; }
.item-actions .danger-link { color: var(--danger); }
.item-actions .btn-link:disabled { color: var(--text-4); cursor: not-allowed; text-decoration: none; }
.item-body { margin-top: 10px; color: var(--text-2); overflow-wrap: anywhere; }
.plain-text { line-height: 1.55; white-space: pre-wrap; word-break: break-word; }
.markdown-reader { min-width: 0; max-width: 100%; color: var(--text-1); font-size: 13.5px; line-height: 1.72; overflow-wrap: anywhere; }
.markdown-reader > :first-child { margin-top: 0; }
.markdown-reader > :last-child { margin-bottom: 0; }
.markdown-reader-empty { padding: 28px 18px; border: 1px dashed var(--line); border-radius: var(--r-md); background: var(--bg-soft); color: var(--text-3); text-align: center; font-size: 13px; }
.markdown-reader h1 { margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--line-soft); font-size: 22px; line-height: 1.3; font-weight: 800; }
.markdown-reader h2 { margin: 24px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--line-soft); font-size: 18px; line-height: 1.35; font-weight: 750; }
.markdown-reader h3 { margin: 20px 0 8px; font-size: 15.5px; line-height: 1.4; font-weight: 700; }
.markdown-reader h4, .markdown-reader h5, .markdown-reader h6 { margin: 16px 0 8px; font-size: 14px; line-height: 1.4; font-weight: 700; }
.markdown-reader p { margin: 0 0 12px; color: var(--text-2); }
.markdown-reader a { color: var(--brand-600); overflow-wrap: anywhere; word-break: break-word; }
.markdown-reader a:hover { text-decoration: underline; }
.markdown-reader ul, .markdown-reader ol { margin: 0 0 14px; padding-left: 1.45em; color: var(--text-2); }
.markdown-reader li { margin: 4px 0; }
.markdown-reader li > p { margin: 6px 0; }
.markdown-reader .contains-task-list { list-style: none; padding-left: 1.2em; }
.markdown-reader .task-list-item { margin-left: -1.2em; }
.markdown-reader input[type="checkbox"] { width: auto; margin: 0 7px 0 0; accent-color: var(--brand-600); vertical-align: -2px; }
.markdown-reader .task-list-item > input[type="checkbox"] { margin-top: 0.42em; }
.markdown-reader blockquote { margin: 14px 0; padding: 10px 14px; border-left: 3px solid var(--brand-500); border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--brand-50); color: var(--text-2); }
.markdown-reader blockquote p { color: inherit; }
.markdown-reader code { padding: 2px 5px; border: 1px solid var(--line-soft); border-radius: var(--r-sm); background: var(--bg-soft); color: var(--text-1); font-family: var(--font-mono); font-size: 0.92em; word-break: break-word; }
.markdown-reader pre { max-width: 100%; margin: 14px 0; padding: 12px 14px; overflow: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,0.65); }
.markdown-reader pre code { display: block; padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text-1); white-space: pre; word-break: normal; overflow-wrap: normal; }
.markdown-reader pre:focus-visible, .markdown-reader-table:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
.markdown-reader-table { max-width: 100%; margin: 14px 0; overflow-x: auto; border: 1px solid var(--line); border-radius: var(--r-md); }
.markdown-reader-table table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 13px; }
.markdown-reader th, .markdown-reader td { padding: 8px 10px; border: 1px solid var(--line); text-align: left; vertical-align: top; }
.markdown-reader th { background: var(--bg-soft); color: var(--text-1); font-weight: 700; }
.markdown-reader tr:nth-child(even) td { background: rgba(248,250,253,0.65); }
.markdown-reader hr { margin: 20px 0; border: 0; border-top: 1px solid var(--line); }
.markdown-reader img { max-width: 100%; height: auto; border-radius: var(--r-md); box-shadow: var(--shadow-sm); }
.meta { margin-top: 6px; color: var(--text-3); font-size: 12px; word-break: break-all; overflow-wrap: anywhere; }
.event-list { min-width: 0; }
.event-item { display: grid; gap: 8px; border-left: 3px solid transparent; }
.event-title { align-items: flex-start; }
.event-title > span:first-child { white-space: normal; overflow: visible; text-overflow: clip; overflow-wrap: anywhere; line-height: 1.45; }
.event-badge { flex: 0 0 auto; display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; white-space: nowrap; }
.event-badge-start, .event-badge-updated { color: var(--info); background: var(--info-bg); }
.event-badge-success { color: var(--success); background: var(--success-bg); }
.event-badge-failed { color: var(--danger); background: var(--danger-bg); }
.event-badge-stopped, .event-badge-stopping { color: var(--warning); background: var(--warning-bg); }
.event-item-start { border-left-color: var(--info); }
.event-item-success { border-left-color: var(--success); }
.event-item-failed { border-left-color: var(--danger); }
.event-item-stopped, .event-item-stopping { border-left-color: var(--warning); }
.event-item-updated { border-left-color: var(--info); }
.event-item .item-body, .event-meta { margin-top: 0; }
.button-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; }

/* 需求/反馈卡片：进度 + 操作脚 + 追加任务 */
.intake-progress { margin-top: 12px; }
.intake-item .item-foot {
  display: flex; align-items: center; gap: 12px; margin-top: 12px;
  padding-top: 10px; border-top: 1px solid var(--line-soft);
}
.intake-item .item-foot .meta { margin-top: 0; margin-left: auto; }
.intake-item .item-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
.intake-item .danger-link { color: var(--danger); }
.intake-item .danger-link:hover { text-decoration: underline; }
.append-row {
  display: flex; gap: 8px; margin-top: 12px;
  padding: 10px; border-radius: var(--r-sm);
  background: var(--bg-soft); border: 1px dashed var(--line);
}
.append-input { flex: 1 1 auto; padding: 7px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); font: inherit; font-size: 12.5px; }
.append-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.inline-editor { display: grid; gap: 10px; margin-top: 12px; }
.inline-editor .field { margin-bottom: 0; }
.inline-editor textarea { min-height: 140px; }
.attachment-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
.attachment-thumb, .attachment-file { display: grid; gap: 6px; width: 120px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); }
.attachment-thumb img { width: 100%; aspect-ratio: 1; border-radius: 4px; object-fit: cover; background: var(--brand-50); }
.attachment-thumb span, .attachment-file span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
.attachment-file small { color: var(--text-3); font-size: 12px; }

.app-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); }
.app-header .brand { display: flex; align-items: center; gap: 12px; }
.brand-mark { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 800; font-size: 18px; box-shadow: 0 8px 18px rgba(77, 110, 255, 0.35); }
.app-header h1 { font-size: 17px; font-weight: 700; }
.app-header p { font-size: 11px; color: var(--text-3); margin-top: 2px; }
.header-actions { display: flex; align-items: center; gap: 10px; }
.projects-main { height: calc(100vh - 77px); overflow: auto; padding: 28px 32px 48px; }
.projects-hero { display: flex; align-items: flex-end; gap: 20px; flex-wrap: wrap; margin-bottom: 22px; }
.projects-hero h2 { font-size: 24px; font-weight: 800; }
.projects-hero p { font-size: 13px; color: var(--text-3); margin-top: 6px; }
.hero-stats { margin-left: auto; display: flex; gap: 24px; }
.hero-stat { text-align: right; }
.hero-stat b { display: block; font-size: 22px; font-weight: 800; color: var(--text-1); }
.hero-stat span { font-size: 11px; color: var(--text-3); }
.projects-toolbar { margin-bottom: 20px; }
.search-input { width: 100%; max-width: 400px; padding: 10px 14px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); font: inherit; font-size: 13px; }
.search-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.project-card { position: relative; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
.project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
.project-card-top { display: flex; align-items: flex-start; gap: 12px; }
.project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
.project-info { min-width: 0; flex: 1 1 auto; }
.project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.project-card-menu { flex: 0 0 auto; }
.ctx-details { position: relative; }
.ctx-details > summary { list-style: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; color: var(--text-3); line-height: 1; cursor: pointer; }
.ctx-details > summary::-webkit-details-marker { display: none; }
.ctx-details > summary:hover { background: var(--bg-hover); color: var(--text-1); }
.ctx-more-icon { --icon-size: 18px; }
.ctx-menu { position: absolute; right: 0; top: calc(100% + 4px); z-index: 60; min-width: 150px; padding: 5px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-md); box-shadow: var(--shadow-lg); display: flex; flex-direction: column; gap: 2px; }
.ctx-menu button { display: flex; align-items: center; gap: 9px; width: 100%; padding: 8px 10px; border: 0; border-radius: var(--r-sm); background: transparent; color: var(--text-2); text-align: left; font-size: 12.5px; white-space: nowrap; }
.ctx-menu button span { min-width: 0; }
.ctx-menu button:hover { background: var(--bg-hover); color: var(--text-1); }
.ctx-menu .ctx-danger { color: var(--danger); }
.ctx-menu .ctx-danger:hover { background: var(--danger-bg); }
.project-desc { font-size: 12.5px; color: var(--text-2); line-height: 1.55; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.project-loop-status { display: flex; align-items: center; gap: 8px; margin-top: 12px; color: var(--text-2); font-size: 12px; font-weight: 600; }
.project-loop-status .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
.project-loop-status .led.stopped { box-shadow: 0 0 0 3px var(--line); }
.project-loop-interval { margin-left: auto; color: var(--text-3); font-family: var(--font-mono); font-weight: 500; }
.project-cli-badge { padding: 1px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-600); font-size: 11px; font-weight: 600; }
.field-hint { color: var(--text-3); font-size: 11px; font-weight: 500; }
.project-meta { font-size: 11px; color: var(--text-4); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line-soft); }

.workspace-shell { display: grid; grid-template-columns: 248px 1fr; height: 100vh; }
.workspace-main { display: flex; flex-direction: column; min-width: 0; height: 100vh; overflow: hidden; }
.sidebar { display: flex; flex-direction: column; gap: 6px; padding: 22px 14px 18px; background: var(--bg-elevated); border-right: 1px solid var(--line); height: 100vh; overflow-y: auto; }
.sidebar .brand { display: flex; align-items: center; gap: 12px; padding: 4px 10px 18px; }
.sidebar .brand-name { font-size: 17px; font-weight: 700; }
.sidebar .brand-sub { font-size: 11px; color: var(--text-3); margin-top: 2px; }
.back-link { display: flex; align-items: center; gap: 8px; margin: 0 4px 10px; padding: 8px 10px; border: 0; border-radius: var(--r-sm); background: transparent; color: var(--text-2); font-size: 12.5px; font-weight: 600; width: calc(100% - 8px); }
.back-link:hover { background: var(--bg-hover); color: var(--text-1); }
.project-switcher { margin: 0 4px 10px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); }
.project-label { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; color: var(--text-4); margin-bottom: 8px; }
.project-select { width: 100%; padding: 8px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); font: inherit; font-size: 13px; font-weight: 600; color: var(--text-1); }
.project-switcher .project-path { margin-top: 8px; font-size: 11px; }
.nav-group-label { padding: 12px 12px 6px; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-4); font-weight: 700; }
.nav-item { display: flex; align-items: center; gap: 12px; width: 100%; padding: 10px 12px; border: 0; border-radius: var(--r-md); background: transparent; color: var(--text-2); text-align: left; font-size: 13.5px; font-weight: 500; transition: background 0.14s, color 0.14s; }
.nav-item:hover { background: var(--bg-hover); color: var(--text-1); }
.nav-item.active { background: var(--brand-50); color: var(--brand-700); font-weight: 600; }
.nav-ico { width: 20px; height: 20px; flex: 0 0 auto; color: var(--text-3); display: grid; place-items: center; line-height: 0; }
.nav-item.active .nav-ico { color: var(--brand-600); }
.sidebar-footer { margin-top: auto; padding: 12px; border-radius: var(--r-md); background: var(--bg-soft); border: 1px solid var(--line-soft); }
.loop-mini { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text-2); }
.loop-mini b { color: var(--text-1); }
.loop-config { font-size: 11px; color: var(--text-3); margin-top: 6px; }

.topbar { display: flex; align-items: center; gap: 16px; padding: 16px 28px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); flex: 0 0 auto; }
.topbar-title { min-width: 0; }
.topbar-title h1 { font-size: 18px; font-weight: 700; }
.topbar-title p { font-size: 12px; color: var(--text-3); margin-top: 2px; }
.topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }
.workspace-search { display: flex; align-items: center; gap: 10px; flex: 1 1 420px; max-width: 580px; min-width: 280px; margin-left: auto; }
.workspace-search + .topbar-actions { margin-left: 0; }
.workspace-search-field { position: relative; flex: 1 1 auto; min-width: 0; }
.workspace-search-input.search-input { max-width: none; padding: 9px 38px 9px 36px; color: var(--text-1); transition: background 0.14s, border-color 0.14s, box-shadow 0.14s; }
.workspace-search-input.search-input:hover:not(:disabled) { background: var(--bg-soft); border-color: #cdd8ea; }
.workspace-search-input.search-input:disabled { background: var(--bg-soft); color: var(--text-4); cursor: not-allowed; }
.workspace-search-icon { position: absolute; left: 13px; top: 50%; z-index: 1; color: var(--text-3); transform: translateY(-50%); pointer-events: none; }
.workspace-search-clear { position: absolute; right: 6px; top: 50%; display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 8px; background: transparent; color: var(--text-3); transform: translateY(-50%); transition: background 0.14s, color 0.14s; }
.workspace-search-clear:hover { background: var(--bg-hover); color: var(--text-1); }
.workspace-search-clear:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--brand-50); color: var(--brand-600); }
.workspace-search-clear:disabled { color: var(--text-4); cursor: not-allowed; }
.workspace-search-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 600; white-space: nowrap; }
.workspace-search-count.is-empty { color: var(--warning); }
.search-results { flex: 0 0 auto; margin: 16px 28px 0; overflow: hidden; }
.search-results-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 14px 16px; border-bottom: 1px solid var(--line-soft); }
.search-results-head h2 { font-size: 14.5px; font-weight: 750; }
.search-results-head p { margin-top: 3px; color: var(--text-3); font-size: 12px; }
.search-results-head b { color: var(--text-1); }
.search-results-clear { flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--brand-600); font-size: 12px; font-weight: 700; }
.search-results-clear:hover { background: var(--brand-50); border-color: #cdd8ea; }
.search-source-strip { display: flex; gap: 8px; padding: 12px 16px; border-bottom: 1px solid var(--line-soft); overflow-x: auto; }
.search-source-chip { display: inline-flex; align-items: center; gap: 7px; flex: 0 0 auto; padding: 6px 10px; border: 1px solid var(--line); border-radius: 999px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; transition: background 0.14s, border-color 0.14s, color 0.14s; }
.search-source-chip b { min-width: 20px; padding: 1px 6px; border-radius: 999px; background: var(--bg-elevated); color: var(--brand-600); text-align: center; }
.search-source-chip:hover:not(:disabled) { background: var(--brand-50); border-color: #cdd8ea; color: var(--brand-700); }
.search-source-chip:disabled { cursor: default; color: var(--text-4); }
.search-source-chip:disabled b { color: var(--text-4); }
.search-results-body { max-height: min(420px, 42vh); overflow: auto; padding: 14px 16px 16px; }
.search-result-groups { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
.search-result-group { min-width: 0; display: flex; flex-direction: column; gap: 10px; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
.search-result-group.is-empty { color: var(--text-4); }
.search-result-group-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.search-result-group-title { display: inline-flex; align-items: center; gap: 8px; min-width: 0; color: var(--text-1); font-size: 13px; font-weight: 750; }
.search-result-group-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.search-result-group-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 700; }
.search-result-items { display: grid; gap: 8px; }
.search-result-item { width: 100%; min-width: 0; display: grid; gap: 7px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); text-align: left; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
.search-result-item:hover { background: #fff; border-color: #cdd8ea; }
.search-result-item:active { transform: translateY(1px); }
.search-result-item:focus-visible { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.search-result-item-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
.search-result-title { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; font-weight: 700; }
.search-result-status { flex: 0 0 auto; max-width: 42%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 2px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-700); font-size: 11px; font-weight: 750; }
.search-result-snippet { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-2); font-size: 12.5px; line-height: 1.5; overflow-wrap: anywhere; }
.search-result-meta { display: flex; justify-content: space-between; gap: 10px; color: var(--text-4); font-size: 11px; }
.search-result-meta span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.search-result-more { width: 100%; padding: 7px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); background: transparent; color: var(--brand-600); font-size: 12px; font-weight: 700; }
.search-result-more:hover { background: var(--brand-50); }
.search-result-group-empty { padding: 18px 10px; border: 1px dashed var(--line); border-radius: var(--r-sm); color: var(--text-4); text-align: center; font-size: 12px; }
.search-results-empty { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 16px; color: var(--text-3); font-size: 13px; }
.pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; background: var(--bg-soft); border: 1px solid var(--line); color: var(--text-2); }
.led { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 4px var(--success-bg); }
.pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
.led.running { animation: led-pulse 1.6s ease-in-out infinite; }
.led.stopped { background: var(--text-4); box-shadow: 0 0 0 4px var(--line); }
@keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,0.15); } }
.view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 24px 28px 32px; display: none; }
.view.active { display: flex; flex-direction: column; }
/* 概览等纯流式内容视图：恢复 block，内部自己滚动 */
.view.active:has(.overview-grid),
.view.active:has(.stat-grid),
.view.active > section.card:only-child { display: block; }

.stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 20px; margin-bottom: 24px; }
.stat { position: relative; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
.stat::after { content: ""; position: absolute; right: -18px; top: -18px; width: 84px; height: 84px; border-radius: 50%; opacity: 0.5; }
.stat-brand::after { background: var(--brand-50); }
.stat-info::after { background: var(--info-bg); }
.stat-success::after { background: var(--success-bg); }
.stat-warning::after { background: var(--warning-bg); }
.stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; line-height: 0; }
.stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }
.stat-info .stat-ico { background: var(--info-bg); color: var(--info); }
.stat-success .stat-ico { background: var(--success-bg); color: var(--success); }
.stat-warning .stat-ico { background: var(--warning-bg); color: var(--warning); }
.stat .stat-value { font-size: 26px; font-weight: 800; line-height: 1; position: relative; z-index: 1; }
.stat .stat-label { font-size: 12px; color: var(--text-3); margin-top: 6px; position: relative; z-index: 1; }
.stat .stat-delta { font-size: 11px; margin-top: 8px; color: var(--success); font-weight: 600; position: relative; z-index: 1; }
.overview-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(380px,1fr); align-items: stretch; gap: 24px; }
.overview-main-column, .overview-side-column { display: flex; flex-direction: column; gap: 20px; min-width: 0; }
.overview-side-column .card-head h2 { white-space: nowrap; }
.loop-card { background: var(--brand-grad); color: #fff; border-radius: var(--r-lg); padding: 22px 24px; position: relative; overflow: hidden; box-shadow: 0 18px 40px rgba(77,110,255,0.28); }
.loop-card .lc-top { display: flex; align-items: center; gap: 12px; }
.loop-card .lc-status { font-size: 13px; opacity: 0.9; }
.loop-card .lc-phase { font-size: 22px; font-weight: 800; margin-top: 4px; }
.loop-card .lc-meta { display: flex; gap: 22px; margin-top: 16px; font-size: 12px; opacity: 0.92; }
.loop-card .lc-meta b { display: block; font-size: 15px; font-weight: 700; margin-top: 2px; }
.loop-card .lc-led { width: 12px; height: 12px; border-radius: 50%; background: #b6f5cf; box-shadow: 0 0 0 4px rgba(182,245,207,0.25); }
.loop-card .lc-led.running { animation: led-pulse 1.6s ease-in-out infinite; }
.loop-card .lc-led.stopped { background: #cfd6e6; box-shadow: 0 0 0 4px rgba(207,214,230,0.25); }

.pipeline { display: flex; align-items: flex-start; gap: 0; overflow-x: auto; }
.pipe-step { flex: 1 1 0; min-width: 0; text-align: center; position: relative; }
.pipe-node { width: 40px; height: 40px; margin: 0 auto; border-radius: 50%; display: grid; place-items: center; background: var(--bg-elevated); border: 2px solid var(--line); color: var(--text-3); font-weight: 700; font-size: 14px; position: relative; z-index: 1; }
.pipe-step.done .pipe-node { background: var(--success); border-color: var(--success); color: #fff; }
.pipe-step.active .pipe-node { background: var(--brand-600); border-color: var(--brand-600); color: #fff; box-shadow: 0 0 0 5px var(--brand-50); }
.pipe-status-icon { --icon-size: 18px; }
.pipe-step::before { content: ""; position: absolute; top: 20px; left: -50%; right: 50%; height: 2px; background: var(--line); z-index: 0; }
.pipe-step:first-child::before { display: none; }
.pipe-step.done::before, .pipe-step.active::before { background: var(--success); }
.pipe-label { font-size: 12px; font-weight: 600; margin-top: 10px; color: var(--text-2); }
.pipe-step.active .pipe-label { color: var(--brand-600); }

/* 实时执行日志（对话格式） */
.live-log-card { display: flex; flex-direction: column; min-height: 0; }
.live-log-card .card-head h2 { display: flex; align-items: center; gap: 8px; }
.overview-main-column > .live-log-card { height: 440px; }
.overview-main-column > .live-log-card .codex-log { flex: 1 1 auto; min-height: 0; max-height: none; }
.log-card-head { align-items: stretch; flex-direction: column; gap: 8px; padding: 12px 18px; }
.log-title-line { display: flex; align-items: center; gap: 12px; min-width: 0; }
.log-title-line h2 { flex: 0 0 auto; }
.log-title-line .hint { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.log-phase-chip { flex: 0 0 auto; border: 1px solid var(--line); border-radius: 999px; padding: 4px 9px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; white-space: nowrap; }
.log-phase-chip.running { color: var(--success); background: var(--success-bg); border-color: transparent; }
.log-summary { display: flex; align-items: center; gap: 18px; color: var(--text-3); font-size: 12px; }
.log-summary b { color: var(--text-1); margin-left: 4px; }
.live-dot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--success);
  box-shadow: 0 0 0 3px var(--success-bg);
  animation: led-pulse 1.4s ease-in-out infinite;
}
.live-dot.idle { background: var(--text-4); box-shadow: 0 0 0 3px var(--line); animation: none; }
.codex-log {
  margin: 0; padding: 10px;
  background: #1b2438; color: #d6e1f5;
  border-radius: 0 0 var(--r-lg) var(--r-lg);
  max-height: 380px; min-height: 120px; overflow: auto;
  font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
}
.codex-raw { margin: 0; white-space: pre-wrap; word-break: break-word; color: #8a96b0; padding: 8px; }

/* 活动时间线行 */
.act-line {
  display: grid; grid-template-columns: 56px 52px 1fr; gap: 8px;
  align-items: baseline; padding: 4px 8px; border-radius: 4px;
}
.act-line:hover { background: rgba(255,255,255,0.04); }
.act-time { color: #5a6680; font-size: 11px; font-variant-numeric: tabular-nums; }
.act-tag {
  display: inline-block; font-size: 10px; font-weight: 700;
  padding: 1px 7px; border-radius: 999px; text-align: center;
  letter-spacing: 0.02em;
}
.act-text { color: #c8d3ec; word-break: break-word; white-space: pre-wrap; }

.act-codex .act-tag { background: rgba(109,93,252,0.3); color: #c4b8ff; }
.act-codex .act-text { color: #e0e6ff; }
.act-exec .act-tag { background: rgba(24,169,87,0.3); color: #7fe0a8; }
.act-exec .act-text { color: #9fd8b8; }
.act-thinking .act-tag { background: rgba(224,134,0,0.3); color: #ffc878; }
.act-thinking .act-text { color: #d8b878; font-style: italic; }
.act-error .act-tag { background: rgba(229,72,77,0.35); color: #ff9498; }
.act-error .act-text { color: #ff9498; }
.act-system .act-tag { background: rgba(124,135,155,0.3); color: #a0aac0; }
.act-system .act-text { color: #a0aac0; }
.act-user .act-tag { background: rgba(59,110,245,0.3); color: #8ab0ff; }
.act-user .act-text { color: #b8c8f0; }
.act-info .act-tag { background: rgba(124,135,155,0.25); color: #8a96b0; }
.act-info .act-text { color: #b0bbd6; }

.intake-layout { display: grid; grid-template-rows: minmax(0,1fr) auto; gap: 16px; flex: 1 1 0; min-height: 0; max-width: 880px; margin: 0 auto; width: 100%; }
.intake-layout > .composer { margin-bottom: 24px; }
.intake-stream { display: grid; grid-template-rows: auto minmax(0,1fr); min-height: 0; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--bg-elevated); padding: 18px; }
.section-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
.section-heading h2 { margin-bottom: 0; }
.section-heading span { color: var(--text-3); font-size: 12px; }
.intake-list { min-height: 0; overflow: auto; padding-right: 4px; display: flex; flex-direction: column; gap: 10px; }

.composer { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-xl); padding: 14px 16px 12px; box-shadow: var(--shadow-lg); transition: border-color 0.16s, box-shadow 0.16s; }
.composer:focus-within { border-color: var(--brand-500); box-shadow: 0 18px 48px rgba(37,62,120,0.2); }
.composer.drag-over { border-color: var(--brand-500); background: var(--brand-50); }
.composer textarea { width: 100%; border: 0; outline: none; resize: none; background: transparent; font: inherit; font-size: 14.5px; line-height: 1.5; color: var(--text-1); min-height: 58px; max-height: 180px; overflow: auto; }
.composer textarea::placeholder { color: var(--text-4); }
.composer-bottom { display: flex; align-items: center; gap: 10px; min-width: 0; margin-top: 8px; }
.composer-tools { display: flex; align-items: center; gap: 10px; flex: 1 1 auto; min-width: 0; }
.attachment-trigger { display: grid; place-items: center; width: 40px; height: 40px; flex: 0 0 auto; padding: 0; border: 0; border-radius: 50%; background: transparent; color: var(--text-3); cursor: pointer; }
.attachment-trigger:hover, .attachment-trigger.drag-over { background: var(--bg-hover); }
.attachment-trigger input { display: none; }
.attachment-trigger-icon { color: var(--text-3); }
.composer-actions { display: flex; align-items: center; justify-content: end; gap: 10px; flex: 0 0 auto; margin-left: auto; }
.composer-actions span { color: var(--text-3); font-size: 12px; }
.send-button { display: grid; place-items: center; width: 42px; height: 42px; flex: 0 0 auto; border: 0; border-radius: 50%; padding: 0; background: var(--brand-grad); color: #fff; font-size: 20px; line-height: 1; box-shadow: 0 6px 14px rgba(77,110,255,0.4); }
.send-button:hover { filter: brightness(1.05); }
.attachment-list.pending { display: flex; align-items: center; flex: 1 1 auto; min-width: 0; max-width: 100%; gap: 8px; overflow-x: auto; }
.pending-attachment { display: grid; grid-template-columns: 42px minmax(88px,1fr) auto auto; align-items: center; flex: 0 0 min(340px,72vw); gap: 8px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-soft); }
.pending-thumb, .pending-file-icon { width: 42px; height: 42px; border-radius: var(--r-sm); background: var(--brand-50); }
.pending-thumb { object-fit: cover; }
.pending-file-icon { display: grid; place-items: center; color: var(--text-3); }
.pending-attachment span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pending-attachment small { color: var(--text-3); }
.pending-attachment button { padding: 5px 8px; font-size: 12px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); }

.task-main { display: grid; grid-template-rows: 1fr; gap: 16px; min-height: 0; }
.task-status-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 16px; min-height: 0; }
.settings-layout { flex: 1 1 0; min-height: 0; overflow: auto; padding-bottom: 8px; }
.settings-card { max-width: 560px; margin: 0; }
.primary-section, .side-section, .task-status-grid .card { min-height: 0; overflow: hidden; display: flex; flex-direction: column; }
.side-section .list, .task-status-grid .list, .primary-section .list { overflow: auto; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; color: var(--text-3); font-size: 11.5px; font-weight: 600; }
.field:last-child { margin-bottom: 0; }
input, textarea, select { width: 100%; border: 1px solid var(--line); border-radius: var(--r-sm); padding: 9px 11px; font: inherit; font-size: 13px; color: var(--text-1); background: var(--bg-elevated); font-weight: 400; }
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
textarea { min-height: 80px; resize: vertical; }

.modal-mask { position: fixed; inset: 0; z-index: 100; overflow: auto; background: rgba(23,32,51,0.42); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 24px; }
.modal { width: 100%; max-width: 480px; background: var(--bg-elevated); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); overflow: hidden; }
.modal-confirm { max-width: 400px; text-align: center; padding: 28px 24px 0; }
.modal-head { display: flex; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line-soft); }
.modal-head h3 { font-size: 16px; font-weight: 700; }
.modal-close { margin-left: auto; width: 30px; height: 30px; border-radius: 8px; border: 0; background: transparent; color: var(--text-3); display: grid; place-items: center; }
.modal-close:hover { background: var(--bg-hover); color: var(--text-1); }
.modal-form { padding: 20px 22px; }
.modal-confirm p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin: 8px 0 4px; }
.modal-danger-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 50%; background: var(--danger-bg); color: var(--danger); margin: 0 auto 14px; }
.modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--line-soft); background: var(--bg-soft); }

.plan-reader-modal { width: 100%; max-width: min(920px, calc(100vw - 48px)); max-height: min(86dvh, 860px); display: flex; flex-direction: column; }
.plan-reader-head { flex: 0 0 auto; align-items: flex-start; }
.plan-reader-title { min-width: 0; display: flex; flex: 1 1 auto; flex-direction: column; gap: 5px; }
.plan-reader-path { max-width: 100%; overflow: hidden; color: var(--text-3); font-size: 12px; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
.plan-reader-actions { flex: 0 0 auto; }
.plan-reader-body { flex: 1 1 auto; min-height: 0; overflow: auto; overscroll-behavior: contain; padding: 16px 22px 22px; display: flex; flex-direction: column; gap: 14px; }
.plan-reader-body:focus-visible { outline: 2px solid var(--brand-500); outline-offset: -4px; }
.plan-reader-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin: 0; }
.plan-reader-summary-item { min-width: 0; padding: 10px 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
.plan-reader-summary-item dt { display: block; margin-bottom: 4px; color: var(--text-3); font-size: 11px; font-weight: 700; }
.plan-reader-summary-item dd { display: block; min-width: 0; margin: 0; overflow: hidden; color: var(--text-1); font-size: 12.5px; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.plan-reader-content { min-width: 0; padding: 16px; overflow: visible; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); box-shadow: var(--shadow-sm); }
.plan-reader-loading, .plan-reader-error { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; padding: 14px 16px; border-radius: var(--r-md); font-size: 13px; line-height: 1.5; }
.plan-reader-loading { border: 1px dashed var(--line); background: var(--bg-soft); color: var(--text-3); }
.plan-reader-error { border: 1px solid rgba(229,72,77,0.28); background: var(--danger-bg); color: var(--danger); }

@media (max-width: 1080px) {
  body { overflow: auto; }
  .workspace-shell { grid-template-columns: 1fr; height: auto; }
  .sidebar { height: auto; }
  .workspace-main { height: auto; min-height: 100vh; }
  .topbar { flex-wrap: wrap; align-items: flex-start; }
  .workspace-search { order: 3; flex-basis: 100%; max-width: none; min-width: 0; margin-left: 0; }
  .workspace-search + .topbar-actions { margin-left: auto; }
  .search-results { margin: 14px 20px 0; }
  .task-main { grid-template-rows: auto auto; }
  .task-status-grid { grid-template-columns: 1fr; }
  .overview-grid { grid-template-columns: 1fr; }
  .overview-main-column > .live-log-card { height: 360px; }
}

@media (max-width: 640px) {
  .view { padding: 18px 14px 24px; }
  .topbar { padding: 14px; }
  .topbar-actions { width: 100%; justify-content: space-between; flex-wrap: wrap; }
  .workspace-search { flex-direction: column; align-items: stretch; gap: 6px; }
  .workspace-search-count { padding-left: 2px; }
  .search-results { margin: 12px 14px 0; }
  .search-results-head, .search-results-empty { align-items: stretch; flex-direction: column; }
  .search-results-clear, .search-results-empty .btn { width: 100%; }
  .search-result-groups { grid-template-columns: 1fr; }
  .search-result-meta { flex-direction: column; gap: 3px; }
  .stat-grid { grid-template-columns: 1fr; }
  .card-head { flex-wrap: wrap; align-items: flex-start; }
  .item-title { align-items: flex-start; flex-wrap: wrap; }
  .item-title-right { width: 100%; justify-content: space-between; flex-wrap: wrap; }
  .plan-reader-modal { max-width: none; max-height: calc(100dvh - 28px); }
  .plan-reader-head { padding: 16px; }
  .plan-reader-actions { width: 100%; justify-content: space-between; }
  .plan-reader-body { padding: 14px; }
  .plan-reader-summary { grid-template-columns: 1fr; }
  .plan-reader-content { padding: 12px; }
  .markdown-reader { font-size: 13px; line-height: 1.68; }
  .event-title { gap: 8px; }
}

::-webkit-scrollbar { width: 9px; height: 9px; }
::-webkit-scrollbar-thumb { background: #d4dce8; border-radius: 999px; border: 2px solid transparent; background-clip: content-box; }
::-webkit-scrollbar-thumb:hover { background: #b9c5d8; background-clip: content-box; }
::-webkit-scrollbar-track { background: transparent; }


