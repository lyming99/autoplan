      <span className="search-result-meta">
        <span>{primaryMatch ? '鐐瑰嚮鍚庡垏鎹㈠埌瀵瑰簲鍒楄〃' : '鐐瑰嚮鏌ョ湅鍖归厤璁板綍'}</span>
        {updatedAt ? <span>{updatedAt}</span> : null}
      </span>
    </button>
  );
}

