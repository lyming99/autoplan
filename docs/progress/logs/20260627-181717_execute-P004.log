@@ -101,3 +101,71 @@
     align-items: flex-start;
   }
 }
+
+.workspace-search-popover-anchor {
+  position: relative;
+  z-index: 30;
+  display: flex;
+  align-items: center;
+  flex: 1 1 420px;
+  max-width: 580px;
+  min-width: 280px;
+  margin-left: auto;
+}
+
+.workspace-search-popover-anchor .workspace-search {
+  width: 100%;
+  max-width: none;
+  margin-left: 0;
+}
+
+.workspace-search-popover-anchor + .topbar-actions {
+  margin-left: 0;
+}
+
+.search-results-popup {
+  position: absolute;
+  top: calc(100% + 10px);
+  right: 0;
+  z-index: 80;
+  width: min(760px, calc(100vw - 48px));
+  max-height: min(620px, calc(100vh - 116px));
+  margin: 0;
+  overflow: hidden;
+  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18), var(--shadow-sm);
+}
+
+.search-results-popup .search-results-body {
+  max-height: min(440px, calc(100vh - 270px));
+}
+
+.search-results-popup .search-result-groups {
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
+}
+
+@media (max-width: 900px) {
+  .workspace-search-popover-anchor {
+    order: 3;
+    flex-basis: 100%;
+    max-width: none;
+    min-width: 0;
+    margin-left: 0;
+  }
+
+  .workspace-search-popover-anchor + .topbar-actions {
+    margin-left: auto;
+  }
+}
+
+@media (max-width: 760px) {
+  .search-results-popup {
+    left: 0;
+    right: auto;
+    width: 100%;
+    max-height: min(620px, calc(100vh - 96px));
+  }
+
+  .search-results-popup .search-result-groups {
+    grid-template-columns: 1fr;
+  }
+}

