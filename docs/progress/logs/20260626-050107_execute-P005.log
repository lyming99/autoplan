 1010:       '- 只有当前任务本身明确要求全量验证时，才允许运行全量测试',
 1011:       '- 不输出完整 diff、源码全文或长文件列表',
 1012:       '- 中文文件读写使用 UTF-8',
 1013:     ];
 1014:     if (options.parallel) {
 1015:       completionRules.unshift('- 当前为并发执行模式，不要读写其它任务的 scope');
 1016:     }
 1017:     const prompt = [
 1018:       '你是开发执行者。',
 1019:       `请只执行指定任务 ${task.task_key}，不要提前执行其它任务，也不要顺手处理其它 checkbox。`,
 1020:       '',
 1021:       `plan 文件（只读）：${planFile}`,
 1022:       `指定任务：${task.raw_line}`,
 1023:       `任务 scope：${task.scope || taskScopeText(task) || 'unknown'}`,
 1024:       '',
 1025:       '完成后必须：',
 1026:       ...completionRules,
 1027:     ].join('\n');
 1028:     let result;
 1029:     try {
 1030:       result = await this.runCodexWithPlanGuard(workspace, prompt, `execute-${task.task_key}`, {
 1031:         projectId: plan.project_id,
 1032:         planId: plan.id,
 1033:         taskId: task.id,
 1034:         parallel: Boolean(options.parallel),
 1035:         ...taskAgentCliContext,
 1036:         ...(isTaskCodexProvider && existingSessionId ? { codexSessionId: existingSessionId } : {}),
 1037:       }, planFile);
 1038:     } catch (error) {
 1039:       const finishedAt = nowIso();
 1040:       const failedTask = this.recordTaskFailure(plan.project_id, plan, task, finishedAt, {
 1041:         ...taskAgentCliContext,
 1042:         error: error?.message || String(error),
 1043:         ...startedSessionContext,
 1044:       });
