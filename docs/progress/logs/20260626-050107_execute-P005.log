 1280:   async runCodexWithPlanGuard(workspace, prompt, label, operation, planFile) {
 1281:     const before = planFile && fs.existsSync(planFile) ? fs.readFileSync(planFile, 'utf8') : null;
 1282:     const result = await this.runCodex(workspace, prompt, label, operation);
 1283:     if (before !== null) {
 1284:       const changed = !fs.existsSync(planFile) || fs.readFileSync(planFile, 'utf8') !== before;
 1285:       if (changed) {
 1286:         fs.writeFileSync(planFile, before, 'utf8');
 1287:         this.addEvent(operation.projectId, 'plan.guard.restored', `${agentCliProviderDisplayName(result.agentCliProvider)} 修改了 plan，已恢复：${normalizeRelative(workspace, planFile)}`, {
 1288:           ...agentCliContextFields(result),
 1289:           planId: operation.planId || null,
 1290:           taskId: operation.taskId || null,
 1291:         });
 1292:       }
 1293:     }
 1294:     return result;
 1295:   }
