  611:       `UPDATE plan_tasks SET status = ?, updated_at = ?
  612:        WHERE plan_id = ? AND status IN ('pending', 'running')`,
  613:       ['blocked', nowIso(), planId],
  614:     );
  615:     this.db.run('UPDATE plans SET status = ?, updated_at = ? WHERE id = ?', ['interrupted', nowIso(), planId]);
  616:     this.addEvent(projectId, 'plan.interrupted', `plan #${planId} 已中断，未完成任务已挂起`);
  617:     this.emitUpdate(projectId);
