 1297:   async runCodex(workspace, prompt, label, operation = {}) {
 1298:     const projectIdForEmit = operation.projectId;
 1299:     const runtime = this.runtime(projectIdForEmit);
 1300:     if (!runtime) throw new Error('projectId is required for codex operations');
 1301:     const projectStatus = projectIdForEmit ? this.status(projectIdForEmit) : null;
 1302:     const agentCliProvider = normalizeAgentCliProvider(projectStatus?.agent_cli_provider);
 1303:     const agentCliCommand = normalizeAgentCliCommand(projectStatus?.agent_cli_command);
 1304:     const isCodexProvider = agentCliProvider === DEFAULT_AGENT_CLI_PROVIDER;
 1305:     const logDir = path.join(workspace, 'docs', 'progress', 'logs');
 1306:     fs.mkdirSync(logDir, { recursive: true });
 1307:     const prefix = `${timestampForPath()}_${safePart(label)}`;
 1308:     const logFile = path.join(logDir, `${prefix}.log`);
 1309:     const lastFile = path.join(logDir, `${prefix}.last.txt`);
 1310:     const hasSessionOption = isCodexProvider && hasCodexSessionOption(operation);
 1311:     const requestedSessionId = isCodexProvider ? operationCodexSessionId(operation) : '';
 1312:     const activeOperation = {
 1313:       ...operation,
 1314:       label,
 1315:       logFile,
 1316:       lastFile,
 1317:       agentCliProvider,
 1318:       agentCliCommand,
 1319:       ...(isCodexProvider
 1320:         ? {
 1321:             codexSessionId: requestedSessionId || null,
