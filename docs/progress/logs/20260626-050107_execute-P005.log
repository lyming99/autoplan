  935:   parallelTaskBatch(tasks) {
  936:     const selected = [];
  937:     const usedScopes = new Set();
  938:     for (const task of tasks) {
  939:       if (selected.length >= MAX_PARALLEL_TASKS) break;
  940:       const scopes = taskParallelScopes(task);
  941:       if (!scopes.length) {
  942:         if (!selected.length) return [task];
  943:         continue;
  944:       }
  945:       if (scopes.some((scope) => usedScopes.has(scope))) continue;
  946:       selected.push(task);
  947:       for (const scope of scopes) usedScopes.add(scope);
  948:     }
  949:     return selected.length > 1 ? selected : [tasks[0]];
  950:   }
  951: 
  952:   async executeTaskBatch(workspace, plan, tasks) {
  953:     this.setPhase(plan.project_id, 'execute-task');
  954:     const agentContext = agentCliContextFields(this.status(plan.project_id), { defaultProvider: true });
  955:     this.addEvent(
  956:       plan.project_id,
  957:       'tasks.parallel.started',
  958:       `${agentCliProviderDisplayName(agentContext.agentCliProvider)} 并发执行 ${tasks.map((task) => task.task_key).join(', ')}`,
  959:       { ...agentContext, taskIds: tasks.map((task) => task.id) },
  960:     );
  961:     const results = await Promise.all(
  962:       tasks.map(async (task) => {
  963:         let result;
  964:         try {
  965:           result = await this.executeTask(workspace, plan, task, { parallel: true });
  966:         } catch (error) {
  967:           const finishedAt = nowIso();
  968:           if (!taskLifecycleEventRecorded(error)) {
  969:             this.recordTaskFailure(plan.project_id, plan, task, finishedAt, {
  970:               error: error?.message || String(error),
  971:             });
  972:           }
  973:           return { task, result: { exitCode: -1, finishedAt } };
  974:         }
  975:         if (result.exitCode === 0) {
  976:           this.completeTask(workspace, plan, task, result);
  977:         }
  978:         return { task, result };
  979:       }),
  980:     );
  981:     return results;
  982:   }
