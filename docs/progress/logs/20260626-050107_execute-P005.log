    1: /**
    2:  * 移植自 run_advanced_plan_with_codex.dart 的 CodexActivityPrinter。
    3:  * 从 codex 的 stdout 原始流中提取**人类可读的活动时间线**：
    4:  * - 跳过 user 回显、版本头、session 信息等噪音
    5:  * - 识别 codex/exec/thinking 等段落
    6:  * - 抽取含关键词的活动行（思考/执行/完成/验证/报错等）
    7:  * - 节流输出 Tail 行
    8:  *
    9:  * offer(rawChunk) 喂入原始流（可能含多行），getLines() 返回当前活动行列表。
   10:  */
   11: 
   12: const ANSI_RE = /\x1B\[[0-?]*[ -/]*[@-~]/g;
   13: const SPINNER_RE = /^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]\s*/;
   14: const LEAD_RE = /^[>•*+\-\s]+/;
   15: 
   16: const ACTIVITY_KEYWORDS = [
   17:   'thinking', 'plan', 'running', 'exec', 'command', 'test', 'analyze',
   18:   'flutter', 'dart', 'complete', 'completed', 'summary', 'verification',
   19:   'blocked', 'error', 'failed', 'warning', 'reconnect',
   20:   '思考', '计划', '执行', '运行', '命令', '测试', '分析', '检查',
   21:   '验证', '完成', '阻塞', '摘要', '推进', '报错', '失败', '重连',
   22: ];
   23: 
   24: const NOISE_PREFIXES = [
   25:   'openai codex', 'workdir:', 'model:', 'provider:', 'approval:', 'sandbox:',
   26:   'reasoning effort:', 'reasoning summaries:', 'session id:', 'usage:',
   27:   'options:', 'warning:', 'succeeded in', 'exitcode',
   28: ];
   29: 
   30: const MODEL_START_RE = /^(codex|exec|assistant|\*\*|Planning |我|正在|我会|先|接下来|完成|修改|运行)/;
   31: 
   32: class CodexActivityPrinter {
   33:   constructor(maxLines = 200) {
   34:     this.maxLines = maxLines;
   35:     this.lines = [];
   36:     this.recent = new Set();
   37:     this.skippingUserEcho = false;
   38:     this.currentRole = 'info';
   39:     this.pendingLine = '';
   40:   }
   41: 
   42:   /** 喂入一段原始文本（可含多行） */
   43:   offer(rawChunk) {
   44:     const text = String(rawChunk || '').replace(ANSI_RE, '').replace(/\r/g, '');
   45:     this.pendingLine += text;
   46:     while (true) {
   47:       const idx = this.pendingLine.indexOf('\n');
   48:       if (idx < 0) break;
   49:       const line = this.pendingLine.slice(0, idx);
   50:       this.pendingLine = this.pendingLine.slice(idx + 1);
   51:       this.processLine(line);
   52:     }
   53:   }
   54: 
   55:   flush() {
   56:     const line = this.pendingLine;
   57:     this.pendingLine = '';
   58:     if (line.trim()) this.processLine(line);
   59:   }
   60: 
   61:   processLine(rawLine) {
   62:     const trimmed = rawLine.trim();
   63:     // 段落角色标记
   64:     if (['user', 'codex', 'exec', 'assistant', 'thinking', 'system', 'error'].includes(trimmed)) {
   65:       if (trimmed === 'user') {
   66:         this.skippingUserEcho = true;
   67:         return;
   68:       }
   69:       this.skippingUserEcho = false;
   70:       this.currentRole = trimmed === 'assistant' ? 'codex' : trimmed;
   71:       return;
   72:     }
   73:     // 跳过 user 回显
   74:     if (this.skippingUserEcho) {
   75:       if (MODEL_START_RE.test(trimmed)) {
   76:         this.skippingUserEcho = false;
   77:       } else {
   78:         return;
   79:       }
   80:     }
   81:     const clean = this.cleanLine(rawLine);
   82:     if (!clean) return;
   83:     if (this.isActivity(clean)) {
   84:       this.push(this.currentRole, clean);
   85:     }
   86:   }
   87: 
   88:   push(role, line) {
   89:     const compact = line.length > 200 ? `${line.slice(0, 197)}...` : line;
   90:     const key = `${role}:${compact}`;
   91:     if (this.recent.has(key)) return;
   92:     this.recent.add(key);
   93:     if (this.lines.length >= this.maxLines) {
   94:       this.lines.shift();
   95:       // 限制 recent 集合大小
   96:       if (this.recent.size > this.maxLines * 2) {
   97:         this.recent = new Set(this.lines.map((l) => `${l.role}:${l.text}`));
   98:       }
   99:     }
  100:     this.lines.push({ role, text: compact, at: new Date().toISOString() });
  101:   }
  102: 
  103:   cleanLine(rawLine) {
  104:     let line = String(rawLine || '').trim();
  105:     if (!line) return null;
  106:     line = line.replace(ANSI_RE, '').replace(LEAD_RE, '').replace(SPINNER_RE, '').trim();
  107:     if (!line) return null;
  108:     if (this.looksLikeNoise(line) || this.looksLikeFileContent(line)) return null;
  109:     return line;
  110:   }
  111: 
  112:   isActivity(line) {
  113:     const lower = line.toLowerCase();
  114:     return ACTIVITY_KEYWORDS.some((kw) => lower.includes(kw));
  115:   }
  116: 
  117:   looksLikeNoise(line) {
  118:     const lower = line.toLowerCase();
  119:     if (NOISE_PREFIXES.some((p) => lower.startsWith(p))) return true;
  120:     if (line === 'codex' || line === 'exec' || line === 'user') return true;
  121:     if (/^\d{1,2}:\d{2}(:\d{2})?$/.test(line)) return true;
  122:     if (/^[=\-_]{3,}$/.test(line)) return true;
  123:     return false;
  124:   }
  125: 
  126:   looksLikeFileContent(line) {
  127:     const lower = line.toLowerCase();
  128:     if (
  129:       line.startsWith('::') ||
  130:       line.startsWith('diff --git') ||
  131:       line.startsWith('@@') ||
  132:       line.startsWith('--- ') ||
  133:       line.startsWith('+++ ') ||
  134:       (line.startsWith('+') && !line.startsWith('+ ')) ||
  135:       (line.startsWith('-') && !line.startsWith('- '))
  136:     ) {
  137:       return true;
  138:     }
  139:     if (/^(import |class |final |const |return |if |for |void )/i.test(line)) return true;
  140:     if (line === '}' || line === '{') return true;
  141:     if (/^(lib|test|docs|tool|scripts|example)[/\\].+/i.test(line)) return true;
  142:     // 代码标点密度
  143:     const punct = (line.match(/[{}();=<>]/g) || []).length;
  144:     if (punct >= 6) return true;
  145:     // Dart/代码特征
  146:     if (/(=>|;\s*$|\$\{|Widget|BuildContext|StringBuffer)/.test(line)) return true;
  147:     return false;
  148:   }
  149: 
  150:   /** 返回当前活动行（供 snapshot） */
  151:   getLines() {
  152:     return this.lines.slice(-120);
  153:   }
  154: }
  155: 
  156: module.exports = { CodexActivityPrinter };

