 1082:   refreshPlanProgress(planId, planFile) {
 1083:     const totals = this.db.get(
 1084:       `SELECT COUNT(*) AS total,
 1085:               SUM(CASE WHEN status = 'completed' THEN 1 ELSE 0 END) AS completed
 1086:        FROM plan_tasks
 1087:        WHERE plan_id = ?`,
 1088:       [planId],
 1089:     ) || { total: 0, completed: 0 };
 1090:     const total = Number(totals.total || 0);
 1091:     const completed = Number(totals.completed || 0);
 1092:     const status = total > 0 && completed === total ? 'ready_for_validation' : 'running';
 1093:     const hash = fs.existsSync(planFile) ? hashFile(planFile) : '';
 1094:     this.db.run(
 1095:       'UPDATE plans SET hash = ?, status = ?, total_tasks = ?, completed_tasks = ?, updated_at = ? WHERE id = ?',
 1096:       [hash, status, total, completed, nowIso(), planId],
 1097:     );
 1098:   }
