  998:       ...taskAgentCliContext,
  999:       planId: plan.id,
 1000:       status: TASK_EVENT_STATUS.RUNNING,
 1001:       startedAt,
 1002:       ...startedSessionContext,
 1003:     });
 1004:     const planFile = path.join(workspace, plan.file_path);
 1005:     const completionRules = [
 1006:       '- plan 文件是只读上下文：不要修改 plan 文件，不要勾选 checkbox，不要更新 plan 进度区',
 1007:       '- AutoPlan 会在任务成功后统一写回数据库、checkbox 和进度区',
 1008:       '- 只修改当前任务 scope 直接相关的业务文件',
