  655:     let content = fs.readFileSync(planFile, 'utf8');
  656:     const line = ensureTaskScopeComment(`- [ ] ${taskKey}: ${cleanTitle}`);
  657:     const taskSectionIdx = content.search(/##\s*任务计划/);
  658:     if (taskSectionIdx === -1) {
  659:       content = `${content.trim()}\n\n## 任务计划\n${line}\n`;
  660:     } else {
  661:       content = `${content.trimEnd()}\n${line}\n`;
