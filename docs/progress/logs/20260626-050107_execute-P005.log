  957:       'tasks.parallel.started',
  958:       `${agentCliProviderDisplayName(agentContext.agentCliProvider)} 并发执行 ${tasks.map((task) => task.task_key).join(', ')}`,
  959:       { ...agentContext, taskIds: tasks.map((task) => task.id) },
  960:     );
  961:     const results = await Promise.all(
  962:       tasks.map(async (task) => {
  963:         let result;
  964:         try {
  965:           result = await this.executeTask(workspace, plan, task, { parallel: true });
  966:         } catch (error) {
  967:           const finishedAt = nowIso();
  968:           if (!taskLifecycleEventRecorded(error)) {
  969:             this.recordTaskFailure(plan.project_id, plan, task, finishedAt, {
  970:               error: error?.message || String(error),
  971:             });
  972:           }
  973:           return { task, result: { exitCode: -1, finishedAt } };
  974:         }
  975:         if (result.exitCode === 0) {
  976:           this.completeTask(workspace, plan, task, result);
  977:         }
  978:         return { task, result };
  979:       }),
  980:     );
  981:     return results;
