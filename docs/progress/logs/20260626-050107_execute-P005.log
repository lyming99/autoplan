  return matches;
}

function waitForChild(child, timeoutMs) {
  return new Promise((resolve) => {
    let settled = false;
    let killTimer = null;
    const finish = (code) => {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      if (killTimer) clearTimeout(killTimer);
      resolve(code ?? 0);
    };
    const timer = setTimeout(() => {
      killChildProcess(child);
      killTimer = setTimeout(() => finish(-1), 5000);
    }, timeoutMs);
    child.on('exit', (code) => {
      finish(code);
    });
    child.on('error', () => finish(-1));
