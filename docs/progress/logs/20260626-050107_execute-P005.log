 1261:   syncPlanTasks(planId, planFile) {
 1262:     if (!fs.existsSync(planFile)) return;
 1263:     normalizePlanTaskScopes(planFile);
 1264:     const text = fs.readFileSync(planFile, 'utf8');
 1265:     const regex = /^\s*[-*]\s+\[([ xX])\]\s+(.+)$/gm;
 1266:     const tasks = [];
 1267:     let match;
 1268:     let index = 0;
 1269:     while ((match = regex.exec(text))) {
 1270:       index += 1;
 1271:       const rawTitle = match[2].trim();
 1272:       const titleWithoutScope = stripTaskScopeComment(rawTitle);
 1273:       const idMatch = titleWithoutScope.match(/^([A-Za-z]+[-_]?\d+|P\d+)[:：\s-]+(.+)$/);
 1274:       tasks.push({
 1275:         key: idMatch?.[1] || `P${String(index).padStart(3, '0')}`,
 1276:         title: idMatch?.[2]?.trim() || titleWithoutScope || rawTitle,
 1277:         rawLine: ensureTaskScopeComment(match[0]),
 1278:         scope: taskScopeText({ raw_line: match[0], title: rawTitle }),
 1279:         status: match[1].toLowerCase() === 'x' ? 'completed' : 'pending',
 1280:         sortOrder: index,
 1281:       });
 1282:     }

