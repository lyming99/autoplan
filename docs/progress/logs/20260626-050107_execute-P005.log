 1052:     const succeeded = result.exitCode === 0;
 1053:     if (!succeeded) {
 1054:       this.recordTaskFailure(plan.project_id, plan, task, finishedAt, {
 1055:         ...agentCliContextFields(result, { defaultProvider: true }),
 1056:         exitCode: result.exitCode,
 1057:         log: result.logFile,
 1058:         ...codexSessionContextFields(result),
 1059:       });
 1060:     }
 1061:     return result;
 1062:   }
 1063: 
 1064:   completeTask(workspace, plan, task, result) {
 1065:     const planFile = path.join(workspace, plan.file_path);
 1066:     const finishedAt = result?.finishedAt || nowIso();
 1067:     this.markTaskCompletedInPlan(workspace, planFile, task, result);
 1068:     const completedTask = this.finishTaskRun(task.id, TASK_EVENT_STATUS.COMPLETED, finishedAt) || task;
 1069:     this.addTaskLifecycleEvent(plan.project_id, TASK_EVENT_TYPES.SUCCEEDED, completedTask, {
