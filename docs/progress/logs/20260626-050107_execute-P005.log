  639: 
  640:     const planFile = path.join(workspace, plan.file_path);
  641:     if (!fs.existsSync(planFile)) throw new Error('plan 文件不存在，无法追加任务');
  642: 
  643:     const cleanTitle = String(title || '').trim();
  644:     if (!cleanTitle) throw new Error('任务标题不能为空');
  645: 
  646:     // 计算下一个 task_key
  647:     const existing = this.db.all('SELECT task_key FROM plan_tasks WHERE plan_id = ? ORDER BY sort_order', [planId]);
  648:     const maxNum = existing.reduce((max, row) => {
  649:       const m = String(row.task_key || '').match(/P0*(\d+)/i);
  650:       return m ? Math.max(max, Number(m[1])) : max;
  651:     }, 0);
  652:     const taskKey = `P${String(maxNum + 1).padStart(3, '0')}`;
  653: 
