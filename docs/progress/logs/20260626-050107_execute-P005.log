 1244:   /** 把当前 activeOperation 转存为 lastOperation（保留日志），然后清空 active */
 1245:   archiveOperation(projectId, operationKey) {
 1246:     const runtime = this.runtime(projectId);
 1247:     if (!runtime) return;
 1248:     const op = operationKey ? runtime.activeOperations.get(operationKey) : runtime.activeOperation;
 1249:     if (op) {
 1250:       if (op.activity && typeof op.activity.flush === 'function') {
 1251:         op.activity.flush();
 1252:       }
 1253:       runtime.lastOperation = {
 1254:         label: op.label || '',
 1255:         projectId: op.projectId || null,
 1256:         planId: op.planId || null,
 1257:         taskId: op.taskId || null,
 1258:         ...agentCliContextFields(op),
 1259:         logFile: op.logFile || null,
 1260:         lastFile: op.lastFile || null,
 1261:         errorMessage: op.errorMessage || '',
 1262:         startedAt: op.startedAt || null,
 1263:         finishedAt: nowIso(),
 1264:         exitCode: typeof op.exitCode === 'number' ? op.exitCode : null,
 1265:         logTail: (op.logBuffer || '').slice(-8000),
 1266:         activity: op.activity ? op.activity.getLines() : [],
 1267:         ...codexSessionContextFields(op),
 1268:       };
 1269:     }
 1270:     if (operationKey) {
 1271:       runtime.activeChildren.delete(operationKey);
 1272:       runtime.activeOperations.delete(operationKey);
 1273:     } else {
 1274:       runtime.activeChildren.clear();
 1275:       runtime.activeOperations.clear();
 1276:     }
 1277:     refreshRuntimeActive(runtime);
 1278:   }
