  911:   async processPlan(workspace, plan) {
  912:     const planFile = path.join(workspace, plan.file_path);
  913:     this.syncPlanTasks(plan.id, planFile);
  914:     const pendingTasks = this.db.all(
  915:       `SELECT * FROM plan_tasks WHERE plan_id = ? AND status = 'pending'
  916:        ORDER BY sort_order ASC`,
  917:       [plan.id],
  918:     );
  919:     if (pendingTasks.length) {
  920:       const batch = this.parallelTaskBatch(pendingTasks);
  921:       if (batch.length > 1) {
  922:         await this.executeTaskBatch(workspace, plan, batch);
  923:       } else {
  924:         const task = batch[0] || pendingTasks[0];
  925:         const result = await this.executeTask(workspace, plan, task);
  926:         if (result.exitCode === 0) {
  927:           this.completeTask(workspace, plan, task, result);
  928:         }
  929:       }
  930:       return;
  931:     }
  932:     await this.validatePlan(workspace, plan);
