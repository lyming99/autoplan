 1100:   markTaskCompletedInPlan(workspace, planFile, task, result) {
 1101:     if (!fs.existsSync(planFile)) return;
 1102:     const relativeLog = result?.logFile ? normalizeRelative(workspace, result.logFile) : '';
 1103:     const key = escapeRegExp(String(task.task_key || ''));
 1104:     const checkboxRe = new RegExp(`(^\\s*[-*]\\s+\\[)([ xX])(\\]\\s+${key}(?:\\b|[:：\\s-]))`, 'm');
 1105:     let content = fs.readFileSync(planFile, 'utf8');
 1106:     if (checkboxRe.test(content)) {
 1107:       content = content.replace(checkboxRe, '$1x$3');
 1108:     }
 1109: 
 1110:     const note = `- ${task.task_key} AutoPlan 完成：${nowIso()}${relativeLog ? `；日志：${relativeLog}` : ''}`;
 1111:     const noteRe = new RegExp(`^\\s*-\\s+${key}\\s+AutoPlan 完成：.*$`, 'm');
 1112:     if (noteRe.test(content)) {
 1113:       content = content.replace(noteRe, note);
 1114:     } else if (/##\s*进度区/.test(content)) {
 1115:       content = `${content.trimEnd()}\n${note}\n`;
 1116:     } else {
 1117:       content = `${content.trimEnd()}\n\n## 进度区\n${note}\n`;
 1118:     }
 1119:     fs.writeFileSync(planFile, content, 'utf8');
 1120:   }
