  673:       projectId,
  674:       'task.appended',
  675:       `追加 ${taskKey}: ${cleanTitle}`,
  676:       taskEventMeta(task, {
  677:         planId,
  678:         taskKey,
  679:         taskTitle: cleanTitle,
  680:         status: TASK_EVENT_STATUS.PENDING,
  681:       }),
  682:     );
  683:     this.emitUpdate(projectId);
  684: 
  685:     // 循环在运行则立即拾取
  686:     if (this.status(projectId)?.running) {
  687:       this.runOnce(projectId).catch((error) => this.recordError(projectId, error));
  688:     }
  689:     return taskKey;
  690:   }
