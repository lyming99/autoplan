 1170:   syncPlanTasks(planId, planFile) {
 1171:     if (!fs.existsSync(planFile)) return;
 1172:     normalizePlanTaskScopes(planFile);
 1173:     const text = fs.readFileSync(planFile, 'utf8');
 1174:     const regex = /^\s*[-*]\s+\[([ xX])\]\s+(.+)$/gm;
 1175:     const tasks = [];
 1176:     let match;
 1177:     let index = 0;
 1178:     while ((match = regex.exec(text))) {
 1179:       index += 1;
 1180:       const rawTitle = match[2].trim();
 1181:       const titleWithoutScope = stripTaskScopeComment(rawTitle);
 1182:       const idMatch = titleWithoutScope.match(/^([A-Za-z]+[-_]?\d+|P\d+)[:：\s-]+(.+)$/);
 1183:       tasks.push({
 1184:         key: idMatch?.[1] || `P${String(index).padStart(3, '0')}`,
 1185:         title: idMatch?.[2]?.trim() || titleWithoutScope || rawTitle,
 1186:         rawLine: ensureTaskScopeComment(match[0]),
 1187:         scope: taskScopeText({ raw_line: match[0], title: rawTitle }),
 1188:         status: match[1].toLowerCase() === 'x' ? 'completed' : 'pending',
 1189:         sortOrder: index,
 1190:       });
 1191:     }
 1192: 
 1193:     const existingTasks = this.db.all('SELECT * FROM plan_tasks WHERE plan_id = ? ORDER BY sort_order ASC, id ASC', [planId]);
 1194:     const existingByKey = new Map();
 1195:     for (const existing of existingTasks) {
 1196:       const matches = existingByKey.get(existing.task_key) || [];
 1197:       matches.push(existing);
 1198:       existingByKey.set(existing.task_key, matches);
 1199:     }
 1200: 
