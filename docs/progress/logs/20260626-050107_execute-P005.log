 1170:   syncPlanTasks(planId, planFile) {
 1171:     if (!fs.existsSync(planFile)) return;
 1172:     normalizePlanTaskScopes(planFile);
 1173:     const text = fs.readFileSync(planFile, 'utf8');
 1174:     const regex = /^\s*[-*]\s+\[([ xX])\]\s+(.+)$/gm;
 1175:     const tasks = [];
 1176:     let match;
 1177:     let index = 0;
 1178:     while ((match = regex.exec(text))) {
 1179:       index += 1;
 1180:       const rawTitle = match[2].trim();
 1181:       const titleWithoutScope = stripTaskScopeComment(rawTitle);
 1182:       const idMatch = titleWithoutScope.match(/^([A-Za-z]+[-_]?\d+|P\d+)[:：\s-]+(.+)$/);
 1183:       tasks.push({
 1184:         key: idMatch?.[1] || `P${String(index).padStart(3, '0')}`,
 1185:         title: idMatch?.[2]?.trim() || titleWithoutScope || rawTitle,
 1186:         rawLine: ensureTaskScopeComment(match[0]),
 1187:         scope: taskScopeText({ raw_line: match[0], title: rawTitle }),
 1188:         status: match[1].toLowerCase() === 'x' ? 'completed' : 'pending',
 1189:         sortOrder: index,
 1190:       });
 1191:     }
 1192: 
 1193:     const existingTasks = this.db.all('SELECT * FROM plan_tasks WHERE plan_id = ? ORDER BY sort_order ASC, id ASC', [planId]);
 1194:     const existingByKey = new Map();
 1195:     for (const existing of existingTasks) {
 1196:       const matches = existingByKey.get(existing.task_key) || [];
 1197:       matches.push(existing);
 1198:       existingByKey.set(existing.task_key, matches);
 1199:     }
 1200: 
 1201:     const syncedStatuses = [];
 1202:     for (const task of tasks) {
 1203:       const existing = existingByKey.get(task.key)?.shift();
 1204:       const status = existing ? syncedTaskStatus(task.status, existing.status) : task.status;
 1205:       syncedStatuses.push(status);
 1206:       if (existing) {
 1207:         this.db.run(
 1208:           `UPDATE plan_tasks
 1209:            SET title = ?, raw_line = ?, scope = ?, status = ?, sort_order = ?, updated_at = ?
 1210:            WHERE id = ?`,
 1211:           [
 1212:             task.title,
 1213:             task.rawLine,
 1214:             task.scope,
 1215:             status,
 1216:             task.sortOrder,
 1217:             nowIso(),
 1218:             existing.id,
 1219:           ],
 1220:         );
 1221:       } else {
 1222:         this.db.run(
 1223:           `INSERT INTO plan_tasks (plan_id, task_key, title, raw_line, scope, status, sort_order, updated_at)
 1224:            VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
 1225:           [planId, task.key, task.title, task.rawLine, task.scope, status, task.sortOrder, nowIso()],
 1226:         );
 1227:       }
 1228:     }
 1229: 
 1230:     for (const matches of existingByKey.values()) {
 1231:       for (const stale of matches) {
 1232:         this.db.run('DELETE FROM plan_tasks WHERE id = ?', [stale.id]);
 1233:       }
 1234:     }
 1235: 
 1236:     const completed = syncedStatuses.filter((status) => status === 'completed').length;
 1237:     const status = tasks.length > 0 && completed === tasks.length ? 'ready_for_validation' : 'running';
 1238:     this.db.run(
 1239:       'UPDATE plans SET hash = ?, status = ?, total_tasks = ?, completed_tasks = ?, updated_at = ? WHERE id = ?',
 1240:       [hashFile(planFile), status, tasks.length, completed, nowIso(), planId],
 1241:     );
 1242:   }
