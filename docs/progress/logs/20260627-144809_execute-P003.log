+  if (input[key] === undefined || input[key] === null) return undefined;
+  if (!Array.isArray(input[key])) throw new Error(`${key} 必须是字节数组`);
+  if (input[key].length > LIMITS.attachmentData) throw new Error(`${key} 长度不能超过 ${LIMITS.attachmentData}`);
