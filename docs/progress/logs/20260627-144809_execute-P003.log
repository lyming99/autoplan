+    feedback: number;
+    plans: number;
+    tasks: number;
+    events: number;
+  };
+}
+
+export interface McpToolResult {
+  projectId: number | null;
+  requirementId?: number | null;
+  feedbackId?: number | null;
+  snapshot: McpSnapshotSummary;
+}
+
