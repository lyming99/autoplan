@import './renderer/styles/layout.css';

@import './renderer/styles/components.css';

@import './renderer/styles/workspace.css';

.task-plan-group-toggle {
  width: 100%;
  border: 0;
  border-radius: var(--r-md);
  background: transparent;
  color: inherit;
  cursor: pointer;
  text-align: left;
}

.task-plan-group-toggle:hover {
  background: var(--bg-hover);
}

.task-plan-group-toggle:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px var(--brand-50);
}

.task-plan-group-title-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1 1 auto;
}

.task-plan-group-chevron {
  display: inline-grid;
  place-items: center;
  width: 18px;
  height: 18px;
  flex: 0 0 auto;
  border-radius: 999px;
  background: var(--bg-soft);
  color: var(--text-3);
  font-size: 11px;
  transition: transform 0.14s ease, background 0.14s ease, color 0.14s ease;
}

.task-plan-group.is-collapsed .task-plan-group-chevron {
  transform: rotate(-90deg);
}

.task-plan-group-meta {
  display: inline-flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-items: center;
  gap: 6px;
  max-width: 56%;
  min-width: 0;
}

.task-plan-group-counts {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 2px 8px;
  border: 1px solid var(--line-soft);
  border-radius: 999px;
  background: var(--bg-soft);
  color: var(--text-2);
  font-size: 11px;
  font-weight: 700;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-plan-group-items {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.task-plan-group.is-collapsed {
  gap: 0;
}

.task-plan-group.is-collapsed .task-plan-group-toggle {
  padding-bottom: 2px;
}

.plan-selection-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin: 10px 0;
  padding: 9px 12px;
  border: 1px solid var(--line-soft);
  border-radius: var(--r-md);
  background: var(--bg-soft);
  color: var(--text-2);
  font-size: 12px;
}

.plan-selection-bar.is-active {
  border-color: var(--brand-500);
  background: var(--brand-50);
  color: var(--brand-700);
}

.plan-selection-summary {
  min-width: 0;
  overflow: hidden;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-selection-clear:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.plan-selection-list {
  margin-bottom: 12px;
}

.plan-select-row {
  border: 1px solid transparent;
  transition: border-color 0.14s ease, background 0.14s ease, box-shadow 0.14s ease;
}

.plan-select-row.is-selected {
  border-color: var(--brand-500);
  background: var(--brand-50);
  box-shadow: inset 3px 0 0 var(--brand-500);
}

.plan-select-row-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-selected-badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 7px;
  border-radius: 999px;
  background: var(--brand-100);
  color: var(--brand-700);
  font-size: 11px;
  font-weight: 800;
}

.plan-select-button.active {
  color: var(--brand-700);
  font-weight: 800;
}

.plan-select-button:focus-visible,
.plan-selection-clear:focus-visible {
  outline: 2px solid var(--brand-500);
  outline-offset: 2px;
  border-radius: 6px;
}

@media (max-width: 760px) {
  .task-plan-group-meta {
    width: 100%;
    max-width: 100%;
    justify-content: flex-start;
  }

  .task-plan-group-toggle {
    align-items: flex-start;
  }

  .plan-selection-bar {
    align-items: flex-start;
    flex-direction: column;
  }
}

.workspace-search-popover-anchor {
  position: relative;
  z-index: 30;
  display: flex;
  align-items: center;
  flex: 1 1 420px;
  max-width: 580px;
  min-width: 280px;
  margin-left: auto;
}

.workspace-search-popover-anchor .workspace-search {
  width: 100%;
  max-width: none;
  margin-left: 0;
}

.workspace-search-popover-anchor + .topbar-actions {
  margin-left: 0;
}

.search-results-popup {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  z-index: 80;
  width: min(760px, calc(100vw - 48px));
  max-height: min(620px, calc(100vh - 116px));
  margin: 0;
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18), var(--shadow-sm);
}

.search-results-popup .search-results-body {
  max-height: min(440px, calc(100vh - 270px));
}

.search-results-popup .search-result-groups {
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

[data-search-anchor="true"] {
  scroll-margin: 96px;
}

.search-locate-highlight {
  border-color: var(--brand-500) !important;
  animation: search-locate-pulse 2.4s ease;
  box-shadow: 0 0 0 3px var(--brand-50), 0 16px 36px rgba(77, 110, 255, 0.18) !important;
}

.search-locate-notice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin: 12px 24px 0;
  padding: 10px 12px;
  border: 1px solid var(--warning);
  border-radius: var(--r-md);
  background: var(--warning-bg);
  color: var(--text-2);
  font-size: 12px;
}

@keyframes search-locate-pulse {
  0% { box-shadow: 0 0 0 0 rgba(77, 110, 255, 0.38); }
  28% { box-shadow: 0 0 0 7px rgba(77, 110, 255, 0.16); }
  100% { box-shadow: 0 0 0 3px var(--brand-50), 0 16px 36px rgba(77, 110, 255, 0.18); }
}

@media (max-width: 900px) {
  .workspace-search-popover-anchor {
    order: 3;
    flex-basis: 100%;
    max-width: none;
    min-width: 0;
    margin-left: 0;
  }

  .workspace-search-popover-anchor + .topbar-actions {
    margin-left: auto;
  }
}

@media (max-width: 760px) {
  .search-results-popup {
    left: 0;
    right: auto;
    width: 100%;
    max-height: min(620px, calc(100vh - 96px));
  }

  .search-results-popup .search-result-groups {
    grid-template-columns: 1fr;
  }

  .search-locate-notice {
    align-items: flex-start;
    flex-direction: column;
    margin: 10px 14px 0;
  }
}


