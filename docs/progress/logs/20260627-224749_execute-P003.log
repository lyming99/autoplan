+  border-radius: 6px; background: var(--bg-soft); color: var(--text-3);
+}
+.snav-ico::before { content: ""; width: 8px; height: 8px; border: 2px solid currentColor; border-radius: 3px; }
+.settings-nav-item.active .snav-ico { background: var(--bg-elevated); color: var(--brand-600); }
+.snav-text { display: grid; gap: 2px; min-width: 0; flex: 1 1 auto; }
+.snav-text > span, .snav-text small { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.snav-text small { color: var(--text-4); font-size: 11px; font-weight: 500; }
+.snav-meta {
+  flex: 0 0 auto; max-width: 86px; overflow: hidden; padding: 1px 7px; border: 1px solid var(--line);
+  border-radius: 999px; background: var(--bg-soft); color: var(--text-4); font-size: 10.5px; font-weight: 700;
+  text-overflow: ellipsis; white-space: nowrap;
+}
+.snav-meta.ok { border-color: rgba(41,151,90,0.28); background: var(--success-bg); color: var(--success); }
+.snav-meta.warn { border-color: rgba(220,158,54,0.3); background: var(--warning-bg); color: var(--warning); }
+.settings-pane { display: none; max-width: 720px; padding: 26px 32px 24px; }
+.settings-pane.active { display: block; }
+.pane-head { margin-bottom: 20px; }
+.pane-head h2 { display: flex; align-items: center; gap: 10px; min-width: 0; font-size: 18px; font-weight: 750; }
+.pane-head p { margin: 6px 0 0; color: var(--text-3); font-size: 12.5px; line-height: 1.55; }
