 491: 
 492:         <section class="view">
 493:           <div class="settings-view">
 494: 
 495:             <!-- ============ 左侧：分组导航 ============ -->
 496:             <nav class="settings-nav">
 497:               <button class="settings-nav-item active" data-pane="loop">
 498:                 <span class="snav-ico"><svg class="icon" aria-hidden="true" focusable="false"><use href="#icon-refresh"></use></svg></span>
 499:                 循环控制
 500:                 <span class="snav-meta warn">未保存</span>
 501:               </button>
 502:               <button class="settings-nav-item" data-pane="cli">
