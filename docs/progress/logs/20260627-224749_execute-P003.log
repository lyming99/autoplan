 217:         padding: 1px 7px; border-radius: 999px;
 218:       }
 219:       .snav-meta.ok { color: var(--success); background: var(--success-bg); border-color: #bce8cd; }
 220:       .snav-meta.warn { color: var(--warning); background: var(--warning-bg); border-color: #f4ddae; }
 221: 
 222:       /* —— 右侧：配置内容 —— */
 223:       .settings-content { overflow: auto; }
 224:       .settings-pane { display: none; padding: 26px 32px 24px; max-width: 720px; }
 225:       .settings-pane.active { display: block; }
 226: 
 227:       .pane-head { margin-bottom: 20px; }
 228:       .pane-head h2 { font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px; }
 229:       .pane-head h2 .pane-ico {
 230:         width: 30px; height: 30px; border-radius: 9px; display: grid; place-items: center;
 231:         background: var(--brand-50); color: var(--brand-600);
 232:       }
 233:       .pane-head h2 .pane-ico .icon { width: 17px; height: 17px; }
 234:       .pane-head p { font-size: 12.5px; color: var(--text-3); margin-top: 6px; line-height: 1.55; }
 235: 
 236:       /* 分区卡片 */
 237:       .set-card {
 238:         border: 1px solid var(--line); border-radius: var(--r-lg);
 239:         background: var(--bg-elevated); box-shadow: var(--shadow-sm);
 240:         margin-bottom: 16px; overflow: hidden;
 241:       }
 242:       .set-card-head {
 243:         padding: 14px 18px; border-bottom: 1px solid var(--line-soft);
 244:         background: var(--bg-soft);
 245:       }
 246:       .set-card-head h3 { font-size: 13px; font-weight: 700; color: var(--text-1); }
 247:       .set-card-head .set-card-hint { font-size: 11.5px; color: var(--text-3); margin-top: 3px; }
 248:       .set-card-body { padding: 6px 18px 8px; }
 249: 
 250:       /* 字段 */
 251:       .field { display: flex; flex-direction: column; gap: 6px; padding: 12px 0; border-bottom: 1px solid var(--line-soft); }
 252:       .field:last-child { border-bottom: 0; }
 253:       .field-label { display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--text-2); }
 254:       .field-label .req { color: var(--danger); font-size: 12px; }
 255:       .field-label .tag {
 256:         margin-left: 4px; font-size: 10px; font-weight: 700;
 257:         color: var(--text-4); background: var(--bg-soft); border: 1px solid var(--line);
 258:         padding: 1px 6px; border-radius: 4px; text-transform: none;
 259:       }
 260:       .field-input, .field-select {
 261:         width: 100%; padding: 9px 11px; border: 1px solid var(--line);
 262:         border-radius: var(--r-sm); background: var(--bg-elevated);
 263:         font: inherit; font-size: 13px; color: var(--text-1);
 264:         transition: border-color .14s, box-shadow .14s;
 265:       }
 266:       .field-input:focus, .field-select:focus {
 267:         outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50);
 268:       }
 269:       .field-input.mono, .field-select.mono { font-family: var(--font-mono); font-size: 12px; }
 270:       .field-input::placeholder { color: var(--text-4); }
 271:       .field-hint { font-size: 11.5px; color: var(--text-3); line-height: 1.5; }
 272:       .field-hint code { font-size: 11px; background: var(--bg-soft); border: 1px solid var(--line); padding: 0 5px; border-radius: 4px; }
 273: 
 274:       /* 带后缀输入框 */
 275:       .input-affix { display: flex; align-items: stretch; }
 276:       .input-affix .field-input { border-radius: var(--r-sm) 0 0 var(--r-sm); }
 277:       .input-affix .affix {
 278:         display: grid; place-items: center; padding: 0 12px;
 279:         border: 1px solid var(--line); border-left: 0; border-radius: 0 var(--r-sm) var(--r-sm) 0;
 280:         background: var(--bg-soft); color: var(--text-3); font-size: 12px; font-weight: 600;
 281:       }
 282: 
 283:       /* 分段控件 */
 284:       .segmented {
 285:         display: inline-flex; padding: 3px; gap: 2px; flex-wrap: wrap;
 286:         background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--r-md);
 287:       }
 288:       .seg-opt {
 289:         display: inline-flex; align-items: center; gap: 8px;
 290:         padding: 7px 14px; border: 0; border-radius: 7px;
 291:         background: transparent; color: var(--text-2);
 292:         font-size: 12.5px; font-weight: 600; white-space: nowrap;
 293:         transition: background .14s, color .14s, box-shadow .14s;
 294:       }
 295:       .seg-opt:hover { color: var(--text-1); }
 296:       .seg-opt.active { background: var(--bg-elevated); color: var(--brand-700); box-shadow: var(--shadow-sm); }
 297:       .seg-opt .icon { width: 15px; height: 15px; }
 298:       .seg-opt .seg-note { font-size: 11px; font-weight: 500; color: var(--text-3); }
 299: 
 300:       /* 思考深度选项卡 */
 301:       .effort-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
 302:       .effort-opt {
 303:         position: relative; padding: 12px 14px; text-align: left;
 304:         border: 1px solid var(--line); border-radius: var(--r-md);
 305:         background: var(--bg-elevated); cursor: pointer;
 306:         transition: border-color .14s, box-shadow .14s, background .14s;
 307:       }
 308:       .effort-opt:hover { border-color: #c6d1e3; background: var(--bg-soft); }
 309:       .effort-opt.active { border-color: var(--brand-500); background: var(--brand-50); box-shadow: 0 0 0 3px var(--brand-50); }
 310:       .effort-opt .eff-name { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; color: var(--text-1); }
 311:       .effort-opt .eff-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-4); }
 312:       .effort-opt.active .eff-dot { background: var(--brand-600); }
 313:       .effort-opt .eff-desc { font-size: 11.5px; color: var(--text-3); margin-top: 5px; line-height: 1.5; }
 314:       .effort-opt .eff-check { position: absolute; top: 10px; right: 10px; color: var(--brand-600); opacity: 0; }
 315:       .effort-opt.active .eff-check { opacity: 1; }
 316:       .effort-opt .eff-check .icon { width: 15px; height: 15px; }
 317: 
 318:       /* 信息行（只读） */
 319:       .info-row {
 320:         display: grid; grid-template-columns: 130px 1fr; gap: 16px;
 321:         align-items: baseline; padding: 12px 0; border-bottom: 1px solid var(--line-soft);
 322:       }
 323:       .info-row:last-child { border-bottom: 0; }
 324:       .info-row .info-key { font-size: 12px; font-weight: 600; color: var(--text-3); }
 325:       .info-row .info-val { font-size: 13px; color: var(--text-1); word-break: break-all; }
 326:       .info-row .info-val.mono { font-family: var(--font-mono); font-size: 12.5px; }
 327:       .info-row .info-val.dim { color: var(--text-3); }
 328: 
 329:       /* MCP 状态徽标 */
 330:       .mcp-status {
 331:         display: inline-flex; align-items: center; gap: 8px;
 332:         padding: 5px 11px; border-radius: 999px; font-size: 12px; font-weight: 700;
 333:         background: var(--success-bg); color: var(--success); border: 1px solid #bce8cd;
 334:       }
 335:       .mcp-status.error { background: var(--danger-bg); color: var(--danger); border-color: #f4c9cb; }
 336:       .mcp-status.disabled { background: var(--bg-soft); color: var(--text-3); border-color: var(--line); }
 337: 
 338:       /* 工具标签 */
 339:       .tool-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 2px; }
 340:       .tool-tag {
 341:         display: inline-flex; align-items: center; gap: 5px; padding: 4px 9px;
 342:         border-radius: var(--r-sm); background: var(--bg-soft); border: 1px solid var(--line);
 343:         font-family: var(--font-mono); font-size: 11.5px; color: var(--text-2);
 344:       }
 345:       .tool-tag .icon { width: 13px; height: 13px; color: var(--brand-600); }
 346: 
 347:       /* 可复制地址条 */
 348:       .copy-bar {
 349:         display: flex; align-items: center; gap: 8px; margin-top: 10px;
 350:         padding: 9px 9px 9px 13px; border: 1px dashed var(--line);
 351:         border-radius: var(--r-sm); background: var(--bg-soft);
 352:       }
 353:       .copy-bar .copy-url { flex: 1 1 auto; font-family: var(--font-mono); font-size: 12.5px; color: var(--text-1); word-break: break-all; }
 354:       .copy-btn {
 355:         display: inline-flex; align-items: center; gap: 5px; flex: 0 0 auto;
 356:         padding: 5px 10px; border-radius: var(--r-sm); border: 1px solid var(--line);
 357:         background: var(--bg-elevated); color: var(--text-2); font-size: 11.5px; font-weight: 600;
 358:       }
 359:       .copy-btn:hover { background: var(--bg-hover); color: var(--text-1); }
 360:       .copy-btn .icon { width: 13px; height: 13px; }
 361: 
 362:       /* 提示横幅 */
 363:       .inline-banner {
 364:         display: flex; align-items: flex-start; gap: 10px;
 365:         margin: 12px 0 4px; padding: 10px 12px;
 366:         border-radius: var(--r-sm); font-size: 12px; line-height: 1.55;
 367:         background: var(--warning-bg); color: #8a5400; border: 1px solid #f4ddae;
 368:       }
 369:       .inline-banner .icon { width: 15px; height: 15px; flex: 0 0 auto; margin-top: 1px; }
 370:       .inline-banner.info { background: var(--info-bg); color: #1f4ea8; border-color: #c8d9f7; }
 371:       .inline-banner code { background: rgba(255,255,255,.6); border: 1px solid currentColor; opacity: .4; padding: 0 5px; border-radius: 4px; }
 372: 
 373:       .provider-note {
 374:         display: flex; align-items: flex-start; gap: 10px; margin: 4px 0 12px;
 375:         padding: 11px 13px; border-radius: var(--r-sm);
 376:         background: var(--bg-soft); border: 1px solid var(--line);
 377:         font-size: 12px; color: var(--text-2); line-height: 1.55;
 378:       }
 379:       .provider-note .icon { width: 16px; height: 16px; flex: 0 0 auto; margin-top: 1px; color: var(--brand-600); }
 380:       .provider-note code { font-size: 11.5px; background: var(--bg-elevated); border: 1px solid var(--line); padding: 0 5px; border-radius: 4px; color: var(--text-1); }
