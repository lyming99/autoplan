+                  <InfoRow label="工具清单">
+                    <span className="tool-tags">
+                      {mcpTools.map((tool) => <span className="tool-tag" key={tool}>{tool}</span>)}
+                    </span>
+                  </InfoRow>
+                  <InfoRow label="最近错误"><span className={mcp?.lastError ? 'danger-text' : 'dim'}>{mcp?.lastError || '无'}</span></InfoRow>
+                  <div className="inline-banner">
+                    <span>{mcp?.note || '默认仅监听本机地址，供本机 MCP 客户端连接。'} 可用环境变量 <code>AUTOPLAN_MCP_ENABLED=0</code> 禁用服务。</span>
+                  </div>
+                </div>
+              </div>
+            </section>
+          ) : null}
+        </form>
       </div>
     </div>
   );
 }
+
+function SettingsActions({ running, onToggleRun }: { running: boolean; onToggleRun: () => void }) {
+  return (
+    <div className="settings-actions button-row">
+      <button type="submit">保存配置</button>
+      <button type="button" onClick={onToggleRun}>{running ? '停止' : '启动'}</button>
+    </div>
+  );
+}
+
+function InfoRow({ label, children }: { label: string; children: ReactNode }) {
+  return (
+    <div className="info-row">
+      <span className="info-key">{label}</span>
+      <span className="info-val">{children}</span>
+    </div>
+  );
+}
