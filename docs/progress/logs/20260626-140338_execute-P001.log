+  return {
+    id: task.id,
+    task_key: task.task_key,
+    title: task.title,
+    status: task.status,
+    scopes: Array.from(new Set(scopes)),
+    reason,
+  };
+}
+
+function emptyConcurrencySuggestion() {
+  return {
+    hasSafeParallelBatches: false,
+    parallelTaskCount: 0,
+    batchCount: 0,
+    serialTaskCount: 0,
+    maxParallelTasks: MAX_PARALLEL_TASKS,
+    batches: [],
+    serialTasks: [],
+  };
+}
