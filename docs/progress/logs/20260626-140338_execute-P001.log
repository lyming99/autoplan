  plan_total?: number | null;
  created_at: string;
  updated_at: string;
}

export interface Feedback {
  id: number;
  project_id: number;
  requirement_id?: number | null;
  title: string;
  body: string;
  status: string;
  agent_cli_provider?: AgentCliProvider | null;
