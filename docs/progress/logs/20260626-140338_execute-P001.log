+  const special = SPECIAL_TASK_SCOPES.has(normalizedPath) ? normalizedPath : '';
+  const result = {
+    path: normalizedPath || 'unknown',
+    exists: false,
+    isDirectory: false,
+    canOpen: false,
+    isUnknown: special === 'unknown' || !normalizedPath,
+    isValidation: special === 'validation',
+    reason: '',
+  };
+  if (result.isUnknown) {
