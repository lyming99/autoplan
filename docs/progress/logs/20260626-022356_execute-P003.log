+    agentCliProvider: normalizedProvider,
+    command: resolvedCommand,
+    args: codexArgs || [],
+    useShell: true,
+  };
+}
+
+async function runAgentCliAttempt(options) {
+  const {
+    workspace,
+    prompt,
+    lastFile,
