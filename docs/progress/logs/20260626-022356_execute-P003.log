+      args: claudeCliArgs(lastFile),
+      useShell: false,
+    };
+  }
+  return {
+    provider: normalizedProvider,
+    agentCliProvider: normalizedProvider,
+    command: resolvedCommand,
+    args: codexArgs || [],
+    useShell: true,
+  };
+}
+
+async function runAgentCliAttempt(options) {
