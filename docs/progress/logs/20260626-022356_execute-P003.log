+    shell: process.platform === 'win32' && spawnSpec.useShell,
+    cwd: workspace,
+  });
+
+  const nextOperationKey = bindRuntimeOperation({
+    runtime,
+    child,
+    activeOperation,
+    operationKey,
+    registerRuntimeOperation,
+  });
+  if (typeof onOperationKey === 'function') onOperationKey(nextOperationKey);
+
+  let output = '';
