+const { spawn } = require('node:child_process');
+
+const DEFAULT_AGENT_CLI_PROVIDER = 'codex';
+const AGENT_CLI_PROVIDERS = new Set([DEFAULT_AGENT_CLI_PROVIDER, 'claude']);
