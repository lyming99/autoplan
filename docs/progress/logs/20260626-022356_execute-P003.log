+    child.stdout.on('data', handleChunk);
+    child.stdout.pipe(stream, { end: false });
+  }
+  if (child.stderr) {
+    child.stderr.on('data', handleChunk);
+    child.stderr.pipe(stream, { end: false });
+  }
+  child.on('error', (error) => {
+    spawnError = error;
