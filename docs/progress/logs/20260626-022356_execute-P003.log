 1386:   async runShell(workspace, command, label, operation = {}) {
 1387:     const projectIdForEmit = operation.projectId;
 1388:     const runtime = this.runtime(projectIdForEmit);
 1389:     if (!runtime) throw new Error('projectId is required for shell operations');
 1390:     const logDir = path.join(workspace, 'docs', 'progress', 'logs');
 1391:     fs.mkdirSync(logDir, { recursive: true });
 1392:     const logFile = path.join(logDir, `${timestampForPath()}_${safePart(label)}.log`);
 1393:     const shellCommand = process.platform === 'win32' ? `chcp 65001>nul && ${command}` : command;
 1394:     const child = spawn(shellCommand, {
 1395:       shell: true,
 1396:       cwd: workspace,
 1397:       env: { ...process.env },
 1398:     });
 1399:     const activeOperation = {
 1400:       ...operation,
 1401:       label,
 1402:       logBuffer: '',
 1403:       activity: new CodexActivityPrinter(200),
 1404:       startedAt: nowIso(),
 1405:     };
 1406:     const operationKey = registerRuntimeOperation(runtime, child, activeOperation);
 1407:     let output = '';
 1408:     const onChunk = (chunk) => {
 1409:       const text = chunk.toString('utf8');
 1410:       output += text;
 1411:       if (!runtime.activeOperations.has(operationKey)) return;
 1412:       activeOperation.logBuffer = (activeOperation.logBuffer || '') + text;
 1413:       if (activeOperation.logBuffer.length > 24000) {
 1414:         activeOperation.logBuffer = activeOperation.logBuffer.slice(-16000);
 1415:       }
 1416:       if (activeOperation.activity) activeOperation.activity.offer(text);
 1417:     };
 1418:     child.stdout.on('data', onChunk);
 1419:     child.stderr.on('data', onChunk);
 1420:     const tailTimer = setInterval(() => {
 1421:       if (projectIdForEmit) this.emitUpdate(projectIdForEmit);
 1422:     }, 600);
 1423:     try {
 1424:       const exitCode = await waitForChild(child, 10 * 60 * 1000);
 1425:       fs.writeFileSync(logFile, output, 'utf8');
 1426:       if (runtime.activeOperations.has(operationKey)) activeOperation.exitCode = exitCode;
 1427:       return { exitCode, output, logFile };
 1428:     } finally {
 1429:       clearInterval(tailTimer);
 1430:       if (runtime.activeOperations.has(operationKey)) {
 1431:         this.archiveOperation(projectIdForEmit, operationKey);
 1432:       }
 1433:     }
 1434:   }
