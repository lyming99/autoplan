+        if (conflictScope) {
+          throw new Error(`第 ${batchIndex + 1} 批存在 scope 冲突：${conflictScope}`);
+        }
+        for (const scope of analysis.scopes) usedScopes.add(scope);
+        return task;
+      });
+    });
