 124: export function formatTaskPlanGroupSummary(group: TaskPlanGroup) {
 125:   const timedTasks = group.tasks as TimedPlanTask[];
 126:   const latestFinishedAt = latestTaskTimestamp(timedTasks, 'finished_at');
 127:   const latestUpdatedAt = latestTaskTimestamp(timedTasks, 'updated_at');
 128:   const timeSummary = latestFinishedAt
 129:     ? `最新完成 ${formatChinaDateTime(latestFinishedAt)}`
 130:     : latestUpdatedAt
 131:       ? `最新更新 ${formatChinaDateTime(latestUpdatedAt)}`
 132:       : '暂无时间记录';
 133:   return `${group.tasks.length} 个任务 · ${timeSummary}`;
 134: }
 135: 
 136: function taskPlanGroupTitle(task: TimedPlanTask) {
 137:   return String(task.plan_title || readPlanTaskAssociationFilePath(task) || '未命名计划').trim() || '未命名计划';
 138: }
 139: 
 140: function taskPlanGroupIdentity(task: TimedPlanTask): TaskPlanGroupIdentity {
 141:   const planId = readPlanId(task);
 142:   if (planId !== null) return { key: `plan:${planId}`, source: 'plan', sourceId: String(planId) };
 143:   const filePath = readPlanTaskAssociationFilePath(task);
 144:   if (filePath) return { key: `file:${filePath}`, source: 'file', sourceId: filePath };
 145:   const title = taskPlanGroupTitle(task);
 146:   if (title !== '未命名计划') return { key: `title:${title}`, source: 'title', sourceId: title };
 147:   return { key: 'unknown-plan', source: 'unknown', sourceId: null };
 148: }
