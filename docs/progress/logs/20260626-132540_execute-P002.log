name: Release

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:
    inputs:
      tag:
        description: 'Release tag to build and publish, for example v0.2.0'
        required: true
        type: string
      release_notes:
        description: 'Release notes body. Leave empty to use a default message.'
        required: false
        type: string
        default: ''

permissions:
  contents: write

concurrency:
  group: release-"'${{ github.event_name == '"'workflow_dispatch' && inputs.tag || github.ref_name }}
  cancel-in-progress: false

jobs:
  build:
    name: Build "'${{ matrix.platform }}
    runs-on: ${{ matrix.runner }}
    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: windows
            runner: windows-latest
            package_script: package:win
          - platform: macos
            runner: macos-latest
            package_script: package:mac
          - platform: linux
            runner: ubuntu-latest
            package_script: package:linux

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event_name == '"'workflow_dispatch' && inputs.tag || github.ref_name }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Package "'${{ matrix.platform }}
        run: npm run ${{ matrix.package_script }}

      - name: Upload ${{ matrix.platform }} artifacts
        uses: actions/upload-artifact@v4
        with:
          name: autoplan-${{ github.event_name == '"'workflow_dispatch' && inputs.tag || github.ref_name }}-"'${{ matrix.platform }}
          path: release/**/*
          if-no-files-found: error
          retention-days: 14

