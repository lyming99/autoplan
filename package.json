{
  "name": "autoplan",
  "version": "0.2.3-beta.5",
  "description": "Electron app for issue-driven autonomous planning and development loops.",
  "author": "lyming99 <lyming99@users.noreply.github.com>",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev": "node scripts/dev.js",
    "build": "tsc --noEmit && vite build",
    "package:win": "npm run build && electron-builder --win nsis --x64",
    "package:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64",
    "package:linux": "npm run build && electron-builder --linux AppImage deb --x64",
    "package:all": "npm run build && electron-builder --win nsis --mac dmg zip --linux AppImage deb --x64",
    "verify:release-artifacts": "node scripts/verify-release-artifacts.js",
    "check": "tsc --noEmit && node --check src/main.js && node --check src/agentCli.js && node --check src/attachments.js && node --check src/database.js && node --check src/loopService.js && node --check src/mcpServer.js && node --check src/preload.js && node --check scripts/dev.js && node --check scripts/smoke-test.js && npm run check:lengths",
    "check:lengths": "node scripts/check-file-lengths.js",
    "test": "node --test \"src/**/*.test.js\"",
    "mcp:http": "node src/mcpServer.js --http",
    "mcp:stdio": "node src/mcpServer.js --stdio",
    "smoke": "node scripts/smoke-test.js"
  },
  "build": {
    "appId": "com.autoplan.desktop",
    "productName": "AutoPlan",
    "directories": {
      "output": "release"
    },
    "afterSign": "scripts/notarize-mac.js",
    "files": [
      "assets/**/*",
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/sql.js/dist/*.wasm",
      "src/loop/scanWorker.js",
      "src/loop/workspaceFiles.js"
    ],
    "toolsets": {
      "appimage": "1.0.3"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}-Setup.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "openai": "^4.104.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^33.3.2",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
