<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "https://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- AutoPlan 以非沙箱直接分发（非 Mac App Store），故意不声明 com.apple.security.app-sandbox，
       以保证任意本地工作区文件夹可读写、in-app MCP 可监听本机端口。下方 network.* entitlement 仅作
       沙箱误开时的兜底与代码审查可追溯，非沙箱运行时无效也无害。 -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- 网络权限兜底：server 供 in-app MCP HTTP 监听本机端口（入站），client 供回写/上传等出站通信。 -->
  <key>com.apple.security.network.server</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
